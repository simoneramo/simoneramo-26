---
interface Link {
  label: string;
  url: string;
}

interface Column {
  heading: string;
  links: Link[];
}

const columns: Column[] = [
  // { heading: "Product", links: [{ label: "Features", url: "#" }] }
];
const copyright = "© 2026 Simon Eramo";

const legalLinks: Link[] = [
  // { label: "Privacy Policy", url: "#" }
];
---

<footer class="pt-6 pb-10 text-black dark:text-white">
  <div class="mx-auto px-8">
    <div
      class="flex flex-col items-center justify-between text-sm font-bold text-neutral-600 md:flex-row dark:text-neutral-400"
    >
      <div
        class="mb-4 flex flex-col items-center gap-6 md:mb-0 md:flex-row md:items-start md:gap-8"
      >
        <p>
          &copy; {new Date().getFullYear()}
          {copyright.replace(/^©\s*\d{4}\s*/, "")}
        </p>
      </div>
      <div class="flex gap-8">
        {
          legalLinks.map((link) => (
            <a
              href={link.url}
              class="relative inline-block transition-colors hover:text-black hover:after:absolute hover:after:bottom-0 hover:after:left-0 hover:after:h-[2px] hover:after:w-full hover:after:bg-black hover:after:content-[''] dark:hover:text-white dark:hover:after:bg-white"
            >
              {link.label}
            </a>
          ))
        }
        <a
          href="#"
          class="transition-colors hover:text-black dark:hover:text-white"
        >
          Back to top &uarr;
        </a>
      </div>
    </div>

    <div class="mt-8 max-w-4xl">
      <p class="text-sm font-bold text-neutral-600 dark:text-neutral-400">
        I am located on the traditional lands of the Bunurong people, part of
        the Kulin Nation, whose country extends across southeastern Victoria,
        including the Mornington Peninsula, Westernport Bay, and Wilson's
        Promontory. I pay my respects to Elders both past and present, and
        recognise and respect their abiding connection to this land, its
        waterways and community.
      </p>
    </div>
  </div>
</footer>
