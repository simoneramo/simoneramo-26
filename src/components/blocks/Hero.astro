---
interface Props {
  heading: string;
  label?: string;
  description: string;
  actions?: {
    label: string;
    link: string;
    variant: "primary" | "secondary";
  }[];
}

const { heading, label, description, actions } = Astro.props;
---

<section class="py-20 text-center">
  <div class="mx-auto max-w-4xl px-4">
    {
      label && (
        <p class="mb-4 text-sm font-bold tracking-widest text-neutral-500 uppercase">
          {label}
        </p>
      )
    }
    <h1 class="mb-6 text-5xl font-black md:text-7xl">{heading}</h1>
    <p
      class="mx-auto mb-10 max-w-2xl text-xl text-neutral-600 dark:text-neutral-400"
    >
      {description}
    </p>

    {
      actions && (
        <div class="flex flex-wrap justify-center gap-4">
          {actions.map((action) => (
            <a
              href={action.link}
              class={`rounded-full px-8 py-3 font-bold transition-all ${
                action.variant === "primary"
                  ? "bg-black text-white hover:scale-105 dark:bg-white dark:text-black"
                  : "bg-neutral-100 text-black hover:bg-neutral-200 dark:bg-neutral-800 dark:text-white"
              }`}
            >
              {action.label}
            </a>
          ))}
        </div>
      )
    }
  </div>
</section>
