---
interface Feature {
  title: string;
  description: string;
  icon: string;
}

interface Props {
  heading: string;
  items: Feature[];
}

const { heading, items } = Astro.props;
---

<section class="bg-neutral-50 py-20 dark:bg-black">
  <div class="mx-auto max-w-6xl px-4 md:px-8">
    <h2 class="mb-12 text-center text-3xl font-black">{heading}</h2>

    <div class="grid gap-8 md:grid-cols-3">
      {
        items.map((item) => (
          <div class="rounded-lg bg-white p-8 shadow-sm transition-shadow hover:shadow-md dark:bg-zinc-900">
            <div class="mb-4 text-4xl">{item.icon}</div>
            <h3 class="mb-2 text-xl font-bold">{item.title}</h3>
            <p class="text-neutral-600 dark:text-neutral-400">
              {item.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
