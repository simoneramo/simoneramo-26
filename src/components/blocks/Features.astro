---
interface Feature {
    title: string;
    description: string;
    icon: string;
}

interface Props {
    heading: string;
    items: Feature[];
}

const { heading, items } = Astro.props;
---

<section class="py-20 bg-neutral-50 dark:bg-black">
    <div class="mx-auto px-4 md:px-8 max-w-6xl">
        <h2 class="text-3xl font-black text-center mb-12">{heading}</h2>

        <div class="grid md:grid-cols-3 gap-8">
            {
                items.map((item) => (
                    <div class="p-8 bg-white dark:bg-zinc-900 rounded-lg shadow-sm hover:shadow-md transition-shadow">
                        <div class="text-4xl mb-4">{item.icon}</div>
                        <h3 class="text-xl font-bold mb-2">{item.title}</h3>
                        <p class="text-neutral-600 dark:text-neutral-400">
                            {item.description}
                        </p>
                    </div>
                ))
            }
        </div>
    </div>
</section>
