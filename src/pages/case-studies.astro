---
import MainLayout from "../layouts/MainLayout.astro";

const caseStudies = [
    {
        id: "launch-local-dashboard",
        title: "Local Launch",
        subtitle: "Full-Stack Development · DX Tools · Next.js",
        description:
            "A local dashboard to scan, launch, stop, and monitor the dev servers across your ~/Sites projects—rebuilt in v2 on a single Next.js process that pushes live state over Server-Sent Events, killing the polling, process desync, and stop bugs of the first version.",
        tags: ["Developer Tools", "Next.js", "React"],
        year: "2026",
        client: "Personal Project",
        color: "#6366f1",
        solid: "bg-indigo-100 dark:bg-indigo-900/20",
        emoji: "🚀",
        status: "available",
        href: "/case-studies/launch-local-dashboard",
        highlights: ["One process, one port — no desync", "Zero polling — SSE pushes on change", "Instant, reliable stop"],
    },
    {
        id: "rolling-mugshot",
        title: "Rolling Mugshot Online Ordering",
        subtitle: "Web App · E-commerce · Hospitality",
        description:
            "Order-ahead for a mobile coffee cart — built on Next.js 16 and Square, where online pre-orders land in Square POS alongside walk-ups. Backed by a Postgres source of truth, an idempotent webhook, a live-polling status page, and a PIN-gated kitchen queue.",
        tags: ["Web App", "Next.js", "Square"],
        year: "2026",
        client: "Rolling Mugshot",
        color: "#b45309",
        solid: "bg-amber-100 dark:bg-amber-900/20",
        emoji: "☕",
        status: "available",
        href: "/case-studies/rolling-mugshot",
        highlights: ["One queue with walk-ups in Square POS", "Exactly-once order capture", "Live status page, no texts"],
    },
    {
        id: "six-nutrition-ordering",
        title: "6Nutrition Online Ordering",
        subtitle: "Web App · E-commerce · Hospitality",
        description:
            "A pickup-first ordering web app for a Melbourne high-protein cafe — built on Next.js 16 and Stripe, with a modifier-aware menu, persistent cart, dedicated kitchen view, and webhook + reconcile cron so paid orders never get lost.",
        tags: ["Web App", "Next.js", "Stripe"],
        year: "2026",
        client: "6Nutrition",
        color: "#10b981",
        solid: "bg-emerald-100 dark:bg-emerald-900/20",
        emoji: "🥗",
        status: "available",
        href: "/case-studies/six-nutrition-ordering",
        highlights: ["<1 min order to paid", "Zero phone orders to transcribe", "100% modifier accuracy"],
    },
    {
        id: "design-prompt-builder",
        title: "Design Prompt Builder",
        subtitle: "Product Design · Prompt Engineering · Alpine.js",
        description:
            "A reactive, zero-dependency tool that eliminates the repetitive overhead of writing AI design prompts from scratch—generating a complete, structured system prompt in real-time as you fill in the brief.",
        tags: ["Developer Tools", "UI/UX", "Prompt Engineering"],
        year: "2026",
        client: "Personal Project",
        color: "#a855f7",
        solid: "bg-purple-100 dark:bg-purple-900/20",
        emoji: "🤖",
        status: "available",
        href: "/case-studies/design-prompt-builder",
        highlights: ["30 sec from blank to full prompt", "Zero repeated prompt writing", "100% consistent output structure"],
    },
    {
        id: "project-starter",
        title: "Project Starter",
        subtitle: "Developer Tools · Node.js · Scaffolding",
        description:
            "Eliminating the \"copy-paste\" project setup tax — a locally-hosted scaffold engine that copies templates, replaces all name strings recursively, generates a .env, runs npm install and git init, and logs the project registry. All in one click.",
        tags: ["Developer Tools", "Node.js", "Scaffolding"],
        year: "2026",
        client: "Personal Project",
        color: "#f97316",
        solid: "bg-orange-100 dark:bg-orange-900/20",
        emoji: "⚡",
        status: "available",
        href: "/case-studies/project-starter",
        highlights: ["5–15 min → ~2 min setup time", "Zero stray template strings", "TinaCMS-ready from first run"],
    },
    {
        id: "paul-jeffers-photography",
        title: "Paul Jeffers Photography",
        subtitle: "Website Redesign · Astro · Headless CMS",
        description:
            "Migrating a high-end Melbourne photography portfolio from Squarespace to a headless Astro architecture — achieving perfect Lighthouse scores and eliminating ~$540 AUD per year in platform costs.",
        tags: ["Website Redesign", "Astro", "Headless CMS"],
        year: "2025",
        client: "Paul Jeffers",
        color: "#0ea5e9",
        solid: "bg-sky-100 dark:bg-sky-900/20",
        emoji: "📷",
        status: "available",
        href: "/case-studies/paul-jeffers-photography",
        highlights: ["100/100 Lighthouse score", "~$540 AUD/yr saved", "1.1s LCP (Desktop)"],
    },
    {
        id: "worksafe-design-system",
        title: "WorkSafe Design System",
        subtitle: "Design Systems · Figma · Component Library",
        description:
            "Modernising the WSV Figma design system from a fragmented, legacy-heavy library to a living component framework — reducing design iteration time by 40% and eliminating legacy debt across a government-scale platform.",
        tags: ["Design System", "Accessibility", "Gov"],
        year: "2023–2024",
        client: "WorkSafe Victoria",
        color: "#FDB813",
        solid: "bg-yellow-100 dark:bg-yellow-900/20",
        emoji: "🏗️",
        status: "available",
        href: "/case-studies/worksafe-design-system",
        highlights: ["~40% faster design iteration", "80% badge library reduction", "Zero legacy components in production"],
    },
    {
        id: "lead-gen-campaigns",
        title: "Lead Generation Redesign",
        subtitle: "CRO · Visual Design · Campaign Strategy",
        description:
            "Rebuilding a high-volume campaign machine from the ground up — lifting average conversion rates from 1.5% to above 5% across 200+ property and education campaigns for clients including Mirvac, Woodlea, Melbourne Uni, and Swinburne.",
        tags: ["Conversion", "Web Design", "Strategy"],
        year: "2017–2020",
        client: "Social Garden",
        color: "#20E28F",
        solid: "bg-emerald-100 dark:bg-emerald-900/20",
        emoji: "📈",
        status: "available",
        href: "/case-studies/lead-gen-campaigns",
        highlights: ["1.5% → 5%+ conversion rate", "200+ campaigns designed", "8-person team trained in CRO"],
    },
    {
        id: "falcon-1-master-template",
        title: "Master Site Template",
        subtitle: "Full-Stack Design · Astro 5 · TinaCMS · Page Builder",
        description:
            "A production-ready Astro site template that compresses days of boilerplate setup into a single CLI command — complete with TinaCMS, a block-based page builder, WCAG 2.1 accessible components, dark mode, SEO, and a 3-tier page architecture.",
        tags: ["Development", "Astro", "Headless CMS"],
        year: "2026",
        client: "Simon Eramo Studio",
        color: "#FF6B6B",
        solid: "bg-red-100 dark:bg-red-900/20",
        emoji: "🦅",
        status: "available",
        href: "/case-studies/falcon-1-master-template",
        highlights: ["Days → minutes project setup", "30+ pre-built components", "100/100 Lighthouse out of the box"],
    },
    {
        id: "little-pigeon",
        title: "Little Pigeon Massage & Waxing",
        subtitle: "Web Design · Astro · Local SEO · Wellness Brand",
        description:
            "A calm, conversion-focused marketing site for a Melbourne wellness studio — built on Astro with image-heavy storytelling, integrated booking, gift cards, a journal, and serverless contact forms.",
        tags: ["Web Design", "Development", "Astro"],
        year: "2025",
        client: "Little Pigeon Massage & Waxing",
        color: "#f472b6",
        solid: "bg-pink-100 dark:bg-pink-900/20",
        emoji: "🕊️",
        status: "available",
        href: "/case-studies/little-pigeon",
        highlights: ["10+ purpose-built pages", "Serverless Resend contact form", "Astro 6 + Tailwind v4 stack"],
    },
];

// Lucide icon inner-SVG markup, keyed by case study id
const cardIcons: Record<string, string> = {
    "rolling-mugshot": '<path d="M10 2v2"/><path d="M14 2v2"/><path d="M16 8a1 1 0 0 1 1 1v8a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4V9a1 1 0 0 1 1-1h14a4 4 0 1 1 0 8h-1"/><path d="M6 2v2"/>',
    "six-nutrition-ordering": '<path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/>',
    "launch-local-dashboard": '<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>',
    "design-prompt-builder": '<path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/>',
    "project-starter": '<path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/>',
    "paul-jeffers-photography": '<path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/>',
    "worksafe-design-system": '<rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/>',
    "lead-gen-campaigns": '<polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/>',
    "falcon-1-master-template": '<path d="M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5z"/><line x1="16" x2="2" y1="8" y2="22"/><line x1="17.5" x2="9" y1="15" y2="15"/>',
    "little-pigeon": '<path d="M16 7h.01"/><path d="M3.4 18H12a8 8 0 0 0 8-8V7a4 4 0 0 0-7.28-2.3L2 20"/><path d="m20 7 2 .5-2 .5"/><path d="M10 18v3"/><path d="M14 17.75V21"/><path d="M7 18a6 6 0 0 0 3.84-10.61"/>',
};

const tagColors: Record<string, string> = {
    "Product Design": "bg-violet-100 text-violet-800 dark:bg-violet-900/30 dark:text-violet-300",
    "AI/ML": "bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300",
    Mobile: "bg-teal-100 text-teal-800 dark:bg-teal-900/30 dark:text-teal-300",
    "Design System": "bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-300",
    Accessibility: "bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300",
    Gov: "bg-slate-100 text-slate-800 dark:bg-slate-900/30 dark:text-slate-300",
    Conversion: "bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-300",
    "Web Design": "bg-cyan-100 text-cyan-800 dark:bg-cyan-900/30 dark:text-cyan-300",
    Strategy: "bg-orange-100 text-orange-800 dark:bg-orange-900/30 dark:text-orange-300",
    Development: "bg-pink-100 text-pink-800 dark:bg-pink-900/30 dark:text-pink-300",
    Astro: "bg-indigo-100 text-indigo-800 dark:bg-indigo-900/30 dark:text-indigo-300",
    "Headless CMS": "bg-rose-100 text-rose-800 dark:bg-rose-900/30 dark:text-rose-300",
    "UX Research": "bg-purple-100 text-purple-800 dark:bg-purple-900/30 dark:text-purple-300",
    Prototyping: "bg-fuchsia-100 text-fuchsia-800 dark:bg-fuchsia-900/30 dark:text-fuchsia-300",
    "A/B Testing": "bg-lime-100 text-lime-800 dark:bg-lime-900/30 dark:text-lime-300",
    Figma: "bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-300",
    "Developer Tools": "bg-indigo-100 text-indigo-800 dark:bg-indigo-900/30 dark:text-indigo-300",
    React: "bg-sky-100 text-sky-800 dark:bg-sky-900/30 dark:text-sky-300",
    "Node.js": "bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300",
    "Prompt Engineering": "bg-purple-100 text-purple-800 dark:bg-purple-900/30 dark:text-purple-300",
    "UI/UX": "bg-fuchsia-100 text-fuchsia-800 dark:bg-fuchsia-900/30 dark:text-fuchsia-300",
    "Website Redesign": "bg-sky-100 text-sky-800 dark:bg-sky-900/30 dark:text-sky-300",
    Scaffolding: "bg-orange-100 text-orange-800 dark:bg-orange-900/30 dark:text-orange-300",
    "Web App": "bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-300",
    "Next.js": "bg-zinc-100 text-zinc-800 dark:bg-zinc-800 dark:text-zinc-200",
    Stripe: "bg-violet-100 text-violet-800 dark:bg-violet-900/30 dark:text-violet-300",
    Square: "bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-300",
};
---

<MainLayout
    title="Case Studies | Simon Eramo"
    description="A curated collection of design and development case studies by Simon Eramo—covering product design, design systems, conversion optimisation, and headless web platforms."
>
    <!-- Hero Section -->
    <section class="py-20 md:py-28">
        <div class="px-4 md:px-8">
            <div class="max-w-3xl">
                <p
                    class="text-xs font-bold uppercase tracking-widest text-neutral-500 dark:text-neutral-400 mb-4"
                >
                    Selected Work
                </p>
                <h1
                    id="case-studies-heading"
                    class="text-5xl md:text-6xl font-black mb-6 text-pretty leading-tighter"
                >
                    What I've been building
                </h1>
                <p
                    class="text-lg md:text-xl font-regular text-neutral-600 dark:text-neutral-400 max-w-2xl leading-relaxed"
                >
                    A curated portfolio of real projects from design systems and AI tools to
                    conversion campaigns and headless web platforms. Each one grounded in
                    research, craft, and measurable impact.
                </p>
            </div>
        </div>
    </section>

    <!-- Case Studies Grid -->
    <section class="pb-24" id="case-studies-grid">
        <div class="px-4 md:px-8">
            <div class="grid md:grid-cols-2 gap-8">
                {
                    caseStudies.map((study) => {
                        const CardTag = study.status === "available" ? "a" : "article";
                        return (
                        <CardTag
                            href={study.status === "available" ? study.href : undefined}
                            aria-label={study.status === "available" ? `Read case study: ${study.title}` : undefined}
                            class={`group relative flex flex-col rounded-2xl border-2 border-zinc-100 dark:border-zinc-700/50 overflow-hidden transition-colors ${study.status === "available" ? "hover:border-black dark:hover:border-white" : "opacity-70"}`}
                        >
                            <!-- Card Header / Visual -->
                            <div
                                class={`relative ${study.solid} p-8 md:p-10 flex items-center justify-between min-h-[180px] overflow-hidden`}
                            >
                                <div class="flex flex-col gap-3 relative z-10">
                                    <span class="flex items-center justify-center w-12 h-12 rounded-xl bg-white/70 dark:bg-white/10 text-black dark:text-white">
                                        <svg
                                            xmlns="http://www.w3.org/2000/svg"
                                            width="24"
                                            height="24"
                                            viewBox="0 0 24 24"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="2"
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            aria-hidden="true"
                                            set:html={cardIcons[study.id]}
                                        />
                                    </span>
                                    <div class="flex flex-wrap gap-2">
                                        {study.tags.map((tag) => (
                                            <span
                                                class={`text-xs font-bold px-2.5 py-1 rounded-full ${tagColors[tag] ?? "bg-zinc-100 text-zinc-800 dark:bg-zinc-700 dark:text-zinc-200"}`}
                                            >
                                                {tag}
                                            </span>
                                        ))}
                                    </div>
                                </div>

                                <div class="relative z-10 text-right shrink-0">
                                    <span
                                        class="block text-xs font-bold uppercase tracking-widest text-neutral-500 dark:text-neutral-400 mb-1"
                                    >
                                        {study.client}
                                    </span>
                                    <span
                                        class="block text-2xl font-black text-neutral-400 dark:text-zinc-600"
                                    >
                                        {study.year}
                                    </span>
                                </div>
                            </div>

                            <!-- Card Body -->
                            <div class="p-8 md:p-10 flex flex-col flex-1">
                                <p
                                    class="text-xs font-bold uppercase tracking-widest text-neutral-500 dark:text-neutral-400 mb-2"
                                >
                                    {study.subtitle}
                                </p>
                                <h2 class="text-2xl font-black mb-3 text-neutral-900 dark:text-white">
                                    {study.title}
                                </h2>
                                <p class="text-neutral-600 dark:text-neutral-400 font-medium leading-relaxed mb-4 flex-1">
                                    {study.description}
                                </p>

                                {/* Highlights / key outcomes */}
                                {'highlights' in study && study.highlights && (
                                    <ul class="flex flex-col gap-1.5 mb-6">
                                        {(study.highlights as string[]).map((h) => (
                                            <li class="flex items-center gap-2 text-sm font-semibold text-neutral-700 dark:text-neutral-300">
                                                <span class="w-1.5 h-1.5 rounded-full bg-indigo-500 shrink-0" />
                                                {h}
                                            </li>
                                        ))}
                                    </ul>
                                )}

                                <!-- CTA -->
                                {study.status === "available" ? (
                                    <span
                                        class="inline-flex items-center gap-2 font-bold text-black dark:text-white transition-all duration-200 group-hover:gap-4"
                                    >
                                        Read case study
                                        <svg
                                            xmlns="http://www.w3.org/2000/svg"
                                            width="18"
                                            height="18"
                                            viewBox="0 0 24 24"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="2.5"
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            class="transition-transform duration-200 group-hover:translate-x-1"
                                            aria-hidden="true"
                                        >
                                            <path d="M5 12h14" />
                                            <path d="m12 5 7 7-7 7" />
                                        </svg>
                                    </span>
                                ) : (
                                    <span class="inline-flex items-center gap-2 font-bold text-neutral-400 dark:text-neutral-600 cursor-not-allowed">
                                        <span class="w-2 h-2 rounded-full bg-yellow-400 animate-pulse" />
                                        Coming soon
                                    </span>
                                )}
                            </div>
                        </CardTag>
                        );
                    })
                }
            </div>
        </div>
    </section>

    <!-- CTA / Contact Section -->
    <section class="py-20">
        <div class="container mx-auto px-4 md:px-8 max-w-3xl text-center">

            <p
                class="text-xs font-bold uppercase tracking-widest text-neutral-500 dark:text-neutral-400 mb-3"
            >
                Get in touch
            </p>
            <h2 class="text-4xl md:text-5xl font-black mb-4">
                Have a project in mind?
            </h2>
            <p
                class="text-lg font-medium text-neutral-600 dark:text-neutral-400 mb-10 max-w-xl mx-auto leading-relaxed"
            >
                I'm always open to new work and collaborations—whether you need a product designed, a site built, or a fresh pair of eyes on something. Tell me what you're working on and I'll get back to you.
            </p>
            <div class="flex flex-col sm:flex-row justify-center gap-4">
               
                <a
                    href="/#contact"
                    id="case-studies-work-cta"
                    class="inline-flex items-center justify-center h-14 px-10 font-bold border-2 border-zinc-200 dark:border-zinc-700 rounded-md hover:border-black dark:hover:border-white transition-colors duration-200"
                >
                    Contact
                </a>
            </div>
        </div>
    </section>
</MainLayout>
