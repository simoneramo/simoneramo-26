---
import MainLayout from "../../layouts/MainLayout.astro";

const caseStudy = {
    title: "Paul Jeffers Photography",
    subtitle: "Migrating a high-end Melbourne photography portfolio from Squarespace to a headless Astro architecture",
    client: "Paul Jeffers",
    year: "2025",
    role: "Designer & Full-Stack Developer",
    stack: ["Astro v5", "TinaCMS", "Cloudinary", "Tailwind CSS v4", "Alpine.js", "Vercel"],
    tags: ["Website Redesign", "Astro", "Headless CMS"],
    emoji: "📷",
};

const outcomes = [
    { value: "100", label: "Lighthouse Score" },
    { value: "1.1s", label: "LCP (Desktop)" },
    { value: "$0", label: "Monthly Cost" },
    { value: "~$2.7k", label: "5-Year Savings" },
];

const lighthouseScores = [
    { category: "Performance", before: 48, after: 100 },
    { category: "Accessibility", before: 92, after: 100 },
    { category: "Best Practices", before: 75, after: 100 },
    { category: "SEO", before: 92, after: 100 },
];

const coreWebVitals = [
    { metric: "LCP", value: "1.1s", label: "Excellent" },
    { metric: "FCP", value: "0.8s", label: "Fast" },
    { metric: "TBT", value: "10ms", label: "Minimal" },
    { metric: "CLS", value: "0.002", label: "Near zero" },
    { metric: "Speed Index", value: "1.9s", label: "Fast" },
];

const problems = [
    {
        title: "Performance Degradation",
        description:
            "Squarespace's one-size-fits-all rendering led to slow loading times and poor Core Web Vitals for a high-resolution image portfolio.",
    },
    {
        title: "High Recurring Costs",
        description:
            "A professional-tier Squarespace subscription ran ~$45 AUD/month — a significant overhead for a sole operator.",
    },
    {
        title: "Unoptimised Asset Delivery",
        description:
            "High-res images were not being served in modern formats or resized dynamically, hurting mobile and desktop experiences alike.",
    },
    {
        title: "Limited Customisation",
        description:
            "Squarespace's proprietary template system blocked the fine-tuned aesthetic control required for a premium photography brand.",
    },
];

const solutions = [
    {
        letter: "A",
        title: "Advanced Image Optimisation via Cloudinary",
        description:
            "By integrating Cloudinary into the TinaCMS schema, we fundamentally changed how assets are managed. Custom utilities pull images with specific URL transformations (converting to WebP/AVIF, resizing on-the-fly) — a massive leap over Squarespace's static image handling.",
    },
    {
        letter: "B",
        title: "Lightweight Interactivity — Zero JS by Default",
        description:
            "Rather than shipping bulky React payloads for a homepage carousel, we used Astro's selective hydration combined with isolated Alpine.js reactivity and CSS transitions. The result: a six-second fading carousel with zero heavy bundle scripts.",
    },
    {
        letter: "C",
        title: "Visual Headless Content Workflow",
        description:
            "Strict TinaCMS content schemas were built for editorial galleries, corporate events, and documentary stories. Paul can now create visually rich narratives pairing text and high-resolution galleries without any developer assistance — changes commit directly to Git as Markdown frontmatter.",
    },
    {
        letter: "D",
        title: "Component Refactoring & Streamlined UX",
        description:
            "The codebase was refactored to use modern, reusable Astro components and consolidated generic layouts. A smooth navigation flow clearly separates Editorial, Stories, and Corporate work with premium typography that foregrounds the photography itself.",
    },
];

const costRows = [
    { expense: "Hosting & Platform", squarespace: "Paid subscription", newStack: "$0" },
    { expense: "CMS", squarespace: "Included in fee", newStack: "$0 (Open source)" },
    { expense: "Media / CDN", squarespace: "Included (unoptimised)", newStack: "$0 (Free tier)" },
    { expense: "Monthly total", squarespace: "~$45 AUD", newStack: "~$0 AUD", bold: true },
    { expense: "Yearly total", squarespace: "~$540 AUD", newStack: "~$0 AUD", bold: true },
    { expense: "5-Year lifecycle", squarespace: "~$2,700 AUD", newStack: "~$0 AUD", bold: true },
];

const projectDetails = [
    { label: "Client", value: "Paul Jeffers" },
    { label: "Industry", value: "Photography" },
    { label: "Location", value: "Melbourne, VIC" },
    { label: "Type", value: "Website Redesign & Migration" },
    { label: "Previous Platform", value: "Squarespace" },
];
---

<MainLayout
    title="Paul Jeffers Photography — Case Study | Simon Eramo"
    description="How I migrated a high-end Melbourne photography portfolio from Squarespace to a headless Astro architecture — achieving perfect Lighthouse scores and eliminating ~$540 AUD per year in platform costs."
>
    <!-- Hero -->
    <section class="py-20 md:py-28 border-b-2 border-zinc-100 dark:border-zinc-800">
        <div class="px-4 md:px-8">
            <div class="flex items-center gap-3 mb-8">
                <a
                    href="/case-studies"
                    class="inline-flex items-center gap-1.5 text-sm font-bold text-neutral-500 dark:text-neutral-400 hover:text-black dark:hover:text-white transition-colors"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
                    Case Studies
                </a>
                <span class="text-neutral-300 dark:text-neutral-600">/</span>
                <span class="text-xs font-bold uppercase tracking-widest text-neutral-400">Website Redesign</span>
            </div>

            <div class="max-w-4xl">
                <p class="text-xs font-bold uppercase tracking-widest text-neutral-500 dark:text-neutral-400 mb-4">
                    {caseStudy.client} · {caseStudy.year}
                </p>
                <div class="flex items-start gap-5 mb-6">
                    <span class="text-6xl md:text-7xl shrink-0 mt-1" aria-hidden="true">{caseStudy.emoji}</span>
                    <h1
                        id="case-study-heading"
                        class="text-4xl md:text-6xl font-black leading-tight text-pretty"
                    >
                        {caseStudy.title}
                    </h1>
                </div>
                <p class="text-xl font-medium text-neutral-600 dark:text-neutral-400 mb-8 max-w-2xl leading-relaxed">
                    {caseStudy.subtitle} — achieving perfect Lighthouse scores and eliminating <strong class="text-bold dark:text-white">~$540 AUD per year</strong> in platform costs.
                </p>

                <div class="flex flex-wrap items-center gap-4 mb-8">
                    <a
                        href="https://pauljeffers.vercel.app"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-2 font-bold text-sm px-4 py-2 rounded-full border-2 border-zinc-200 dark:border-zinc-700 hover:border-black dark:hover:border-white transition-colors"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>
                        View live site
                    </a>
                </div>

                <!-- Meta strip -->
                <div class="flex flex-wrap gap-6 pt-8 border-t-2 border-zinc-100 dark:border-zinc-800">
                    <div>
                        <p class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-1">Role</p>
                        <p class="font-bold text-sm">{caseStudy.role}</p>
                    </div>
                    <div>
                        <p class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-1">Year</p>
                        <p class="font-bold text-sm">{caseStudy.year}</p>
                    </div>
                    <div>
                        <p class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-1">Stack</p>
                        <p class="font-bold text-sm">{caseStudy.stack.join(" · ")}</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Outcomes -->
    <section class="py-16 bg-zinc-50 dark:bg-neutral-900">
        <div class="px-4 md:px-8">
            <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-4xl mx-auto text-center">
                {outcomes.map((o) => (
                    <div class="p-6 md:p-8 rounded-2xl border-2 border-zinc-200 dark:border-zinc-700/50 bg-white dark:bg-zinc-900">
                        <span class="block text-3xl md:text-5xl font-black mb-2 text-black dark:text-white">
                            {o.value}
                        </span>
                        <span class="text-xs font-bold text-neutral-500 dark:text-neutral-400 uppercase tracking-widest">
                            {o.label}
                        </span>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Project Details + Challenge -->
    <section class="py-20">
        <div class="px-4 md:px-8">
            <div class="grid md:grid-cols-3 gap-12 max-w-6xl">
                <!-- Project details sidebar -->
                <div class="md:col-span-1">
                    <p class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-3">Project Details</p>
                    <div class="space-y-4">
                        {projectDetails.map((d) => (
                            <div>
                                <p class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-0.5">{d.label}</p>
                                <p class="font-bold text-sm">{d.value}</p>
                            </div>
                        ))}
                        <div>
                            <p class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-2">Tech Stack</p>
                            <div class="flex flex-col gap-1">
                                {[
                                    { name: "Astro v5", role: "Framework" },
                                    { name: "TinaCMS", role: "Headless CMS" },
                                    { name: "Cloudinary", role: "Media CDN" },
                                    { name: "Tailwind CSS v4", role: "Styling" },
                                    { name: "Alpine.js", role: "Interactivity" },
                                    { name: "Vercel", role: "Deployment" },
                                ].map((t) => (
                                    <div class="flex items-center justify-between py-1.5 border-b border-zinc-100 dark:border-zinc-800">
                                        <span class="font-black text-sm">{t.name}</span>
                                        <span class="text-xs text-neutral-500 dark:text-neutral-400 font-medium">{t.role}</span>
                                    </div>
                                ))}
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Challenge -->
                <div class="md:col-span-2 space-y-8">
                    <div>
                        <p class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-3">The Challenge</p>
                        <h2 class="text-3xl font-black mb-5">Moving Beyond Squarespace</h2>
                        <p class="text-lg font-medium text-neutral-700 dark:text-neutral-300 leading-relaxed mb-8">
                            Paul Jeffers runs a high-end Melbourne photography practice spanning editorial, corporate, and portrait work. His portfolio, hosted on Squarespace, was struggling to keep pace with the demands of an image-heavy, SEO-sensitive business.
                        </p>
                        <div class="space-y-5">
                            {problems.map((p) => (
                                <div class="flex gap-4">
                                    <span class="mt-1 w-2 h-2 rounded-full bg-red-500 shrink-0" />
                                    <div>
                                        <h3 class="font-black text-base mb-1">{p.title}</h3>
                                        <p class="text-neutral-600 dark:text-neutral-400 font-medium leading-relaxed text-sm">{p.description}</p>
                                    </div>
                                </div>
                            ))}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Lighthouse Performance -->
    <section class="py-20 bg-zinc-50 dark:bg-neutral-900">
        <div class="px-4 md:px-8">
            <div class="grid md:grid-cols-3 gap-12 max-w-6xl">
                <div class="md:col-span-1">
                    <p class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-3">Performance</p>
                    <h2 class="text-3xl font-black mb-4">Lighthouse: Old vs. New</h2>
                    <p class="text-neutral-600 dark:text-neutral-400 font-medium leading-relaxed text-sm">
                        A laser focus on Core Web Vitals from day one meant the new site achieved perfect scores across all four Lighthouse categories upon its first production deployment.
                    </p>
                </div>
                <div class="md:col-span-2 space-y-8">
                    <!-- Lighthouse comparison bars -->
                    <div class="space-y-5">
                        {lighthouseScores.map((s) => (
                            <div>
                                <div class="flex items-center justify-between mb-2">
                                    <span class="font-black text-sm">{s.category}</span>
                                    <div class="flex items-center gap-3 text-sm font-bold">
                                        <span class="text-red-500">{s.before}/100</span>
                                        <span class="text-neutral-400">→</span>
                                        <span class="text-green-500">{s.after}/100</span>
                                    </div>
                                </div>
                                <div class="relative h-3 bg-zinc-200 dark:bg-zinc-700 rounded-full overflow-hidden">
                                    <!-- Before bar (ghosted) -->
                                    <div
                                        class="absolute inset-y-0 left-0 bg-red-300 dark:bg-red-900 rounded-full opacity-50"
                                        style={`width: ${s.before}%`}
                                    />
                                    <!-- After bar -->
                                    <div
                                        class="absolute inset-y-0 left-0 bg-green-500 rounded-full"
                                        style={`width: ${s.after}%`}
                                    />
                                </div>
                            </div>
                        ))}
                    </div>

                    <!-- Core Web Vitals -->
                    <div>
                        <p class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-4">Core Web Vitals (Desktop)</p>
                        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
                            {coreWebVitals.map((v) => (
                                <div class="p-4 rounded-xl border-2 border-zinc-200 dark:border-zinc-700/50 bg-white dark:bg-zinc-900">
                                    <p class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-1">{v.metric}</p>
                                    <p class="text-2xl font-black text-green-500 mb-0.5">{v.value}</p>
                                    <p class="text-xs font-bold text-neutral-500">{v.label}</p>
                                </div>
                            ))}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Solutions -->
    <section class="py-20">
        <div class="px-4 md:px-8">
            <div class="grid md:grid-cols-3 gap-12 max-w-6xl">
                <div class="md:col-span-1">
                    <p class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-3">Solutions</p>
                    <h2 class="text-3xl font-black mb-4">How We Solved It</h2>
                </div>
                <div class="md:col-span-2 space-y-6">
                    {solutions.map((s) => (
                        <div class="flex gap-5 p-6 rounded-xl border-2 border-zinc-200 dark:border-zinc-700/50 bg-white dark:bg-zinc-900 hover:border-zinc-400 dark:hover:border-zinc-500 transition-colors">
                            <span class="w-9 h-9 rounded-lg bg-black dark:bg-white text-white dark:text-black font-black text-sm flex items-center justify-center shrink-0">
                                {s.letter}
                            </span>
                            <div>
                                <h3 class="font-black text-base mb-2">{s.title}</h3>
                                <p class="text-neutral-600 dark:text-neutral-400 font-medium leading-relaxed text-sm">
                                    {s.description}
                                </p>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <!-- Cost Analysis -->
    <section class="py-20 bg-zinc-50 dark:bg-neutral-900">
        <div class="px-4 md:px-8">
            <div class="grid md:grid-cols-3 gap-12 max-w-6xl">
                <div class="md:col-span-1">
                    <p class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-3">Cost Analysis</p>
                    <h2 class="text-3xl font-black mb-4">The Real Financial Impact</h2>
                    <p class="text-neutral-600 dark:text-neutral-400 font-medium leading-relaxed text-sm">
                        Moving off Squarespace wasn't just a performance win — it fundamentally changed the economics of running Paul's online presence.
                    </p>
                </div>
                <div class="md:col-span-2">
                    <div class="rounded-xl overflow-hidden border-2 border-zinc-200 dark:border-zinc-700/50">
                        <table class="w-full text-sm">
                            <thead>
                                <tr class="bg-zinc-100 dark:bg-zinc-800">
                                    <th class="text-left px-5 py-3 font-black text-xs uppercase tracking-widest text-neutral-500">Expense</th>
                                    <th class="text-left px-5 py-3 font-black text-xs uppercase tracking-widest text-neutral-500">Squarespace</th>
                                    <th class="text-left px-5 py-3 font-black text-xs uppercase tracking-widest text-green-600 dark:text-green-400">New Stack</th>
                                </tr>
                            </thead>
                            <tbody>
                                {costRows.map((row) => (
                                    <tr class={`border-t border-zinc-100 dark:border-zinc-800 ${row.bold ? "bg-zinc-50 dark:bg-zinc-800/50" : "bg-white dark:bg-zinc-900"}`}>
                                        <td class={`px-5 py-3.5 ${row.bold ? "font-black" : "font-medium text-neutral-700 dark:text-neutral-300"}`}>{row.expense}</td>
                                        <td class={`px-5 py-3.5 text-red-600 dark:text-red-400 ${row.bold ? "font-black" : "font-medium"}`}>{row.squarespace}</td>
                                        <td class={`px-5 py-3.5 text-green-600 dark:text-green-400 ${row.bold ? "font-black" : "font-medium"}`}>{row.newStack}</td>
                                    </tr>
                                ))}
                            </tbody>
                        </table>
                    </div>
                    <p class="mt-4 text-sm font-medium text-neutral-500 dark:text-neutral-400 leading-relaxed">
                        Unlike proprietary platforms where costs increase annually, this headless architecture means Paul owns his data and code — enabling free hosting on global edge networks.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Result -->
    <section class="py-20">
        <div class="px-4 md:px-8">
            <div class="grid md:grid-cols-3 gap-12 max-w-6xl">
                <div class="md:col-span-1">
                    <p class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-3">Result</p>
                    <h2 class="text-3xl font-black mb-4">A Portfolio Built for the Long Haul</h2>
                </div>
                <div class="md:col-span-2 space-y-6">
                    <p class="text-lg font-medium text-neutral-700 dark:text-neutral-300 leading-relaxed">
                        The migration has redefined the Paul Jeffers web experience. The site loads instantly, achieves 100/100 across all Google Lighthouse audits, handles image optimisation automatically via Cloudinary, and completely removes server bottlenecks.
                    </p>
                    <p class="text-lg font-medium text-neutral-700 dark:text-neutral-300 leading-relaxed">
                        Under the hood, the transition dramatically reduces repository bloat while providing a future-proof infrastructure natively hooked up to visual Markdown editing — perfect for continuous, effortless content publishing.
                    </p>
                    <ul class="space-y-4 pt-2">
                        <li class="flex items-start gap-3 text-neutral-700 dark:text-neutral-300 font-medium text-lg">
                            <span class="mt-1.5 w-2 h-2 rounded-full bg-green-500 shrink-0" />
                            <span><strong class="text-black dark:text-white">100/100</strong> across all four Google Lighthouse categories on first production deploy.</span>
                        </li>
                        <li class="flex items-start gap-3 text-neutral-700 dark:text-neutral-300 font-medium text-lg">
                            <span class="mt-1.5 w-2 h-2 rounded-full bg-green-500 shrink-0" />
                            <span><strong class="text-black dark:text-white">~$540 AUD/year</strong> eliminated in platform costs, ~$2,700 over five years.</span>
                        </li>
                        <li class="flex items-start gap-3 text-neutral-700 dark:text-neutral-300 font-medium text-lg">
                            <span class="mt-1.5 w-2 h-2 rounded-full bg-green-500 shrink-0" />
                            <span><strong class="text-black dark:text-white">Zero-developer content publishing</strong> via visual TinaCMS editing committed directly to Git.</span>
                        </li>
                    </ul>

                    <div class="pt-2">
                        <a
                            href="https://pauljeffers.vercel.app"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="group relative inline-flex items-center justify-center overflow-hidden h-12 px-8 font-bold text-white bg-black dark:bg-white dark:text-black transition-all duration-300 rounded-md"
                        >
                            <span class="transform transition-transform duration-300 group-hover:-translate-x-4">
                                Visit pauljeffers.vercel.app
                            </span>
                            <span class="absolute right-5 transform -translate-x-4 opacity-0 transition-all duration-300 group-hover:translate-x-0 group-hover:opacity-100">
                                &rarr;
                            </span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Next / Back nav -->
    <section class="py-16 border-t-2 border-zinc-100 dark:border-zinc-800">
        <div class="px-4 md:px-8 flex flex-col sm:flex-row items-center justify-between gap-6">
            <a
                href="/case-studies"
                class="inline-flex items-center gap-2 font-bold text-neutral-500 dark:text-neutral-400 hover:text-black dark:hover:text-white transition-colors"
            >
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
                All case studies
            </a>
            <a
                href="/#contact"
                class="group relative inline-flex items-center justify-center overflow-hidden h-12 px-8 font-bold text-white bg-black dark:bg-white dark:text-black transition-all duration-300 rounded-md"
            >
                <span class="transform transition-transform duration-300 group-hover:-translate-x-4">
                    Get in touch
                </span>
                <span class="absolute right-5 transform -translate-x-4 opacity-0 transition-all duration-300 group-hover:translate-x-0 group-hover:opacity-100">
                    &rarr;
                </span>
            </a>
        </div>
    </section>
</MainLayout>
