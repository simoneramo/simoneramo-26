---
import MainLayout from "../../layouts/MainLayout.astro";

const caseStudy = {
  title: "Rolling Mugshot Online Ordering",
  subtitle:
    "Order-Ahead for a Mobile Coffee Cart, Wired Straight into Square POS",
  client: "Rolling Mugshot",
  year: "2026",
  role: "Product Designer & Full-Stack Developer",
  stack: [
    "Next.js 16",
    "App Router",
    "React 19",
    "Tailwind CSS",
    "shadcn/ui",
    "Square",
    "Neon Postgres",
    "Resend",
    "Vercel",
  ],
  tags: ["Web App", "E-commerce", "Hospitality"],
  emoji: "☕",
};

const features = [
  {
    icon: "🔗",
    title: "Square Payment Links",
    description:
      "Checkout creates a real Square Order plus a hosted Payment Link, so online pre-orders land in Square POS right alongside walk-up sales — one queue, one source of takings, no double entry.",
  },
  {
    icon: "🗄️",
    title: "Postgres Source of Truth",
    description:
      "Every paid order is written to a Neon Postgres `orders` table — the canonical record the kitchen view, status page, and receipts all read from, independent of Square's dashboard.",
  },
  {
    icon: "🛡️",
    title: "Idempotent Webhook",
    description:
      "The Square order ID is a UNIQUE column and the webhook does INSERT … ON CONFLICT DO NOTHING — so retried `payment.updated` events can never create a duplicate order at the window.",
  },
  {
    icon: "📟",
    title: "Live Order Status Page",
    description:
      'After paying, customers land on a status screen that polls every 3 seconds — walking from "Order received" to "Preparing" to "Ready for pickup" without a refresh or a text message.',
  },
  {
    icon: "👨‍🍳",
    title: "PIN-Gated Kitchen Queue",
    description:
      "A dedicated /kitchen view, protected by a signed HMAC cookie + shared PIN, lets cart staff advance each order paid → preparing → ready → collected on a glanceable counter tablet.",
  },
  {
    icon: "✉️",
    title: "Dual Resend Emails + Reconcile Cron",
    description:
      "Each paid order fires two Resend emails — a kitchen ticket and a customer receipt — while a reconcile route polls Square for any payment the webhook missed, so nothing slips through.",
  },
];

const outcomes = [
  { value: "1 POS", label: "Walk-ups + online in a single queue" },
  { value: "~2s", label: "From payment to kitchen ticket" },
  { value: "0", label: "Duplicate orders, via idempotent webhook" },
];

const problems = [
  "A growing queue at the cart window during the morning rush",
  "Walk-up sales and any online channel living in two separate systems to reconcile",
  "No way for staff to see what's coming before a customer reaches the window",
  "Dropped or duplicated orders whenever a payment webhook is retried",
  "No digital receipt trail for customers paying ahead",
];
---

<MainLayout
  title="Rolling Mugshot Online Ordering — Case Study | Simon Eramo"
  description="How I designed and built order-ahead for the Rolling Mugshot mobile coffee cart — a Next.js 16 + Square app where online pre-orders land in Square POS alongside walk-ups, backed by a Postgres source of truth, an idempotent webhook, a live status page, and a PIN-gated kitchen queue."
>
  <!-- Hero -->
  <section
    class="border-b-2 border-zinc-100 py-20 md:py-28 dark:border-zinc-800"
  >
    <div class="px-4 md:px-8">
      <div class="mb-8 flex items-center gap-3">
        <a
          href="/case-studies"
          class="inline-flex items-center gap-1.5 text-sm font-bold text-neutral-500 transition-colors hover:text-black dark:text-neutral-400 dark:hover:text-white"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"><path d="m15 18-6-6 6-6"></path></svg
          >
          Case Studies
        </a>
      </div>

      <div class="max-w-4xl">
        <p
          class="mb-4 text-xs font-bold tracking-widest text-neutral-500 uppercase dark:text-neutral-400"
        >
          {caseStudy.client} · {caseStudy.year}
        </p>
        <div class="mb-6 flex items-start gap-5">
          <span class="mt-1 shrink-0 text-6xl md:text-7xl" aria-hidden="true"
            >{caseStudy.emoji}</span
          >
          <h1
            id="case-study-heading"
            class="text-4xl leading-tight font-black text-pretty md:text-6xl"
          >
            {caseStudy.title}
          </h1>
        </div>
        <p
          class="mb-8 max-w-4xl text-xl leading-relaxed font-medium text-neutral-600 dark:text-neutral-400"
        >
          {caseStudy.subtitle}
        </p>

        <!-- Meta strip -->
        <div
          class="flex flex-wrap gap-6 border-t-2 border-zinc-100 pt-8 dark:border-zinc-800"
        >
          <div>
            <p
              class="mb-1 text-xs font-bold tracking-widest text-neutral-400 uppercase"
            >
              Role
            </p>
            <p class="text-sm font-bold">{caseStudy.role}</p>
          </div>
          <div>
            <p
              class="mb-1 text-xs font-bold tracking-widest text-neutral-400 uppercase"
            >
              Year
            </p>
            <p class="text-sm font-bold">{caseStudy.year}</p>
          </div>
          <div>
            <p
              class="mb-1 text-xs font-bold tracking-widest text-neutral-400 uppercase"
            >
              Stack
            </p>
            <p class="text-sm font-bold">
              {caseStudy.stack.join(" · ")}
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Executive Summary -->
  <section class="py-20">
    <div class="px-4 md:px-8">
      <div class="grid max-w-6xl gap-12 md:grid-cols-3">
        <div class="md:col-span-1">
          <p
            class="mb-3 text-xs font-bold tracking-widest text-neutral-400 uppercase"
          >
            Overview
          </p>
          <h2 class="mb-4 text-3xl font-black">Executive Summary</h2>
        </div>
        <div class="md:col-span-2">
          <p
            class="text-lg leading-relaxed font-medium text-neutral-700 dark:text-neutral-300"
          >
            <strong class="text-black dark:text-white"
              >Rolling Mugshot Online Ordering</strong
            > lets customers browse the menu, order ahead, pay online, and collect
            at the truck window — without standing in the morning queue. Orders flow
            through Square Payment Links so they land in Square POS <em
              >alongside</em
            > walk-ups, write to a Postgres source of truth, surface to staff in a
            PIN-gated kitchen view, and confirm to the customer on a live-polling
            status page. An idempotent webhook plus a reconcile cron make sure every
            paid order arrives exactly once — all deployed on Vercel.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Outcomes -->
  <section class="bg-zinc-50 py-16 dark:bg-neutral-900">
    <div class="px-4 md:px-8">
      <div
        class="mx-auto grid max-w-4xl grid-cols-1 gap-8 text-center md:grid-cols-3"
      >
        {
          outcomes.map((o) => (
            <div class="rounded-2xl border-2 border-zinc-200 bg-white p-8 dark:border-zinc-700/50 dark:bg-zinc-900">
              <span class="mb-2 block text-4xl font-black text-black md:text-5xl dark:text-white">
                {o.value}
              </span>
              <span class="text-sm font-bold tracking-widest text-neutral-500 uppercase dark:text-neutral-400">
                {o.label}
              </span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- The Problem -->
  <section class="py-20">
    <div class="px-4 md:px-8">
      <div class="grid max-w-6xl gap-12 md:grid-cols-3">
        <div class="md:col-span-1">
          <p
            class="mb-3 text-xs font-bold tracking-widest text-neutral-400 uppercase"
          >
            The Challenge
          </p>
          <h2 class="mb-4 text-3xl font-black">
            A Queue at the Window and Two Systems to Reconcile
          </h2>
        </div>
        <div class="space-y-6 md:col-span-2">
          <p
            class="text-lg leading-relaxed font-medium text-neutral-700 dark:text-neutral-300"
          >
            A mobile coffee cart lives and dies by throughput at peak. Rolling
            Mugshot needed to take orders ahead of time without bolting on a
            second point-of-sale to reconcile at the end of the day. The hard
            part isn't the menu — it's making sure an online order behaves <strong
              class="text-black dark:text-white">exactly like a walk-up</strong
            >: same till, same queue, counted once, never lost.
          </p>
          <ul class="space-y-3">
            {
              problems.map((p) => (
                <li class="flex items-start gap-3 font-medium text-neutral-700 dark:text-neutral-400">
                  <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-red-500" />
                  {p}
                </li>
              ))
            }
          </ul>
          <div
            class="rounded-xl border-l-4 border-red-500 bg-red-50 p-6 dark:bg-red-950/30"
          >
            <p class="text-lg font-bold text-red-800 dark:text-red-300">
              "Two-till drift" — the moment online orders live in a separate
              system from the window, every shift ends with a reconciliation
              puzzle and the risk of a paid order nobody made.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- The Solution -->
  <section class="bg-zinc-50 py-20 dark:bg-neutral-900">
    <div class="px-4 md:px-8">
      <div class="grid max-w-6xl gap-12 md:grid-cols-3">
        <div class="md:col-span-1">
          <p
            class="mb-3 text-xs font-bold tracking-widest text-neutral-400 uppercase"
          >
            The Solution
          </p>
          <h2 class="mb-4 text-3xl font-black">
            One Queue, Backed by a Real Database
          </h2>
        </div>
        <div class="md:col-span-2">
          <p
            class="mb-8 text-lg leading-relaxed font-medium text-neutral-700 dark:text-neutral-300"
          >
            A Next.js 16 App Router build that hands money to Square via Payment
            Links — so online orders surface in the same POS as the window — and
            treats a Postgres <code>orders</code> table as the single source of truth.
            Every decision, from the UNIQUE payment reference to the reconcile cron,
            exists so that <strong class="text-black dark:text-white"
              >every paid order reaches the cart exactly once and exactly as
              ordered</strong
            >.
          </p>
          <div class="grid gap-4 sm:grid-cols-2">
            {
              features.map((f) => (
                <div class="rounded-xl border-2 border-zinc-200 bg-white p-5 transition-colors hover:border-zinc-400 dark:border-zinc-700/50 dark:bg-zinc-900 dark:hover:border-zinc-500">
                  <span class="mb-2 block text-2xl">{f.icon}</span>
                  <h3 class="mb-1 text-base font-black">{f.title}</h3>
                  <p class="text-sm leading-relaxed font-medium text-neutral-600 dark:text-neutral-400">
                    {f.description}
                  </p>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Design Highlights -->
  <section class="py-20">
    <div class="px-4 md:px-8">
      <div class="grid max-w-6xl gap-12 md:grid-cols-3">
        <div class="md:col-span-1">
          <p
            class="mb-3 text-xs font-bold tracking-widest text-neutral-400 uppercase"
          >
            Design
          </p>
          <h2 class="mb-4 text-3xl font-black">Key Design Decisions</h2>
        </div>
        <div class="space-y-8 md:col-span-2">
          <div class="flex gap-5">
            <span class="shrink-0 text-3xl">🪟</span>
            <div>
              <h3 class="mb-1 text-lg font-black">
                Pickup-at-the-Window, Not Delivery
              </h3>
              <p
                class="leading-relaxed font-medium text-neutral-700 dark:text-neutral-400"
              >
                The whole flow is scoped to order-ahead-and-collect. No
                couriers, no delivery zones — just a faster path to the same
                truck window, which keeps the build simple and the margins
                intact.
              </p>
            </div>
          </div>
          <div class="flex gap-5">
            <span class="shrink-0 text-3xl">📟</span>
            <div>
              <h3 class="mb-1 text-lg font-black">
                A Status Page That Replaces the "Is It Ready?" Tap
              </h3>
              <p
                class="leading-relaxed font-medium text-neutral-700 dark:text-neutral-400"
              >
                Rather than texting customers, the post-payment screen polls
                every 3 seconds and moves through received → preparing → ready
                states — so people walk up exactly when their coffee is done,
                not before.
              </p>
            </div>
          </div>
          <div class="flex gap-5">
            <span class="shrink-0 text-3xl">🔢</span>
            <div>
              <h3 class="mb-1 text-lg font-black">
                Human-Readable Pickup Codes
              </h3>
              <p
                class="leading-relaxed font-medium text-neutral-700 dark:text-neutral-400"
              >
                Orders get a short, speakable code instead of a UUID, so a
                barista can call it across a noisy cart and a customer can read
                it back without squinting at a screen.
              </p>
            </div>
          </div>
          <div class="flex gap-5">
            <span class="shrink-0 text-3xl">🔒</span>
            <div>
              <h3 class="mb-1 text-lg font-black">Friction-Light Staff Auth</h3>
              <p
                class="leading-relaxed font-medium text-neutral-700 dark:text-neutral-400"
              >
                The kitchen view is gated by a signed HMAC cookie and a shared
                PIN — secure enough for a counter tablet, but no account
                juggling for casual staff mid-rush.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Technical Architecture -->
  <section class="bg-zinc-50 py-20 dark:bg-neutral-900">
    <div class="px-4 md:px-8">
      <div class="grid max-w-6xl gap-12 md:grid-cols-3">
        <div class="md:col-span-1">
          <p
            class="mb-3 text-xs font-bold tracking-widest text-neutral-400 uppercase"
          >
            Engineering
          </p>
          <h2 class="mb-4 text-3xl font-black">Technical Architecture</h2>
        </div>
        <div class="space-y-6 md:col-span-2">
          <p
            class="text-lg leading-relaxed font-medium text-neutral-700 dark:text-neutral-300"
          >
            Built on Next.js 16 App Router and deployed on Vercel. Checkout
            creates a Square Payment Link; a signature-verified webhook inserts
            the paid order into Neon Postgres and fires Resend emails; the
            kitchen view and customer status page both read from that single
            table. A reconcile route backfills anything Square's webhook misses.
          </p>
          <div class="grid gap-4 sm:grid-cols-3">
            <div
              class="rounded-xl border-2 border-zinc-200 bg-white p-5 dark:border-zinc-700/50 dark:bg-zinc-900"
            >
              <p
                class="mb-2 text-xs font-bold tracking-widest text-neutral-400 uppercase"
              >
                Framework
              </p>
              <p class="font-black">Next.js 16</p>
              <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">
                App Router · RSC
              </p>
            </div>
            <div
              class="rounded-xl border-2 border-zinc-200 bg-white p-5 dark:border-zinc-700/50 dark:bg-zinc-900"
            >
              <p
                class="mb-2 text-xs font-bold tracking-widest text-neutral-400 uppercase"
              >
                Payments
              </p>
              <p class="font-black">Square</p>
              <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">
                Payment Links · Webhooks
              </p>
            </div>
            <div
              class="rounded-xl border-2 border-zinc-200 bg-white p-5 dark:border-zinc-700/50 dark:bg-zinc-900"
            >
              <p
                class="mb-2 text-xs font-bold tracking-widest text-neutral-400 uppercase"
              >
                Data
              </p>
              <p class="font-black">Neon Postgres</p>
              <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">
                Source of truth · Resend
              </p>
            </div>
          </div>

          <!-- Architecture flow diagram -->
          <div
            class="overflow-x-auto rounded-xl border-2 border-zinc-700 bg-zinc-900 p-6 font-mono text-sm dark:bg-black"
          >
            <pre
              class="leading-relaxed whitespace-pre text-zinc-300"><span class="text-blue-400">Customer</span> ──▶ <span class="text-orange-400">/api/checkout</span> ──▶ <span class="text-green-400">Square Payment Link</span> ──▶ <span class="text-yellow-400">hosted checkout</span>
                                                                  │ pays
                                                                  ▼
                                                       <span class="text-pink-400">/api/square/webhook</span>
                                                                  │ INSERT … ON CONFLICT DO NOTHING
                                                                  ▼
                                                       <span class="text-indigo-400">Postgres `orders`</span>
                                                                  │
                                              ┌───────────────────┼───────────────────┐
                                              ▼                   ▼                   ▼
                                        <span class="text-green-400">Resend</span>            <span class="text-green-400">/kitchen</span>            <span class="text-blue-400">/order/[id]</span>
                                   (ticket + receipt)     (staff queue)      (polls every 3s)
                                              ▲
                                  <span class="text-indigo-400">/api/cron/reconcile</span> ──┘  (backfills missed webhooks)</pre>
          </div>

          <div
            class="rounded-xl border-l-4 border-amber-500 bg-amber-50 p-6 dark:bg-amber-950/30"
          >
            <p class="text-base font-bold text-amber-800 dark:text-amber-300">
              ☕ The whole system is built around one invariant: the Square
              order ID is UNIQUE in Postgres. Webhook retries, duplicate events,
              and reconcile sweeps all converge on the same row — so a paid
              order can be created once and only once, no matter how many times
              Square tries.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Results -->
  <section class="py-20">
    <div class="px-4 md:px-8">
      <div class="grid max-w-6xl gap-12 md:grid-cols-3">
        <div class="md:col-span-1">
          <p
            class="mb-3 text-xs font-bold tracking-widest text-neutral-400 uppercase"
          >
            Impact
          </p>
          <h2 class="mb-4 text-3xl font-black">The Result</h2>
        </div>
        <div class="space-y-6 md:col-span-2">
          <p
            class="text-lg leading-relaxed font-medium text-neutral-700 dark:text-neutral-300"
          >
            Rolling Mugshot customers can order and pay before they arrive, then
            walk straight to the window when their status page says "Ready."
            Because checkout runs through Square, online pre-orders sit in the
            same POS as walk-ups — one queue, one set of takings, nothing to
            reconcile twice.
          </p>
          <ul class="space-y-4">
            <li
              class="flex items-start gap-3 text-lg font-medium text-neutral-700 dark:text-neutral-300"
            >
              <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-green-500"
              ></span>
              <span
                ><strong class="text-black dark:text-white"
                  >One unified queue</strong
                > — online orders land in Square POS alongside window sales, with
                no second till to reconcile.</span
              >
            </li>
            <li
              class="flex items-start gap-3 text-lg font-medium text-neutral-700 dark:text-neutral-300"
            >
              <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-green-500"
              ></span>
              <span
                ><strong class="text-black dark:text-white"
                  >Exactly-once order capture</strong
                > — a UNIQUE payment reference plus a reconcile cron guarantee no
                duplicates and no dropped orders.</span
              >
            </li>
            <li
              class="flex items-start gap-3 text-lg font-medium text-neutral-700 dark:text-neutral-300"
            >
              <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-green-500"
              ></span>
              <span
                ><strong class="text-black dark:text-white"
                  >No more "is it ready?"</strong
                > — a live status page and a glanceable kitchen queue keep customers
                and staff in sync without a single text message.</span
              >
            </li>
          </ul>

          <div
            class="mt-4 rounded-xl border-l-4 border-emerald-500 bg-emerald-50 p-6 dark:bg-emerald-950/30"
          >
            <p
              class="text-base font-bold text-emerald-800 dark:text-emerald-300"
            >
              💡 Meet the merchant where they already are: by building on the
              cart's existing Square POS instead of a parallel system, online
              ordering became an extension of the window — not a second business
              to run.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Last updated -->
  <section class="pb-12">
    <div class="px-4 md:px-8">
      <p
        class="text-xs font-bold tracking-widest text-neutral-900 uppercase dark:text-white"
      >
        Last updated · June 2026
      </p>
    </div>
  </section>

  <!-- Next / Back nav -->
  <section class="border-t-2 border-zinc-100 py-16 dark:border-zinc-800">
    <div
      class="flex flex-col items-center justify-between gap-6 px-4 sm:flex-row md:px-8"
    >
      <a
        href="/case-studies"
        class="inline-flex items-center gap-2 font-bold text-neutral-500 transition-colors hover:text-black dark:text-neutral-400 dark:hover:text-white"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"><path d="m15 18-6-6 6-6"></path></svg
        >
        All case studies
      </a>
      <a
        href="/#contact"
        class="group relative inline-flex h-12 items-center justify-center overflow-hidden rounded-full bg-black px-8 font-bold text-white transition-all duration-300 dark:bg-white dark:text-black"
      >
        <span
          class="transform transition-transform duration-300 group-hover:-translate-x-4"
        >
          Get in touch
        </span>
        <span
          class="absolute right-5 -translate-x-4 transform opacity-0 transition-all duration-300 group-hover:translate-x-0 group-hover:opacity-100"
        >
          &rarr;
        </span>
      </a>
    </div>
  </section>
</MainLayout>
