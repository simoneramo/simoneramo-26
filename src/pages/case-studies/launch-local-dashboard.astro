---
import MainLayout from "../../layouts/MainLayout.astro";

const caseStudy = {
    title: "Launch Local Dashboard",
    subtitle:
        "A premium command center designed to eliminate terminal fatigue and streamline the local development experience. It bridges the gap between the filesystem and the browser, enabling developers to scan, launch, and monitor projects with unparalleled ease.",
    client: "Personal Project",
    year: "2026",
    role: "Product Designer & Full-Stack Developer",
    stack: ["React 19", "Vite", "Node.js", "Express", "Lucide Icons"],
    tags: ["Developer Tools", "React", "Node.js"],
    emoji: "🖥️",
};

const features = [
    {
        icon: "🔍",
        title: "Smart Scanning",
        description: "Automatically detects projects in the ~/Sites directory.",
    },
    {
        icon: "🧠",
        title: "Framework Intelligence",
        description:
            "Identifies Next.js, Astro, Vite, and React projects automatically.",
    },
    {
        icon: "📡",
        title: "Deep Process Detection",
        description:
            "Uses lsof to find all active servers, even those started outside the app.",
    },
    {
        icon: "🚀",
        title: "One-Click Launch",
        description:
            "Spawns background processes and automatically opens Chrome to the correct URL.",
    },
    {
        icon: "🛠️",
        title: 'Universal "Open With"',
        description:
            "Instant access to VS Code, Cursor, Antigravity, Warp, and Finder.",
    },
    {
        icon: "📌",
        title: "Pinned & Sorted",
        description:
            "Pin active projects to the top, sorted by date or alphabetically.",
    },
];

const outcomes = [
    { value: "~2 min", label: "Saved per project switch" },
    { value: "100%", label: "Zombie processes identified & killed" },
    { value: "1-click", label: "From directory to running localhost" },
];

const problems = [
    "Navigating deep directory structures in the terminal",
    "Remembering which project runs on which port",
    "Manually running npm run dev and waiting for the URL",
    "Losing track of background processes consuming system resources",
    "Switching between different editors and tools for each project",
];
---

<MainLayout
    title="Launch Local Dashboard — Case Study | Simon Eramo"
    description="How I designed and built Launch Local—a premium command center that eliminates terminal fatigue for web developers with one-click project launching and real-time server monitoring."
>
    <!-- Hero -->
    <section
        class="py-20 md:py-28 border-b-2 border-zinc-100 dark:border-zinc-800"
    >
        <div class="px-4 md:px-8">
            <div class="flex items-center gap-3 mb-8">
                <a
                    href="/case-studies"
                    class="inline-flex items-center gap-1.5 text-sm font-bold text-neutral-500 dark:text-neutral-400 hover:text-black dark:hover:text-white transition-colors"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"><path d="m15 18-6-6 6-6"></path></svg
                    >
                    Case Studies
                </a>
            </div>

            <div class="max-w-4xl">
                <p
                    class="text-xs font-bold uppercase tracking-widest text-neutral-500 dark:text-neutral-400 mb-4"
                >
                    {caseStudy.client} · {caseStudy.year}
                </p>
                <div class="flex items-start gap-5 mb-6">
                    <span
                        class="text-6xl md:text-7xl shrink-0 mt-1"
                        aria-hidden="true">{caseStudy.emoji}</span
                    >
                    <h1
                        id="case-study-heading"
                        class="text-4xl md:text-6xl font-black leading-tight text-pretty"
                    >
                        {caseStudy.title}
                    </h1>
                </div>
                <p
                    class="text-xl font-medium text-neutral-600 dark:text-neutral-400 mb-8 max-w-2xl leading-relaxed"
                >
                    {caseStudy.subtitle}
                </p>

                <!-- Meta strip -->
                <div
                    class="flex flex-wrap gap-6 pt-8 border-t-2 border-zinc-100 dark:border-zinc-800"
                >
                    <div>
                        <p
                            class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-1"
                        >
                            Role
                        </p>
                        <p class="font-bold text-sm">{caseStudy.role}</p>
                    </div>
                    <div>
                        <p
                            class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-1"
                        >
                            Year
                        </p>
                        <p class="font-bold text-sm">{caseStudy.year}</p>
                    </div>
                    <div>
                        <p
                            class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-1"
                        >
                            Stack
                        </p>
                        <p class="font-bold text-sm">
                            {caseStudy.stack.join(" · ")}
                        </p>
                    </div>
                </div>
            </div>

            <!-- Hero product screenshot -->
            <div
                class="mt-12 rounded-2xl overflow-hidden border-2 border-zinc-200 dark:border-zinc-700/50 shadow-xl"
            >
                <img
                    src="/images/default-view.png"
                    alt="Launch Local Dashboard — default project grid view"
                    class="w-full h-auto block"
                    width="1456"
                    height="816"
                />
            </div>
        </div>
    </section>

    <!-- Executive Summary -->
    <section class="py-20">
        <div class="px-4 md:px-8">
            <div class="grid md:grid-cols-3 gap-12 max-w-6xl">
                <div class="md:col-span-1">
                    <p
                        class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-3"
                    >
                        Overview
                    </p>
                    <h2 class="text-3xl font-black mb-4">Executive Summary</h2>
                </div>
                <div class="md:col-span-2">
                    <p
                        class="text-lg font-medium text-neutral-700 dark:text-neutral-300 leading-relaxed"
                    >
                        <strong class="text-black dark:text-white"
                            >Launch Local</strong
                        > is a centralised dashboard built to solve the <em
                            >"terminal fatigue"</em
                        > experienced by modern web developers. By providing a visual
                        interface to scan, launch, and manage local projects across
                        various frameworks (Next.js, Astro, Vite, etc.), it reduces
                        the cognitive overhead of switching between projects and managing
                        background processes.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Outcomes -->
    <section class="py-16 bg-zinc-50 dark:bg-neutral-900">
        <div class="px-4 md:px-8">
            <div
                class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto text-center"
            >
                {
                    outcomes.map((o) => (
                        <div class="p-8 rounded-2xl border-2 border-zinc-200 dark:border-zinc-700/50 bg-white dark:bg-zinc-900">
                            <span class="block text-4xl md:text-5xl font-black mb-2 text-black dark:text-white">
                                {o.value}
                            </span>
                            <span class="text-sm font-bold text-neutral-500 dark:text-neutral-400 uppercase tracking-widest">
                                {o.label}
                            </span>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- The Problem -->
    <section class="py-20">
        <div class="px-4 md:px-8">
            <div class="grid md:grid-cols-3 gap-12 max-w-6xl">
                <div class="md:col-span-1">
                    <p
                        class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-3"
                    >
                        The Challenge
                    </p>
                    <h2 class="text-3xl font-black mb-4">
                        Terminal Fatigue & Port Chaos
                    </h2>
                </div>
                <div class="md:col-span-2 space-y-6">
                    <p
                        class="text-lg font-medium text-neutral-700 dark:text-neutral-300 leading-relaxed"
                    >
                        Modern developers often juggle <strong
                            class="text-black dark:text-white"
                            >5–10 active projects</strong
                        >. The traditional workflow is fragmented and
                        error-prone, leading to a cluttered workspace and lost
                        time.
                    </p>
                    <ul class="space-y-3">
                        {
                            problems.map((p) => (
                                <li class="flex items-start gap-3 text-neutral-700 dark:text-neutral-400 font-medium">
                                    <span class="mt-2 w-1.5 h-1.5 rounded-full bg-red-500 shrink-0" />
                                    {p}
                                </li>
                            ))
                        }
                    </ul>
                    <div
                        class="p-6 rounded-xl bg-red-50 dark:bg-red-950/30 border-l-4 border-red-500"
                    >
                        <p
                            class="font-bold text-red-800 dark:text-red-300 text-lg"
                        >
                            "Terminal Fatigue" — the compounding cognitive cost
                            of a fragmented local dev workflow.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- The Solution -->
    <section class="py-20 bg-zinc-50 dark:bg-neutral-900">
        <div class="px-4 md:px-8">
            <div class="grid md:grid-cols-3 gap-12 max-w-6xl">
                <div class="md:col-span-1">
                    <p
                        class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-3"
                    >
                        The Solution
                    </p>
                    <h2 class="text-3xl font-black mb-4">
                        A Unified Command Center
                    </h2>
                </div>
                <div class="md:col-span-2">
                    <p
                        class="text-lg font-medium text-neutral-700 dark:text-neutral-300 leading-relaxed mb-8"
                    >
                        Launch Local replaces terminal commands with a
                        high-fidelity visual dashboard. It acts as a bridge
                        between the filesystem and the developer's
                        tools—providing a <strong
                            class="text-black dark:text-white"
                            >single source of truth</strong
                        > for the local development environment.
                    </p>
                    <div class="grid sm:grid-cols-2 gap-4">
                        {
                            features.map((f) => (
                                <div class="p-5 rounded-xl border-2 border-zinc-200 dark:border-zinc-700/50 bg-white dark:bg-zinc-900 transition-colors hover:border-zinc-400 dark:hover:border-zinc-500">
                                    <span class="text-2xl block mb-2">
                                        {f.icon}
                                    </span>
                                    <h3 class="font-black text-base mb-1">
                                        {f.title}
                                    </h3>
                                    <p class="text-sm text-neutral-600 dark:text-neutral-400 font-medium leading-relaxed">
                                        {f.description}
                                    </p>
                                </div>
                            ))
                        }
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Design Highlights -->
    <section class="py-20">
        <div class="px-4 md:px-8">
            <div class="grid md:grid-cols-3 gap-12 max-w-6xl">
                <div class="md:col-span-1">
                    <p
                        class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-3"
                    >
                        Design
                    </p>
                    <h2 class="text-3xl font-black mb-4">
                        Key Design Decisions
                    </h2>
                </div>
                <div class="md:col-span-2 space-y-8">
                    <div class="flex gap-5">
                        <span class="text-3xl shrink-0">🎨</span>
                        <div>
                            <h3 class="font-black text-lg mb-1">
                                Premium Aesthetics
                            </h3>
                            <p
                                class="text-neutral-700 dark:text-neutral-400 font-medium leading-relaxed"
                            >
                                The application leverages <strong
                                    class="text-black dark:text-white"
                                    >Glassmorphism</strong
                                >, <strong class="text-black dark:text-white"
                                    >Dynamic Gradients</strong
                                >, and <strong
                                    class="text-black dark:text-white"
                                    >Micro-animations</strong
                                > to create a "state of the art" feel—a UI as inspiring
                                as the projects it manages.
                            </p>
                        </div>
                    </div>
                    <div class="flex gap-5">
                        <span class="text-3xl shrink-0">📡</span>
                        <div class="w-full">
                            <h3 class="font-black text-lg mb-1">
                                Real-time Monitoring
                            </h3>
                            <p
                                class="text-neutral-700 dark:text-neutral-400 font-medium leading-relaxed mb-5"
                            >
                                The Activity Monitor tracks running servers in
                                real-time—differentiating between projects
                                launched via the dashboard and external
                                processes, enabling clean termination of any
                                local server.
                            </p>
                            <!-- Light / Dark mode screenshots -->
                            <div class="grid sm:grid-cols-2 gap-4">
                                <figure
                                    class="rounded-xl overflow-hidden border-2 border-zinc-200 dark:border-zinc-700/50 shadow-md"
                                >
                                    <img
                                        src="/images/server-running.png"
                                        alt="Launch Local — running server panel in light mode"
                                        class="w-full h-auto block"
                                        width="728"
                                        height="600"
                                    />
                                    <figcaption
                                        class="px-3 py-2 text-xs font-bold text-neutral-500 bg-zinc-50 dark:bg-zinc-800 uppercase tracking-widest"
                                    >
                                        Light mode
                                    </figcaption>
                                </figure>
                                <figure
                                    class="rounded-xl overflow-hidden border-2 border-zinc-700/50 shadow-md"
                                >
                                    <img
                                        src="/images/server-running-dark.png"
                                        alt="Launch Local — running server panel in dark mode"
                                        class="w-full h-auto block"
                                        width="728"
                                        height="600"
                                    />
                                    <figcaption
                                        class="px-3 py-2 text-xs font-bold text-neutral-400 bg-zinc-900 uppercase tracking-widest"
                                    >
                                        Dark mode
                                    </figcaption>
                                </figure>
                            </div>
                        </div>
                    </div>
                    <div class="flex gap-5">
                        <span class="text-3xl shrink-0">📌</span>
                        <div>
                            <h3 class="font-black text-lg mb-1">
                                Pinned & Sorted
                            </h3>
                            <p
                                class="text-neutral-700 dark:text-neutral-400 font-medium leading-relaxed"
                            >
                                Developers can pin "Active" projects to the top,
                                while the rest are sorted by creation date or
                                alphabetically—ensuring the most relevant work
                                is always reachable.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Technical Architecture -->
    <section class="py-20 bg-zinc-50 dark:bg-neutral-900">
        <div class="px-4 md:px-8">
            <div class="grid md:grid-cols-3 gap-12 max-w-6xl">
                <div class="md:col-span-1">
                    <p
                        class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-3"
                    >
                        Engineering
                    </p>
                    <h2 class="text-3xl font-black mb-4">
                        Technical Architecture
                    </h2>
                </div>
                <div class="md:col-span-2 space-y-6">
                    <p
                        class="text-lg font-medium text-neutral-700 dark:text-neutral-300 leading-relaxed"
                    >
                        The project is built on a modern stack focused on
                        performance and deep system integration.
                    </p>
                    <div class="grid sm:grid-cols-3 gap-4">
                        <div
                            class="p-5 rounded-xl border-2 border-zinc-200 dark:border-zinc-700/50 bg-white dark:bg-zinc-900"
                        >
                            <p
                                class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-2"
                            >
                                Frontend
                            </p>
                            <p class="font-black">React 19 + Vite</p>
                            <p
                                class="text-sm text-neutral-500 dark:text-neutral-400 mt-1"
                            >
                                Lucide Icons
                            </p>
                        </div>
                        <div
                            class="p-5 rounded-xl border-2 border-zinc-200 dark:border-zinc-700/50 bg-white dark:bg-zinc-900"
                        >
                            <p
                                class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-2"
                            >
                                Backend
                            </p>
                            <p class="font-black">Node.js + Express</p>
                            <p
                                class="text-sm text-neutral-500 dark:text-neutral-400 mt-1"
                            >
                                child_process · tree-kill
                            </p>
                        </div>
                        <div
                            class="p-5 rounded-xl border-2 border-zinc-200 dark:border-zinc-700/50 bg-white dark:bg-zinc-900"
                        >
                            <p
                                class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-2"
                            >
                                System
                            </p>
                            <p class="font-black">lsof · fs</p>
                            <p
                                class="text-sm text-neutral-500 dark:text-neutral-400 mt-1"
                            >
                                Deep FS traversal
                            </p>
                        </div>
                    </div>

                    <!-- Architecture flow diagram (pure CSS/HTML) -->
                    <div
                        class="p-6 rounded-xl bg-zinc-900 dark:bg-black border-2 border-zinc-700 font-mono text-sm overflow-x-auto"
                    >
                        <pre
                            class="text-zinc-300 leading-relaxed whitespace-pre"><span class="text-indigo-400">React Dashboard</span>  ──── API Requests ────▶  <span class="text-green-400">Node.js Server</span>
                                                         │
                                      ┌──────────────────┼──────────────────┐
                                      ▼                  ▼                  ▼
                               <span class="text-yellow-400">Scan ~/Sites</span>      <span class="text-blue-400">lsof (ports)</span>      <span class="text-pink-400">Spawn procs</span>
                                                                            │
                                                                    <span class="text-orange-400">Log match → Auto-open browser</span></pre>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Results -->
    <section class="py-20">
        <div class="px-4 md:px-8">
            <div class="grid md:grid-cols-3 gap-12 max-w-6xl">
                <div class="md:col-span-1">
                    <p
                        class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-3"
                    >
                        Impact
                    </p>
                    <h2 class="text-3xl font-black mb-4">The Result</h2>
                </div>
                <div class="md:col-span-2 space-y-6">
                    <p
                        class="text-lg font-medium text-neutral-700 dark:text-neutral-300 leading-relaxed"
                    >
                        Launch Local transforms a manual, error-prone workflow
                        into a seamless experience. The dashboard delivers
                        measurable time savings and a genuinely elevated
                        developer experience.
                    </p>
                    <ul class="space-y-4">
                        <li
                            class="flex items-start gap-3 text-neutral-700 dark:text-neutral-300 font-medium text-lg"
                        >
                            <span
                                class="mt-1.5 w-2 h-2 rounded-full bg-green-500 shrink-0"
                            ></span>
                            <span
                                ><strong class="text-black dark:text-white"
                                    >~2–3 minutes saved</strong
                                > per project switch through one-click launching.</span
                            >
                        </li>
                        <li
                            class="flex items-start gap-3 text-neutral-700 dark:text-neutral-300 font-medium text-lg"
                        >
                            <span
                                class="mt-1.5 w-2 h-2 rounded-full bg-green-500 shrink-0"
                            ></span>
                            <span
                                ><strong class="text-black dark:text-white"
                                    >Easy identification and termination</strong
                                > of zombie processes consuming resources.</span
                            >
                        </li>
                        <li
                            class="flex items-start gap-3 text-neutral-700 dark:text-neutral-300 font-medium text-lg"
                        >
                            <span
                                class="mt-1.5 w-2 h-2 rounded-full bg-green-500 shrink-0"
                            ></span>
                            <span
                                ><strong class="text-black dark:text-white"
                                    >A beautiful, focused environment</strong
                                > that reduces friction and boosts creative flow.</span
                            >
                        </li>
                    </ul>

                    <div
                        class="p-6 rounded-xl bg-indigo-50 dark:bg-indigo-950/30 border-l-4 border-indigo-500 mt-4"
                    >
                        <p
                            class="font-bold text-indigo-800 dark:text-indigo-300 text-base"
                        >
                            💡 Pro Tip: Launch Local works best as a browser
                            "Home Page"—jump straight into any project the
                            moment you start your workday.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Next / Back nav -->
    <section class="py-16 border-t-2 border-zinc-100 dark:border-zinc-800">
        <div
            class="px-4 md:px-8 flex flex-col sm:flex-row items-center justify-between gap-6"
        >
            <a
                href="/case-studies"
                class="inline-flex items-center gap-2 font-bold text-neutral-500 dark:text-neutral-400 hover:text-black dark:hover:text-white transition-colors"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"><path d="m15 18-6-6 6-6"></path></svg
                >
                All case studies
            </a>
            <a
                href="/#contact"
                class="group relative inline-flex items-center justify-center overflow-hidden h-12 px-8 font-bold text-white bg-black dark:bg-white dark:text-black transition-all duration-300 rounded-md"
            >
                <span
                    class="transform transition-transform duration-300 group-hover:-translate-x-4"
                >
                    Get in touch
                </span>
                <span
                    class="absolute right-5 transform -translate-x-4 opacity-0 transition-all duration-300 group-hover:translate-x-0 group-hover:opacity-100"
                >
                    &rarr;
                </span>
            </a>
        </div>
    </section>
</MainLayout>
