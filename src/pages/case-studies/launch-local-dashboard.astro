---
import MainLayout from "../../layouts/MainLayout.astro";

const caseStudy = {
  title: "Local Launch",
  subtitle:
    "A local command center for the dev servers across your ~/Sites projects—scan, launch, stop, and monitor them from one place, on one port. Version 2 is a ground-up rewrite that pushes live state over Server-Sent Events, so the dashboard always reflects what's actually running.",
  client: "Personal Project",
  year: "2026",
  role: "Product Designer & Full-Stack Developer",
  stack: [
    "Next.js 15",
    "React 19",
    "TypeScript",
    "Server-Sent Events",
    "Node.js",
  ],
  tags: ["Developer Tools", "Next.js", "React"],
  emoji: "🚀",
};

const features = [
  {
    icon: "📡",
    title: "Live SSE State",
    description:
      "The server pushes an event when a process spawns, dies, or changes port. The UI never polls.",
  },
  {
    icon: "🧩",
    title: "One Process, One Port",
    description:
      "A single Next.js App Router process serves the UI and the API on port 7777—no frontend/backend to fall out of sync.",
  },
  {
    icon: "🧠",
    title: "Framework Intelligence",
    description:
      "Table-driven detection and port resolution for Next.js, Astro, Vite, and TinaCMS—adding a framework is one row.",
  },
  {
    icon: "🛑",
    title: "Reliable Stop Pipeline",
    description:
      "Graceful SIGTERM → SIGKILL → port-kill fallback. Stop is instant and always leaves the port free.",
  },
  {
    icon: "⚙️",
    title: "Per-Project Config",
    description:
      "Override the command, port, browser, or env vars without touching package.json—the escape hatch for monorepos and Docker.",
  },
  {
    icon: "♻️",
    title: "Orphan Recovery",
    description:
      "On startup it checks last-known ports against what's still listening and offers one-click cleanup of leftovers.",
  },
];

const outcomes = [
  { value: "1 process", label: "One Next.js app, one port" },
  { value: "Zero polling", label: "SSE pushes state on change" },
  { value: "Instant", label: "Stop — no resurrect bug" },
];

const problems = [
  "2.5s polling triggered an lsof storm that stalled the backend",
  '"Frontend alive, backend dead" desync between the Vite and Express processes',
  "The UI wouldn't update after Stop—an 8s cooldown plus a resurrect bug",
  "Hot-reload wiped in-memory state and orphaned child processes",
  "A 921-line App.jsx and 1054-line server.js that were hard to change safely",
  "PID files littered into every project folder",
];
---

<MainLayout
  title="Local Launch — Case Study | Simon Eramo"
  description="How I rebuilt Local Launch—a local dev-server dashboard—on a single Next.js process with Server-Sent Events, eliminating the polling, process desync, and stop bugs of the first version."
>
  <!-- Hero -->
  <section
    class="border-b-2 border-zinc-100 py-20 md:py-28 dark:border-zinc-800"
  >
    <div class="px-4 md:px-8">
      <div class="mb-8 flex items-center gap-3">
        <a
          href="/case-studies"
          class="inline-flex items-center gap-1.5 text-sm font-bold text-neutral-500 transition-colors hover:text-black dark:text-neutral-400 dark:hover:text-white"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"><path d="m15 18-6-6 6-6"></path></svg
          >
          Case Studies
        </a>
      </div>

      <div class="max-w-4xl">
        <p
          class="mb-4 text-xs font-bold tracking-widest text-neutral-500 uppercase dark:text-neutral-400"
        >
          {caseStudy.client} · {caseStudy.year}
        </p>
        <div class="mb-6 flex items-start gap-5">
          <span class="mt-1 shrink-0 text-6xl md:text-7xl" aria-hidden="true"
            >{caseStudy.emoji}</span
          >
          <h1
            id="case-study-heading"
            class="text-4xl leading-tight font-black text-pretty md:text-6xl"
          >
            {caseStudy.title}
          </h1>
        </div>
        <p
          class="mb-8 max-w-4xl text-xl leading-relaxed font-medium text-neutral-600 dark:text-neutral-400"
        >
          {caseStudy.subtitle}
        </p>

        <div class="mb-8 flex flex-wrap items-center gap-4">
          <a
            href="https://github.com/simoneramo/Local-Launch-v2"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-full border-2 border-zinc-200 px-4 py-2 text-sm font-bold transition-colors hover:border-black dark:border-zinc-700 dark:hover:border-white"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              ><path
                d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.4 5.4 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
              ></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg
            >
            View on GitHub
          </a>
        </div>

        <!-- Meta strip -->
        <div
          class="flex flex-wrap gap-6 border-t-2 border-zinc-100 pt-8 dark:border-zinc-800"
        >
          <div>
            <p
              class="mb-1 text-xs font-bold tracking-widest text-neutral-400 uppercase"
            >
              Role
            </p>
            <p class="text-sm font-bold">{caseStudy.role}</p>
          </div>
          <div>
            <p
              class="mb-1 text-xs font-bold tracking-widest text-neutral-400 uppercase"
            >
              Year
            </p>
            <p class="text-sm font-bold">{caseStudy.year}</p>
          </div>
          <div>
            <p
              class="mb-1 text-xs font-bold tracking-widest text-neutral-400 uppercase"
            >
              Stack
            </p>
            <p class="text-sm font-bold">
              {caseStudy.stack.join(" · ")}
            </p>
          </div>
        </div>
      </div>

      <!-- Hero product screenshot -->
      <div
        class="mt-12 overflow-hidden rounded-2xl border-2 border-zinc-200 shadow-xl dark:border-zinc-700/50"
      >
        <img
          src="/images/default-view.png"
          alt="Local Launch — default project grid view"
          class="block h-auto w-full"
          width="1456"
          height="816"
        />
      </div>
    </div>
  </section>

  <!-- Executive Summary -->
  <section class="py-20">
    <div class="px-4 md:px-8">
      <div class="grid max-w-6xl gap-12 md:grid-cols-3">
        <div class="md:col-span-1">
          <p
            class="mb-3 text-xs font-bold tracking-widest text-neutral-400 uppercase"
          >
            Overview
          </p>
          <h2 class="mb-4 text-3xl font-black">Executive Summary</h2>
        </div>
        <div class="md:col-span-2">
          <p
            class="text-lg leading-relaxed font-medium text-neutral-700 dark:text-neutral-300"
          >
            <strong class="text-black dark:text-white">Local Launch</strong> is a
            dashboard for starting, stopping, and tracking the dev servers across
            a developer's <code
              class="rounded bg-zinc-100 px-1.5 py-0.5 text-base dark:bg-zinc-800"
              >~/Sites</code
            > projects—from one place, on one port. <strong
              class="text-black dark:text-white">Version 2</strong
            > is a ground-up rewrite. The original worked, but its split Vite-frontend
            / Express-backend architecture and 2.5s polling loop produced a class
            of frustrating bugs: process desync, an lsof storm, and a UI that wouldn't
            update after you hit Stop. v2 collapses everything into a single Next.js
            process that <em>pushes</em> state over Server-Sent Events, so the dashboard
            always reflects what's actually running.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Outcomes -->
  <section class="bg-zinc-50 py-16 dark:bg-neutral-900">
    <div class="px-4 md:px-8">
      <div
        class="mx-auto grid max-w-4xl grid-cols-1 gap-8 text-center md:grid-cols-3"
      >
        {
          outcomes.map((o) => (
            <div class="rounded-2xl border-2 border-zinc-200 bg-white p-8 dark:border-zinc-700/50 dark:bg-zinc-900">
              <span class="mb-2 block text-4xl font-black text-black md:text-5xl dark:text-white">
                {o.value}
              </span>
              <span class="text-sm font-bold tracking-widest text-neutral-500 uppercase dark:text-neutral-400">
                {o.label}
              </span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- The Problem -->
  <section class="py-20">
    <div class="px-4 md:px-8">
      <div class="grid max-w-6xl gap-12 md:grid-cols-3">
        <div class="md:col-span-1">
          <p
            class="mb-3 text-xs font-bold tracking-widest text-neutral-400 uppercase"
          >
            The Challenge
          </p>
          <h2 class="mb-4 text-3xl font-black">
            A Working Tool That Fought Back
          </h2>
        </div>
        <div class="space-y-6 md:col-span-2">
          <p
            class="text-lg leading-relaxed font-medium text-neutral-700 dark:text-neutral-300"
          >
            v1 shipped and got daily use—but its architecture made it
            <strong class="text-black dark:text-white"
              >fragile and hard to evolve</strong
            >. Two processes, a constant polling loop, and detection logic that
            walked every listening port created bugs that compounded with use.
          </p>
          <ul class="space-y-3">
            {
              problems.map((p) => (
                <li class="flex items-start gap-3 font-medium text-neutral-700 dark:text-neutral-400">
                  <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-red-500" />
                  {p}
                </li>
              ))
            }
          </ul>
          <div
            class="rounded-xl border-l-4 border-red-500 bg-red-50 p-6 dark:bg-red-950/30"
          >
            <p class="text-lg font-bold text-red-800 dark:text-red-300">
              The root cause: a two-process design where the UI could show
              "Running" for a server that was already dead.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- The Solution -->
  <section class="bg-zinc-50 py-20 dark:bg-neutral-900">
    <div class="px-4 md:px-8">
      <div class="grid max-w-6xl gap-12 md:grid-cols-3">
        <div class="md:col-span-1">
          <p
            class="mb-3 text-xs font-bold tracking-widest text-neutral-400 uppercase"
          >
            The Solution
          </p>
          <h2 class="mb-4 text-3xl font-black">One Process, Pushed State</h2>
        </div>
        <div class="md:col-span-2">
          <p
            class="mb-8 text-lg leading-relaxed font-medium text-neutral-700 dark:text-neutral-300"
          >
            v2 rebuilds the dashboard on a single <strong
              class="text-black dark:text-white">Next.js 15 (App Router)</strong
            > process serving both the UI and the API on one port. The server is the
            <strong class="text-black dark:text-white"
              >single source of truth</strong
            >, pushing live updates over SSE and tracking only the processes it
            spawned—so Stop is instant and the state can't drift.
          </p>
          <div class="grid gap-4 sm:grid-cols-2">
            {
              features.map((f) => (
                <div class="rounded-xl border-2 border-zinc-200 bg-white p-5 transition-colors hover:border-zinc-400 dark:border-zinc-700/50 dark:bg-zinc-900 dark:hover:border-zinc-500">
                  <span class="mb-2 block text-2xl">{f.icon}</span>
                  <h3 class="mb-1 text-base font-black">{f.title}</h3>
                  <p class="text-sm leading-relaxed font-medium text-neutral-600 dark:text-neutral-400">
                    {f.description}
                  </p>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Design Highlights -->
  <section class="py-20">
    <div class="px-4 md:px-8">
      <div class="grid max-w-6xl gap-12 md:grid-cols-3">
        <div class="md:col-span-1">
          <p
            class="mb-3 text-xs font-bold tracking-widest text-neutral-400 uppercase"
          >
            Design
          </p>
          <h2 class="mb-4 text-3xl font-black">Key Design Decisions</h2>
        </div>
        <div class="space-y-8 md:col-span-2">
          <div class="flex gap-5">
            <span class="shrink-0 text-3xl">🎯</span>
            <div>
              <h3 class="mb-1 text-lg font-black">Truth Over Detection</h3>
              <p
                class="leading-relaxed font-medium text-neutral-700 dark:text-neutral-400"
              >
                v1 scanned every port to surface terminal-started servers—the
                source of the lsof storm and the resurrect-after-stop bug. v2 <strong
                  class="text-black dark:text-white"
                  >deliberately drops external detection</strong
                >: a project is Running <em>iff</em> the dashboard launched it. A
                smaller promise the tool can keep perfectly.
              </p>
            </div>
          </div>
          <div class="flex gap-5">
            <span class="shrink-0 text-3xl">📡</span>
            <div class="w-full">
              <h3 class="mb-1 text-lg font-black">Push, Don't Poll</h3>
              <p
                class="mb-5 leading-relaxed font-medium text-neutral-700 dark:text-neutral-400"
              >
                A live log drawer streams stdout/stderr from any running project
                (also written to <code
                  class="rounded bg-zinc-100 px-1.5 py-0.5 text-sm dark:bg-zinc-800"
                  >~/.local-launch/logs</code
                >), and an event bus pushes state changes the instant a process
                spawns, dies, or remaps a port—replacing the old polling loop
                entirely.
              </p>
              <!-- Light / Dark mode screenshots -->
              <div class="grid gap-4 sm:grid-cols-2">
                <figure
                  class="overflow-hidden rounded-xl border-2 border-zinc-200 shadow-md dark:border-zinc-700/50"
                >
                  <img
                    src="/images/server-running.png"
                    alt="Local Launch — running server panel in light mode"
                    class="block h-auto w-full"
                    width="728"
                    height="600"
                  />
                  <figcaption
                    class="bg-zinc-50 px-3 py-2 text-xs font-bold tracking-widest text-neutral-500 uppercase dark:bg-zinc-800"
                  >
                    Light mode
                  </figcaption>
                </figure>
                <figure
                  class="overflow-hidden rounded-xl border-2 border-zinc-700/50 shadow-md"
                >
                  <img
                    src="/images/server-running-dark.png"
                    alt="Local Launch — running server panel in dark mode"
                    class="block h-auto w-full"
                    width="728"
                    height="600"
                  />
                  <figcaption
                    class="bg-zinc-900 px-3 py-2 text-xs font-bold tracking-widest text-neutral-400 uppercase"
                  >
                    Dark mode
                  </figcaption>
                </figure>
              </div>
            </div>
          </div>
          <div class="flex gap-5">
            <span class="shrink-0 text-3xl">🗂️</span>
            <div>
              <h3 class="mb-1 text-lg font-black">
                One Hand-Inspectable Store
              </h3>
              <p
                class="leading-relaxed font-medium text-neutral-700 dark:text-neutral-400"
              >
                Pins, added projects, settings, and per-project overrides live
                in a single JSON file at <code
                  class="rounded bg-zinc-100 px-1.5 py-0.5 text-sm dark:bg-zinc-800"
                  >~/.local-launch/state.json</code
                >—written atomically through a serialized queue, so concurrent
                routes can't clobber it. No more PID files scattered across
                every project.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Technical Architecture -->
  <section class="bg-zinc-50 py-20 dark:bg-neutral-900">
    <div class="px-4 md:px-8">
      <div class="grid max-w-6xl gap-12 md:grid-cols-3">
        <div class="md:col-span-1">
          <p
            class="mb-3 text-xs font-bold tracking-widest text-neutral-400 uppercase"
          >
            Engineering
          </p>
          <h2 class="mb-4 text-3xl font-black">Technical Architecture</h2>
        </div>
        <div class="space-y-6 md:col-span-2">
          <p
            class="text-lg leading-relaxed font-medium text-neutral-700 dark:text-neutral-300"
          >
            A single Next.js process where Route Handlers mutate state, emit on
            an event bus, and stream the result back to the UI over SSE—no
            second runtime to fall out of sync.
          </p>
          <div class="grid gap-4 sm:grid-cols-3">
            <div
              class="rounded-xl border-2 border-zinc-200 bg-white p-5 dark:border-zinc-700/50 dark:bg-zinc-900"
            >
              <p
                class="mb-2 text-xs font-bold tracking-widest text-neutral-400 uppercase"
              >
                Frontend
              </p>
              <p class="font-black">Next.js 15 + React 19</p>
              <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">
                TypeScript · Lucide Icons
              </p>
            </div>
            <div
              class="rounded-xl border-2 border-zinc-200 bg-white p-5 dark:border-zinc-700/50 dark:bg-zinc-900"
            >
              <p
                class="mb-2 text-xs font-bold tracking-widest text-neutral-400 uppercase"
              >
                Backend
              </p>
              <p class="font-black">Route Handlers</p>
              <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">
                child_process · tree-kill
              </p>
            </div>
            <div
              class="rounded-xl border-2 border-zinc-200 bg-white p-5 dark:border-zinc-700/50 dark:bg-zinc-900"
            >
              <p
                class="mb-2 text-xs font-bold tracking-widest text-neutral-400 uppercase"
              >
                Realtime
              </p>
              <p class="font-black">Server-Sent Events</p>
              <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">
                Event bus on globalThis
              </p>
            </div>
          </div>

          <!-- Architecture flow diagram (pure CSS/HTML) -->
          <div
            class="overflow-x-auto rounded-xl border-2 border-zinc-700 bg-zinc-900 p-6 font-mono text-sm dark:bg-black"
          >
            <pre
              class="leading-relaxed whitespace-pre text-zinc-300">click ──▶ <span class="text-indigo-400">api.launch()</span> ──▶ <span class="text-green-400">/api/launch</span> ──▶ <span class="text-yellow-400">launcher.launch()</span>
                                              │ spawns child, parses URL
                                              ▼
                                      <span class="text-pink-400">eventBus.emit("project")</span>
                                              │
   UI state ◀── <span class="text-blue-400">useProjects</span> ◀── <span class="text-orange-400">/api/events (SSE)</span> ◀──┘</pre>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Results -->
  <section class="py-20">
    <div class="px-4 md:px-8">
      <div class="grid max-w-6xl gap-12 md:grid-cols-3">
        <div class="md:col-span-1">
          <p
            class="mb-3 text-xs font-bold tracking-widest text-neutral-400 uppercase"
          >
            Impact
          </p>
          <h2 class="mb-4 text-3xl font-black">The Result</h2>
        </div>
        <div class="space-y-6 md:col-span-2">
          <p
            class="text-lg leading-relaxed font-medium text-neutral-700 dark:text-neutral-300"
          >
            v2 is feature-complete and verified end-to-end on macOS—launch,
            stop, and orphan-recovery flows all tested against real projects.
            The rewrite didn't just add features; it deleted whole categories of
            bug.
          </p>
          <ul class="space-y-4">
            <li
              class="flex items-start gap-3 text-lg font-medium text-neutral-700 dark:text-neutral-300"
            >
              <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-green-500"
              ></span>
              <span
                ><strong class="text-black dark:text-white"
                  >Process desync eliminated</strong
                >—one process means the UI can't show "Running" for a dead
                server.</span
              >
            </li>
            <li
              class="flex items-start gap-3 text-lg font-medium text-neutral-700 dark:text-neutral-300"
            >
              <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-green-500"
              ></span>
              <span
                ><strong class="text-black dark:text-white"
                  >Instant, reliable Stop</strong
                >—graceful → force → port-kill always leaves the port free, no
                8-second cooldown.</span
              >
            </li>
            <li
              class="flex items-start gap-3 text-lg font-medium text-neutral-700 dark:text-neutral-300"
            >
              <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-green-500"
              ></span>
              <span
                ><strong class="text-black dark:text-white"
                  >Survives hot-reload and crashes</strong
                >—registry and event bus pinned to globalThis; the orphan banner
                recovers leftover ports on restart.</span
              >
            </li>
            <li
              class="flex items-start gap-3 text-lg font-medium text-neutral-700 dark:text-neutral-300"
            >
              <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-green-500"
              ></span>
              <span
                ><strong class="text-black dark:text-white"
                  >Far easier to evolve</strong
                >—single-responsibility files (~50–200 lines) replace a 921-line
                component and 1054-line server; adding a framework is one row.</span
              >
            </li>
          </ul>

          <div
            class="mt-4 rounded-xl border-l-4 border-indigo-500 bg-indigo-50 p-6 dark:bg-indigo-950/30"
          >
            <p class="text-base font-bold text-indigo-800 dark:text-indigo-300">
              💡 Daily use: wire <code
                class="rounded bg-indigo-100 px-1.5 py-0.5 dark:bg-indigo-900/40"
                >alias ll='~/Sites/local-launch-v2/scripts/start.sh'</code
              >—it builds if needed and serves the dashboard on port 7777, ready
              every morning.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Last updated -->
  <section class="pb-12">
    <div class="px-4 md:px-8">
      <p
        class="text-xs font-bold tracking-widest text-neutral-900 uppercase dark:text-white"
      >
        Last updated · June 2026
      </p>
    </div>
  </section>

  <!-- Next / Back nav -->
  <section class="border-t-2 border-zinc-100 py-16 dark:border-zinc-800">
    <div
      class="flex flex-col items-center justify-between gap-6 px-4 sm:flex-row md:px-8"
    >
      <a
        href="/case-studies"
        class="inline-flex items-center gap-2 font-bold text-neutral-500 transition-colors hover:text-black dark:text-neutral-400 dark:hover:text-white"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"><path d="m15 18-6-6 6-6"></path></svg
        >
        All case studies
      </a>
      <a
        href="/#contact"
