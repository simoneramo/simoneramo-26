---
import MainLayout from "../../layouts/MainLayout.astro";

const caseStudy = {
    title: "Local Launch",
    subtitle:
        "A local command center for the dev servers across your ~/Sites projects—scan, launch, stop, and monitor them from one place, on one port. Version 2 is a ground-up rewrite that pushes live state over Server-Sent Events, so the dashboard always reflects what's actually running.",
    client: "Personal Project",
    year: "2026",
    role: "Product Designer & Full-Stack Developer",
    stack: ["Next.js 15", "React 19", "TypeScript", "Server-Sent Events", "Node.js"],
    tags: ["Developer Tools", "Next.js", "React"],
    emoji: "🚀",
};

const features = [
    {
        icon: "📡",
        title: "Live SSE State",
        description:
            "The server pushes an event when a process spawns, dies, or changes port. The UI never polls.",
    },
    {
        icon: "🧩",
        title: "One Process, One Port",
        description:
            "A single Next.js App Router process serves the UI and the API on port 7777—no frontend/backend to fall out of sync.",
    },
    {
        icon: "🧠",
        title: "Framework Intelligence",
        description:
            "Table-driven detection and port resolution for Next.js, Astro, Vite, and TinaCMS—adding a framework is one row.",
    },
    {
        icon: "🛑",
        title: "Reliable Stop Pipeline",
        description:
            "Graceful SIGTERM → SIGKILL → port-kill fallback. Stop is instant and always leaves the port free.",
    },
    {
        icon: "⚙️",
        title: "Per-Project Config",
        description:
            "Override the command, port, browser, or env vars without touching package.json—the escape hatch for monorepos and Docker.",
    },
    {
        icon: "♻️",
        title: "Orphan Recovery",
        description:
            "On startup it checks last-known ports against what's still listening and offers one-click cleanup of leftovers.",
    },
];

const outcomes = [
    { value: "1 process", label: "One Next.js app, one port" },
    { value: "Zero polling", label: "SSE pushes state on change" },
    { value: "Instant", label: "Stop — no resurrect bug" },
];

const problems = [
    "2.5s polling triggered an lsof storm that stalled the backend",
    '"Frontend alive, backend dead" desync between the Vite and Express processes',
    "The UI wouldn't update after Stop—an 8s cooldown plus a resurrect bug",
    "Hot-reload wiped in-memory state and orphaned child processes",
    "A 921-line App.jsx and 1054-line server.js that were hard to change safely",
    "PID files littered into every project folder",
];
---

<MainLayout
    title="Local Launch — Case Study | Simon Eramo"
    description="How I rebuilt Local Launch—a local dev-server dashboard—on a single Next.js process with Server-Sent Events, eliminating the polling, process desync, and stop bugs of the first version."
>
    <!-- Hero -->
    <section
        class="py-20 md:py-28 border-b-2 border-zinc-100 dark:border-zinc-800"
    >
        <div class="px-4 md:px-8">
            <div class="flex items-center gap-3 mb-8">
                <a
                    href="/case-studies"
                    class="inline-flex items-center gap-1.5 text-sm font-bold text-neutral-500 dark:text-neutral-400 hover:text-black dark:hover:text-white transition-colors"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"><path d="m15 18-6-6 6-6"></path></svg
                    >
                    Case Studies
                </a>
            </div>

            <div class="max-w-4xl">
                <p
                    class="text-xs font-bold uppercase tracking-widest text-neutral-500 dark:text-neutral-400 mb-4"
                >
                    {caseStudy.client} · {caseStudy.year}
                </p>
                <div class="flex items-start gap-5 mb-6">
                    <span
                        class="text-6xl md:text-7xl shrink-0 mt-1"
                        aria-hidden="true">{caseStudy.emoji}</span
                    >
                    <h1
                        id="case-study-heading"
                        class="text-4xl md:text-6xl font-black leading-tight text-pretty"
                    >
                        {caseStudy.title}
                    </h1>
                </div>
                <p
                    class="text-xl font-medium text-neutral-600 dark:text-neutral-400 mb-8 max-w-2xl leading-relaxed"
                >
                    {caseStudy.subtitle}
                </p>

                <div class="flex flex-wrap items-center gap-4 mb-8">
                    <a
                        href="https://github.com/simoneramo/Local-Launch-v2"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-2 font-bold text-sm px-4 py-2 rounded-full border-2 border-zinc-200 dark:border-zinc-700 hover:border-black dark:hover:border-white transition-colors"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.4 5.4 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
                        View on GitHub
                    </a>
                </div>

                <!-- Meta strip -->
                <div
                    class="flex flex-wrap gap-6 pt-8 border-t-2 border-zinc-100 dark:border-zinc-800"
                >
                    <div>
                        <p
                            class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-1"
                        >
                            Role
                        </p>
                        <p class="font-bold text-sm">{caseStudy.role}</p>
                    </div>
                    <div>
                        <p
                            class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-1"
                        >
                            Year
                        </p>
                        <p class="font-bold text-sm">{caseStudy.year}</p>
                    </div>
                    <div>
                        <p
                            class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-1"
                        >
                            Stack
                        </p>
                        <p class="font-bold text-sm">
                            {caseStudy.stack.join(" · ")}
                        </p>
                    </div>
                </div>
            </div>

            <!-- Hero product screenshot -->
            <div
                class="mt-12 rounded-2xl overflow-hidden border-2 border-zinc-200 dark:border-zinc-700/50 shadow-xl"
            >
                <img
                    src="/images/default-view.png"
                    alt="Local Launch — default project grid view"
                    class="w-full h-auto block"
                    width="1456"
                    height="816"
                />
            </div>
        </div>
    </section>

    <!-- Executive Summary -->
    <section class="py-20">
        <div class="px-4 md:px-8">
            <div class="grid md:grid-cols-3 gap-12 max-w-6xl">
                <div class="md:col-span-1">
                    <p
                        class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-3"
                    >
                        Overview
                    </p>
                    <h2 class="text-3xl font-black mb-4">Executive Summary</h2>
                </div>
                <div class="md:col-span-2">
                    <p
                        class="text-lg font-medium text-neutral-700 dark:text-neutral-300 leading-relaxed"
                    >
                        <strong class="text-black dark:text-white"
                            >Local Launch</strong
                        > is a dashboard for starting, stopping, and tracking the
                        dev servers across a developer's <code
                            class="text-base px-1.5 py-0.5 rounded bg-zinc-100 dark:bg-zinc-800"
                            >~/Sites</code
                        > projects—from one place, on one port. <strong
                            class="text-black dark:text-white">Version 2</strong
                        > is a ground-up rewrite. The original worked, but its split
                        Vite-frontend / Express-backend architecture and 2.5s polling
                        loop produced a class of frustrating bugs: process desync,
                        an lsof storm, and a UI that wouldn't update after you hit
                        Stop. v2 collapses everything into a single Next.js process
                        that <em>pushes</em> state over Server-Sent Events, so the
                        dashboard always reflects what's actually running.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- Outcomes -->
    <section class="py-16 bg-zinc-50 dark:bg-neutral-900">
        <div class="px-4 md:px-8">
            <div
                class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto text-center"
            >
                {
                    outcomes.map((o) => (
                        <div class="p-8 rounded-2xl border-2 border-zinc-200 dark:border-zinc-700/50 bg-white dark:bg-zinc-900">
                            <span class="block text-4xl md:text-5xl font-black mb-2 text-black dark:text-white">
                                {o.value}
                            </span>
                            <span class="text-sm font-bold text-neutral-500 dark:text-neutral-400 uppercase tracking-widest">
                                {o.label}
                            </span>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- The Problem -->
    <section class="py-20">
        <div class="px-4 md:px-8">
            <div class="grid md:grid-cols-3 gap-12 max-w-6xl">
                <div class="md:col-span-1">
                    <p
                        class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-3"
                    >
                        The Challenge
                    </p>
                    <h2 class="text-3xl font-black mb-4">
                        A Working Tool That Fought Back
                    </h2>
                </div>
                <div class="md:col-span-2 space-y-6">
                    <p
                        class="text-lg font-medium text-neutral-700 dark:text-neutral-300 leading-relaxed"
                    >
                        v1 shipped and got daily use—but its architecture made it
                        <strong class="text-black dark:text-white"
                            >fragile and hard to evolve</strong
                        >. Two processes, a constant polling loop, and detection
                        logic that walked every listening port created bugs that
                        compounded with use.
                    </p>
                    <ul class="space-y-3">
                        {
                            problems.map((p) => (
                                <li class="flex items-start gap-3 text-neutral-700 dark:text-neutral-400 font-medium">
                                    <span class="mt-2 w-1.5 h-1.5 rounded-full bg-red-500 shrink-0" />
                                    {p}
                                </li>
                            ))
                        }
                    </ul>
                    <div
                        class="p-6 rounded-xl bg-red-50 dark:bg-red-950/30 border-l-4 border-red-500"
                    >
                        <p
                            class="font-bold text-red-800 dark:text-red-300 text-lg"
                        >
                            The root cause: a two-process design where the UI
                            could show "Running" for a server that was already
                            dead.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- The Solution -->
    <section class="py-20 bg-zinc-50 dark:bg-neutral-900">
        <div class="px-4 md:px-8">
            <div class="grid md:grid-cols-3 gap-12 max-w-6xl">
                <div class="md:col-span-1">
                    <p
                        class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-3"
                    >
                        The Solution
                    </p>
                    <h2 class="text-3xl font-black mb-4">
                        One Process, Pushed State
                    </h2>
                </div>
                <div class="md:col-span-2">
                    <p
                        class="text-lg font-medium text-neutral-700 dark:text-neutral-300 leading-relaxed mb-8"
                    >
                        v2 rebuilds the dashboard on a single <strong
                            class="text-black dark:text-white"
                            >Next.js 15 (App Router)</strong
                        > process serving both the UI and the API on one port. The
                        server is the <strong class="text-black dark:text-white"
                            >single source of truth</strong
                        >, pushing live updates over SSE and tracking only the processes
                        it spawned—so Stop is instant and the state can't drift.
                    </p>
                    <div class="grid sm:grid-cols-2 gap-4">
                        {
                            features.map((f) => (
                                <div class="p-5 rounded-xl border-2 border-zinc-200 dark:border-zinc-700/50 bg-white dark:bg-zinc-900 transition-colors hover:border-zinc-400 dark:hover:border-zinc-500">
                                    <span class="text-2xl block mb-2">
                                        {f.icon}
                                    </span>
                                    <h3 class="font-black text-base mb-1">
                                        {f.title}
                                    </h3>
                                    <p class="text-sm text-neutral-600 dark:text-neutral-400 font-medium leading-relaxed">
                                        {f.description}
                                    </p>
                                </div>
                            ))
                        }
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Design Highlights -->
    <section class="py-20">
        <div class="px-4 md:px-8">
            <div class="grid md:grid-cols-3 gap-12 max-w-6xl">
                <div class="md:col-span-1">
                    <p
                        class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-3"
                    >
                        Design
                    </p>
                    <h2 class="text-3xl font-black mb-4">
                        Key Design Decisions
                    </h2>
                </div>
                <div class="md:col-span-2 space-y-8">
                    <div class="flex gap-5">
                        <span class="text-3xl shrink-0">🎯</span>
                        <div>
                            <h3 class="font-black text-lg mb-1">
                                Truth Over Detection
                            </h3>
                            <p
                                class="text-neutral-700 dark:text-neutral-400 font-medium leading-relaxed"
                            >
                                v1 scanned every port to surface terminal-started
                                servers—the source of the lsof storm and the
                                resurrect-after-stop bug. v2 <strong
                                    class="text-black dark:text-white"
                                    >deliberately drops external detection</strong
                                >: a project is Running <em>iff</em> the dashboard
                                launched it. A smaller promise the tool can keep perfectly.
                            </p>
                        </div>
                    </div>
                    <div class="flex gap-5">
                        <span class="text-3xl shrink-0">📡</span>
                        <div class="w-full">
                            <h3 class="font-black text-lg mb-1">
                                Push, Don't Poll
                            </h3>
                            <p
                                class="text-neutral-700 dark:text-neutral-400 font-medium leading-relaxed mb-5"
                            >
                                A live log drawer streams stdout/stderr from any
                                running project (also written to <code
                                    class="text-sm px-1.5 py-0.5 rounded bg-zinc-100 dark:bg-zinc-800"
                                    >~/.local-launch/logs</code
                                >), and an event bus pushes state changes the
                                instant a process spawns, dies, or remaps a
                                port—replacing the old polling loop entirely.
                            </p>
                            <!-- Light / Dark mode screenshots -->
                            <div class="grid sm:grid-cols-2 gap-4">
                                <figure
                                    class="rounded-xl overflow-hidden border-2 border-zinc-200 dark:border-zinc-700/50 shadow-md"
                                >
                                    <img
                                        src="/images/server-running.png"
                                        alt="Local Launch — running server panel in light mode"
                                        class="w-full h-auto block"
                                        width="728"
                                        height="600"
                                    />
                                    <figcaption
                                        class="px-3 py-2 text-xs font-bold text-neutral-500 bg-zinc-50 dark:bg-zinc-800 uppercase tracking-widest"
                                    >
                                        Light mode
                                    </figcaption>
                                </figure>
                                <figure
                                    class="rounded-xl overflow-hidden border-2 border-zinc-700/50 shadow-md"
                                >
                                    <img
                                        src="/images/server-running-dark.png"
                                        alt="Local Launch — running server panel in dark mode"
                                        class="w-full h-auto block"
                                        width="728"
                                        height="600"
                                    />
                                    <figcaption
                                        class="px-3 py-2 text-xs font-bold text-neutral-400 bg-zinc-900 uppercase tracking-widest"
                                    >
                                        Dark mode
                                    </figcaption>
                                </figure>
                            </div>
                        </div>
                    </div>
                    <div class="flex gap-5">
                        <span class="text-3xl shrink-0">🗂️</span>
                        <div>
                            <h3 class="font-black text-lg mb-1">
                                One Hand-Inspectable Store
                            </h3>
                            <p
                                class="text-neutral-700 dark:text-neutral-400 font-medium leading-relaxed"
                            >
                                Pins, added projects, settings, and per-project
                                overrides live in a single JSON file at <code
                                    class="text-sm px-1.5 py-0.5 rounded bg-zinc-100 dark:bg-zinc-800"
                                    >~/.local-launch/state.json</code
                                >—written atomically through a serialized queue,
                                so concurrent routes can't clobber it. No more PID
                                files scattered across every project.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Technical Architecture -->
    <section class="py-20 bg-zinc-50 dark:bg-neutral-900">
        <div class="px-4 md:px-8">
            <div class="grid md:grid-cols-3 gap-12 max-w-6xl">
                <div class="md:col-span-1">
                    <p
                        class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-3"
                    >
                        Engineering
                    </p>
                    <h2 class="text-3xl font-black mb-4">
                        Technical Architecture
                    </h2>
                </div>
                <div class="md:col-span-2 space-y-6">
                    <p
                        class="text-lg font-medium text-neutral-700 dark:text-neutral-300 leading-relaxed"
                    >
                        A single Next.js process where Route Handlers mutate
                        state, emit on an event bus, and stream the result back to
                        the UI over SSE—no second runtime to fall out of sync.
                    </p>
                    <div class="grid sm:grid-cols-3 gap-4">
                        <div
                            class="p-5 rounded-xl border-2 border-zinc-200 dark:border-zinc-700/50 bg-white dark:bg-zinc-900"
                        >
                            <p
                                class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-2"
                            >
                                Frontend
                            </p>
                            <p class="font-black">Next.js 15 + React 19</p>
                            <p
                                class="text-sm text-neutral-500 dark:text-neutral-400 mt-1"
                            >
                                TypeScript · Lucide Icons
                            </p>
                        </div>
                        <div
                            class="p-5 rounded-xl border-2 border-zinc-200 dark:border-zinc-700/50 bg-white dark:bg-zinc-900"
                        >
                            <p
                                class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-2"
                            >
                                Backend
                            </p>
                            <p class="font-black">Route Handlers</p>
                            <p
                                class="text-sm text-neutral-500 dark:text-neutral-400 mt-1"
                            >
                                child_process · tree-kill
                            </p>
                        </div>
                        <div
                            class="p-5 rounded-xl border-2 border-zinc-200 dark:border-zinc-700/50 bg-white dark:bg-zinc-900"
                        >
                            <p
                                class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-2"
                            >
                                Realtime
                            </p>
                            <p class="font-black">Server-Sent Events</p>
                            <p
                                class="text-sm text-neutral-500 dark:text-neutral-400 mt-1"
                            >
                                Event bus on globalThis
                            </p>
                        </div>
                    </div>

                    <!-- Architecture flow diagram (pure CSS/HTML) -->
                    <div
                        class="p-6 rounded-xl bg-zinc-900 dark:bg-black border-2 border-zinc-700 font-mono text-sm overflow-x-auto"
                    >
                        <pre
                            class="text-zinc-300 leading-relaxed whitespace-pre">click ──▶ <span class="text-indigo-400">api.launch()</span> ──▶ <span class="text-green-400">/api/launch</span> ──▶ <span class="text-yellow-400">launcher.launch()</span>
                                              │ spawns child, parses URL
                                              ▼
                                      <span class="text-pink-400">eventBus.emit("project")</span>
                                              │
   UI state ◀── <span class="text-blue-400">useProjects</span> ◀── <span class="text-orange-400">/api/events (SSE)</span> ◀──┘</pre>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Results -->
    <section class="py-20">
        <div class="px-4 md:px-8">
            <div class="grid md:grid-cols-3 gap-12 max-w-6xl">
                <div class="md:col-span-1">
                    <p
                        class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-3"
                    >
                        Impact
                    </p>
                    <h2 class="text-3xl font-black mb-4">The Result</h2>
                </div>
                <div class="md:col-span-2 space-y-6">
                    <p
                        class="text-lg font-medium text-neutral-700 dark:text-neutral-300 leading-relaxed"
                    >
                        v2 is feature-complete and verified end-to-end on
                        macOS—launch, stop, and orphan-recovery flows all tested
                        against real projects. The rewrite didn't just add
                        features; it deleted whole categories of bug.
                    </p>
                    <ul class="space-y-4">
                        <li
                            class="flex items-start gap-3 text-neutral-700 dark:text-neutral-300 font-medium text-lg"
                        >
                            <span
                                class="mt-1.5 w-2 h-2 rounded-full bg-green-500 shrink-0"
                            ></span>
                            <span
                                ><strong class="text-black dark:text-white"
                                    >Process desync eliminated</strong
                                >—one process means the UI can't show "Running"
                                for a dead server.</span
                            >
                        </li>
                        <li
                            class="flex items-start gap-3 text-neutral-700 dark:text-neutral-300 font-medium text-lg"
                        >
                            <span
                                class="mt-1.5 w-2 h-2 rounded-full bg-green-500 shrink-0"
                            ></span>
                            <span
                                ><strong class="text-black dark:text-white"
                                    >Instant, reliable Stop</strong
                                >—graceful → force → port-kill always leaves the
                                port free, no 8-second cooldown.</span
                            >
                        </li>
                        <li
                            class="flex items-start gap-3 text-neutral-700 dark:text-neutral-300 font-medium text-lg"
                        >
                            <span
                                class="mt-1.5 w-2 h-2 rounded-full bg-green-500 shrink-0"
                            ></span>
                            <span
                                ><strong class="text-black dark:text-white"
                                    >Survives hot-reload and crashes</strong
                                >—registry and event bus pinned to globalThis; the
                                orphan banner recovers leftover ports on
                                restart.</span
                            >
                        </li>
                        <li
                            class="flex items-start gap-3 text-neutral-700 dark:text-neutral-300 font-medium text-lg"
                        >
                            <span
                                class="mt-1.5 w-2 h-2 rounded-full bg-green-500 shrink-0"
                            ></span>
                            <span
                                ><strong class="text-black dark:text-white"
                                    >Far easier to evolve</strong
                                >—single-responsibility files (~50–200 lines)
                                replace a 921-line component and 1054-line server;
                                adding a framework is one row.</span
                            >
                        </li>
                    </ul>

                    <div
                        class="p-6 rounded-xl bg-indigo-50 dark:bg-indigo-950/30 border-l-4 border-indigo-500 mt-4"
                    >
                        <p
                            class="font-bold text-indigo-800 dark:text-indigo-300 text-base"
                        >
                            💡 Daily use: wire <code
                                class="px-1.5 py-0.5 rounded bg-indigo-100 dark:bg-indigo-900/40"
                                >alias ll='~/Sites/local-launch-v2/scripts/start.sh'</code
                            >—it builds if needed and serves the dashboard on port
                            7777, ready every morning.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Last updated -->
    <section class="pb-12">
        <div class="px-4 md:px-8">
            <p
                class="text-xs font-bold uppercase tracking-widest text-neutral-900 dark:text-white"
            >
                Last updated · June 2026
            </p>
        </div>
    </section>

    <!-- Next / Back nav -->
    <section class="py-16 border-t-2 border-zinc-100 dark:border-zinc-800">
        <div
            class="px-4 md:px-8 flex flex-col sm:flex-row items-center justify-between gap-6"
        >
