---
import MainLayout from "../../layouts/MainLayout.astro";

const caseStudy = {
  title: "6Nutrition Online Ordering",
  subtitle: "Pickup-First Ordering for a Melbourne High-Protein Cafe",
  client: "6Nutrition",
  year: "2026",
  role: "Product Designer & Full-Stack Developer",
  stack: [
    "Next.js 16",
    "App Router",
    "React 19",
    "Tailwind CSS",
    "shadcn/ui",
    "Stripe",
    "Vercel",
  ],
  tags: ["Web App", "E-commerce", "Hospitality"],
  emoji: "🥗",
};

const features = [
  {
    icon: "🍽️",
    title: "Structured Menu Engine",
    description:
      "A JSON-driven menu with categories, modifier groups, shared add-ons, allergens and dietary tags — all resolved server-side so the menu is fast, cacheable, and never stale.",
  },
  {
    icon: "🧩",
    title: "Modifier-Aware Item Cards",
    description:
      "Every item opens a modal with required choices, multi-select extras, min/max validation and live price recalculation as the customer customises their order.",
  },
  {
    icon: "🛒",
    title: "Persistent Cart Drawer",
    description:
      "A fixed top-right cart pill that follows the customer through the menu, opening a side drawer with quantity controls, pickup-time selection, and customer details.",
  },
  {
    icon: "💳",
    title: "Stripe Checkout",
    description:
      "Server-side Stripe Checkout session creation with line items, modifier descriptions and pickup metadata — handing off to Stripe's hosted, PCI-compliant payment flow.",
  },
  {
    icon: "📥",
    title: "Webhook + Reconcile Cron",
    description:
      "A Stripe webhook captures completed sessions and a reconcile route catches anything missed, so the kitchen view never loses a paid order — even if a webhook is dropped.",
  },
  {
    icon: "👨‍🍳",
    title: "Kitchen View",
    description:
      "A dedicated /kitchen screen displays paid orders with customer name, phone, pickup time and itemised modifiers — designed to be glanceable on a counter tablet.",
  },
];

const outcomes = [
  { value: "<1 min", label: "From landing page to paid order" },
  { value: "0 staff", label: "Manual phone orders to transcribe" },
  { value: "100%", label: "Modifier accuracy via structured options" },
];

const problems = [
  "Phone orders interrupting service and creating handwritten dockets",
  "No reliable way to capture complex modifier choices (preparation, sides, extras)",
  "Customers waiting in queue just to order, not to pick up",
  "Inconsistent pickup timing — no visibility for the kitchen on what's coming next",
  "No GST-compliant digital receipt trail for retail items",
];
---

<MainLayout
  title="6Nutrition Online Ordering — Case Study | Simon Eramo"
  description="How I designed and built the 6Nutrition pickup ordering app — a Next.js 16 + Stripe ordering platform with a structured menu engine, modifier-aware item cards, persistent cart, and a kitchen view."
>
  <!-- Hero -->
  <section
    class="border-b-2 border-zinc-100 py-20 md:py-28 dark:border-zinc-800"
  >
    <div class="px-4 md:px-8">
      <div class="mb-8 flex items-center gap-3">
        <a
          href="/case-studies"
          class="inline-flex items-center gap-1.5 text-sm font-bold text-neutral-500 transition-colors hover:text-black dark:text-neutral-400 dark:hover:text-white"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"><path d="m15 18-6-6 6-6"></path></svg
          >
          Case Studies
        </a>
      </div>

      <div class="max-w-4xl">
        <p
          class="mb-4 text-xs font-bold tracking-widest text-neutral-500 uppercase dark:text-neutral-400"
        >
          {caseStudy.client} · {caseStudy.year}
        </p>
        <div class="mb-6 flex items-start gap-5">
          <span class="mt-1 shrink-0 text-6xl md:text-7xl" aria-hidden="true"
            >{caseStudy.emoji}</span
          >
          <h1
            id="case-study-heading"
            class="text-4xl leading-tight font-black text-pretty md:text-6xl"
          >
            {caseStudy.title}
          </h1>
        </div>
        <p
          class="mb-8 max-w-4xl text-xl leading-relaxed font-medium text-neutral-600 dark:text-neutral-400"
        >
          {caseStudy.subtitle}
        </p>

        <!-- Meta strip -->
        <div
          class="flex flex-wrap gap-6 border-t-2 border-zinc-100 pt-8 dark:border-zinc-800"
        >
          <div>
            <p
              class="mb-1 text-xs font-bold tracking-widest text-neutral-400 uppercase"
            >
              Role
            </p>
            <p class="text-sm font-bold">{caseStudy.role}</p>
          </div>
          <div>
            <p
              class="mb-1 text-xs font-bold tracking-widest text-neutral-400 uppercase"
            >
              Year
            </p>
            <p class="text-sm font-bold">{caseStudy.year}</p>
          </div>
          <div>
            <p
              class="mb-1 text-xs font-bold tracking-widest text-neutral-400 uppercase"
            >
              Stack
            </p>
            <p class="text-sm font-bold">
              {caseStudy.stack.join(" · ")}
            </p>
          </div>
        </div>
      </div>

      <!-- Hero product screenshot -->
      <div
        class="mt-12 max-w-3xl overflow-hidden rounded-2xl border-2 border-zinc-200 shadow-xl dark:border-zinc-700/50"
      >
        <img
          src="/images/six-nutrition/six-nutrition-home.png"
          alt="6Nutrition ordering home screen — pastel mint background with brand mark, phone number, and a grid of breakfast items with high-quality food photography"
          class="block h-auto w-full"
          width="2940"
          height="1482"
        />
      </div>
    </div>
  </section>

  <!-- Executive Summary -->
  <section class="py-20">
    <div class="px-4 md:px-8">
      <div class="grid max-w-6xl gap-12 md:grid-cols-3">
        <div class="md:col-span-1">
          <p
            class="mb-3 text-xs font-bold tracking-widest text-neutral-400 uppercase"
          >
            Overview
          </p>
          <h2 class="mb-4 text-3xl font-black">Executive Summary</h2>
        </div>
        <div class="md:col-span-2">
          <p
            class="text-lg leading-relaxed font-medium text-neutral-700 dark:text-neutral-300"
          >
            <strong class="text-black dark:text-white"
              >6Nutrition Online Ordering</strong
            > is a pickup-first ordering experience built for a Melbourne high-protein
            cafe. It replaces phone orders and queue-time ordering with a fast, modifier-aware
            web app that hands money to Stripe, surfaces orders to the kitchen in
            real time, and reconciles every payment via webhook plus a safety-net
            cron — all deployed on Vercel.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Outcomes -->
  <section class="bg-zinc-50 py-16 dark:bg-neutral-900">
    <div class="px-4 md:px-8">
      <div
        class="mx-auto grid max-w-4xl grid-cols-1 gap-8 text-center md:grid-cols-3"
      >
        {
          outcomes.map((o) => (
            <div class="rounded-2xl border-2 border-zinc-200 bg-white p-8 dark:border-zinc-700/50 dark:bg-zinc-900">
              <span class="mb-2 block text-4xl font-black text-black md:text-5xl dark:text-white">
                {o.value}
              </span>
              <span class="text-sm font-bold tracking-widest text-neutral-500 uppercase dark:text-neutral-400">
                {o.label}
              </span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- The Problem -->
  <section class="py-20">
    <div class="px-4 md:px-8">
      <div class="grid max-w-6xl gap-12 md:grid-cols-3">
        <div class="md:col-span-1">
          <p
            class="mb-3 text-xs font-bold tracking-widest text-neutral-400 uppercase"
          >
            The Challenge
          </p>
          <h2 class="mb-4 text-3xl font-black">
            Phone Orders, Queues, and Lost Modifiers
          </h2>
        </div>
        <div class="space-y-6 md:col-span-2">
          <p
            class="text-lg leading-relaxed font-medium text-neutral-700 dark:text-neutral-300"
          >
            Like most cafes, 6Nutrition was juggling phone orders, in-person
            queues and a menu rich with <strong
              class="text-black dark:text-white"
              >required preparation choices, extras and add-ons</strong
            >. Handwritten dockets dropped modifier details, peak-time phone
            calls pulled staff off the counter, and customers waited in line
            just to place an order — not to collect one.
          </p>
          <ul class="space-y-3">
            {
              problems.map((p) => (
                <li class="flex items-start gap-3 font-medium text-neutral-700 dark:text-neutral-400">
                  <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-red-500" />
                  {p}
                </li>
              ))
            }
          </ul>
          <div
            class="rounded-xl border-l-4 border-red-500 bg-red-50 p-6 dark:bg-red-950/30"
          >
            <p class="text-lg font-bold text-red-800 dark:text-red-300">
              "Modifier Drift" — every handwritten docket loses a preparation
              choice or a side. Multiply by hundreds of orders a week and the
              kitchen is always guessing.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- The Solution -->
  <section class="bg-zinc-50 py-20 dark:bg-neutral-900">
    <div class="px-4 md:px-8">
      <div class="grid max-w-6xl gap-12 md:grid-cols-3">
        <div class="md:col-span-1">
          <p
            class="mb-3 text-xs font-bold tracking-widest text-neutral-400 uppercase"
          >
            The Solution
          </p>
          <h2 class="mb-4 text-3xl font-black">A Pickup-First Web App</h2>
        </div>
        <div class="md:col-span-2">
          <p
            class="mb-8 text-lg leading-relaxed font-medium text-neutral-700 dark:text-neutral-300"
          >
            A Next.js 16 App Router build with a structured JSON menu,
            modifier-aware modals, a persistent cart drawer, Stripe Checkout,
            and a dedicated kitchen view. Every decision — from
            required-modifier validation to the reconcile cron — exists to make
            sure <strong class="text-black dark:text-white"
              >every paid order reaches the kitchen exactly as the customer
              chose it</strong
            >.
          </p>
          <div class="grid gap-4 sm:grid-cols-2">
            {
              features.map((f) => (
                <div class="rounded-xl border-2 border-zinc-200 bg-white p-5 transition-colors hover:border-zinc-400 dark:border-zinc-700/50 dark:bg-zinc-900 dark:hover:border-zinc-500">
                  <span class="mb-2 block text-2xl">{f.icon}</span>
                  <h3 class="mb-1 text-base font-black">{f.title}</h3>
                  <p class="text-sm leading-relaxed font-medium text-neutral-600 dark:text-neutral-400">
                    {f.description}
                  </p>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Design Highlights -->
  <section class="py-20">
    <div class="px-4 md:px-8">
      <div class="grid max-w-6xl gap-12 md:grid-cols-3">
        <div class="md:col-span-1">
          <p
            class="mb-3 text-xs font-bold tracking-widest text-neutral-400 uppercase"
          >
            Design
          </p>
          <h2 class="mb-4 text-3xl font-black">Key Design Decisions</h2>
        </div>
        <div class="space-y-8 md:col-span-2">
          <div class="flex gap-5">
            <span class="shrink-0 text-3xl">🥬</span>
            <div>
              <h3 class="mb-1 text-lg font-black">Pastel-Mint Brand Palette</h3>
              <p
                class="leading-relaxed font-medium text-neutral-700 dark:text-neutral-400"
              >
                A soft mint background paired with a circular brand mark and
                high-contrast black/white interactive elements — the menu feels
                fresh and "healthy" without ever competing with the food
                photography.
              </p>
            </div>
          </div>
          <div class="flex gap-5">
            <span class="shrink-0 text-3xl">🃏</span>
            <div>
              <h3 class="mb-1 text-lg font-black">Modifier-First Item Cards</h3>
              <p
                class="leading-relaxed font-medium text-neutral-700 dark:text-neutral-400"
              >
                Every card opens a dialog rather than quick-adding — even simple
                items — so customers always confirm required choices and the
                cart never ends up with an "incomplete" line item.
              </p>
            </div>
          </div>
          <div class="flex gap-5">
            <span class="shrink-0 text-3xl">🧷</span>
            <div>
              <h3 class="mb-1 text-lg font-black">Persistent Top-Right Cart</h3>
              <p
                class="leading-relaxed font-medium text-neutral-700 dark:text-neutral-400"
              >
                A fixed cart pill shows item count and running total at all
                times — no scroll-to-bottom moment of doubt. Tapping it slides
                in a full-height drawer with quantity controls and a pickup-time
                selector.
              </p>
            </div>
          </div>
          <div class="flex gap-5">
            <span class="shrink-0 text-3xl">📷</span>
            <div>
              <h3 class="mb-1 text-lg font-black">
                Photo-Backed Menu with Graceful Fallback
              </h3>
              <p
                class="leading-relaxed font-medium text-neutral-700 dark:text-neutral-400"
              >
                Items with photography render edge-to-edge imagery via <code
                  >next/image</code
                >; items without fall back to a category-coloured placeholder —
                so the grid never looks half-finished while photo coverage rolls
                out.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Modal screenshot -->
  <section class="pb-20">
    <div class="px-4 md:px-8">
      <div class="mx-auto max-w-md">
        <div
          class="overflow-hidden rounded-2xl border-2 border-zinc-200 shadow-xl dark:border-zinc-700/50"
        >
          <img
            src="/images/six-nutrition/six-nutrition-modal.png"
            alt="6Nutrition customise-item modal — required 'Choice of Preparation' radio group above an 'Extra Sides' multi-select list, with live price, validation message, and Add to Order CTA pinned to the bottom"
            class="block h-auto w-full"
          />
        </div>
        <p
          class="mt-4 text-center text-sm font-medium text-neutral-500 dark:text-neutral-400"
        >
          The customise-item modal: required choices, multi-select extras, live
          validation and a sticky total.
        </p>
      </div>
    </div>
  </section>

  <!-- Mobile screenshot -->
  <section class="pb-20">
    <div class="px-4 md:px-8">
      <div class="mx-auto max-w-sm">
        <div
          class="overflow-hidden rounded-2xl border-2 border-zinc-200 shadow-xl dark:border-zinc-700/50"
        >
          <img
            src="/images/six-nutrition/six-nutrition-mobile.png"
            alt="6Nutrition ordering on mobile — pastel mint hero with brand mark and phone number above a single-column Breakfast menu showing the 'All in One Breaky' item with food photography and price"
            class="block h-auto w-full"
            width="1000"
            height="1576"
          />
        </div>
        <p
          class="mt-4 text-center text-sm font-medium text-neutral-500 dark:text-neutral-400"
        >
          The same ordering flow on mobile: a single-column, thumb-friendly menu
          that keeps food photography and pricing front and centre.
        </p>
      </div>
    </div>
  </section>

  <!-- Technical Architecture -->
  <section class="bg-zinc-50 py-20 dark:bg-neutral-900">
    <div class="px-4 md:px-8">
      <div class="grid max-w-6xl gap-12 md:grid-cols-3">
        <div class="md:col-span-1">
          <p
            class="mb-3 text-xs font-bold tracking-widest text-neutral-400 uppercase"
          >
            Engineering
          </p>
          <h2 class="mb-4 text-3xl font-black">Technical Architecture</h2>
        </div>
        <div class="space-y-6 md:col-span-2">
          <p
            class="text-lg leading-relaxed font-medium text-neutral-700 dark:text-neutral-300"
          >
            Built on Next.js 16 App Router and deployed on Vercel. The menu is a
            single JSON document resolved server-side; the cart lives in client
            state; checkout and webhooks run as Vercel Functions backed by
            Stripe.
          </p>
          <div class="grid gap-4 sm:grid-cols-3">
            <div
              class="rounded-xl border-2 border-zinc-200 bg-white p-5 dark:border-zinc-700/50 dark:bg-zinc-900"
            >
              <p
                class="mb-2 text-xs font-bold tracking-widest text-neutral-400 uppercase"
              >
                Framework
              </p>
              <p class="font-black">Next.js 16</p>
              <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">
                App Router · RSC
              </p>
            </div>
            <div
              class="rounded-xl border-2 border-zinc-200 bg-white p-5 dark:border-zinc-700/50 dark:bg-zinc-900"
            >
              <p
                class="mb-2 text-xs font-bold tracking-widest text-neutral-400 uppercase"
              >
                Payments
              </p>
              <p class="font-black">Stripe</p>
              <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">
                Checkout · Webhooks
              </p>
            </div>
            <div
              class="rounded-xl border-2 border-zinc-200 bg-white p-5 dark:border-zinc-700/50 dark:bg-zinc-900"
            >
              <p
                class="mb-2 text-xs font-bold tracking-widest text-neutral-400 uppercase"
              >
                Hosting
              </p>
              <p class="font-black">Vercel</p>
              <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">
                Fluid Compute · Edge
              </p>
            </div>
          </div>

          <!-- Architecture flow diagram -->
          <div
            class="overflow-x-auto rounded-xl border-2 border-zinc-700 bg-zinc-900 p-6 font-mono text-sm dark:bg-black"
          >
            <pre
              class="leading-relaxed whitespace-pre text-zinc-300"><span class="text-indigo-400">menu.json</span> ──▶ <span class="text-green-400">getMenu()</span> ──▶ <span class="text-yellow-400">RSC Page</span> ──▶ <span class="text-pink-400">MenuItemCard</span>
                                                              │
                                                              ▼
                                                       <span class="text-blue-400">Cart (client)</span>
                                                              │
                                                              ▼
                                                  <span class="text-orange-400">/api/checkout</span>
                                                              │
                                                              ▼
                                                       <span class="text-green-400">Stripe Checkout</span>
                                                              │
                                              ┌───────────────┴───────────────┐
                                              ▼                               ▼
                                <span class="text-pink-400">/api/stripe/webhook</span>      <span class="text-indigo-400">/api/cron/reconcile</span>
                                              │                               │
                                              └─────────────▶ <span class="text-green-400">/kitchen</span> ◀─────────────┘</pre>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Order lifecycle -->
  <section class="py-20">
    <div class="px-4 md:px-8">
      <div class="mx-auto max-w-6xl">
        <div class="mb-12 max-w-2xl">
          <p
            class="mb-3 text-xs font-bold tracking-widest text-neutral-400 uppercase"
          >
            Real-time
          </p>
          <h2 class="mb-4 text-3xl font-black">From Checkout to Kitchen</h2>
          <p
            class="text-lg leading-relaxed font-medium text-neutral-700 dark:text-neutral-300"
          >
            A paid order hands the customer a short pickup code and drops a live
            ticket onto the kitchen dashboard. Staff move each ticket from
            <strong class="text-black dark:text-white">preparing</strong> to
            <strong class="text-black dark:text-white">ready</strong> to
            <strong class="text-black dark:text-white">collected</strong>, and
            the board refreshes itself every few seconds — no hardware, no app
            to install.
          </p>
        </div>

        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          <figure>
            <div
              class="overflow-hidden rounded-xl border-2 border-zinc-200 shadow-md dark:border-zinc-700/50"
            >
              <img
                src="/images/six-nutrition/order-received.png"
                alt="6Nutrition customer confirmation screen — large 'XCUZ' order code, an 'Order received' heading, the pickup time, and a 'Back to menu' link on the pastel mint background"
                class="block h-auto w-full"
                width="704"
                height="535"
              />
            </div>
            <figcaption
              class="mt-3 text-center text-xs font-medium text-neutral-500 dark:text-neutral-400"
            >
              Customer confirmation: a pickup code and time.
            </figcaption>
          </figure>

          <figure>
            <div
              class="overflow-hidden rounded-xl border-2 border-zinc-200 shadow-md dark:border-zinc-700/50"
            >
              <img
                src="/images/six-nutrition/kitchen-state-1.png"
                alt="6Nutrition kitchen dashboard — two paid order tickets (VYX4 and XCUZ) with item, pickup time and price, each showing a 'Start preparing' button"
                class="block h-auto w-full"
                width="704"
                height="535"
              />
            </div>
            <figcaption
              class="mt-3 text-center text-xs font-medium text-neutral-500 dark:text-neutral-400"
            >
              The kitchen board: new paid tickets ready to start.
            </figcaption>
          </figure>

          <figure class="sm:col-span-2 lg:col-span-1">
            <div
              class="overflow-hidden rounded-xl border-2 border-zinc-200 shadow-md dark:border-zinc-700/50"
            >
              <img
                src="/images/six-nutrition/kitchen-state-2.png"
                alt="6Nutrition kitchen dashboard after staff action — ticket VYX4 marked 'Ready' with a 'Mark collected' button, while XCUZ is 'Preparing' with a 'Mark ready' button"
                class="block h-auto w-full"
                width="704"
                height="535"
              />
            </div>
            <figcaption
              class="mt-3 text-center text-xs font-medium text-neutral-500 dark:text-neutral-400"
            >
              Status updates as staff progress each ticket.
            </figcaption>
          </figure>
        </div>
      </div>
    </div>
  </section>

  <!-- Results -->
  <section class="py-20">
    <div class="px-4 md:px-8">
      <div class="grid max-w-6xl gap-12 md:grid-cols-3">
        <div class="md:col-span-1">
          <p
            class="mb-3 text-xs font-bold tracking-widest text-neutral-400 uppercase"
          >
            Impact
          </p>
          <h2 class="mb-4 text-3xl font-black">The Result</h2>
        </div>
        <div class="space-y-6 md:col-span-2">
          <p
            class="text-lg leading-relaxed font-medium text-neutral-700 dark:text-neutral-300"
          >
            6Nutrition customers can browse, customise and pay for pickup in
            under a minute — without taking up counter time or risking a missed
            modifier. The kitchen sees exactly what was ordered, when it's due,
            and who it's for.
          </p>
          <ul class="space-y-4">
            <li
              class="flex items-start gap-3 text-lg font-medium text-neutral-700 dark:text-neutral-300"
            >
              <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-green-500"
              ></span>
              <span
                ><strong class="text-black dark:text-white"
                  >Under a minute</strong
                > from landing page to a paid, scheduled pickup order.</span
              >
            </li>
            <li
              class="flex items-start gap-3 text-lg font-medium text-neutral-700 dark:text-neutral-300"
            >
              <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-green-500"
              ></span>
              <span
                ><strong class="text-black dark:text-white"
                  >Zero phone orders</strong
                > to transcribe — every modifier choice is captured, priced and ticketed
                automatically.</span
              >
            </li>
            <li
              class="flex items-start gap-3 text-lg font-medium text-neutral-700 dark:text-neutral-300"
            >
              <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-green-500"
              ></span>
              <span
                ><strong class="text-black dark:text-white"
