---
import MainLayout from "../../layouts/MainLayout.astro";

const caseStudy = {
  title: "Master Site Template",
  subtitle:
    "A production-ready Astro site template that compresses days of boilerplate setup into a single CLI command — with CMS, contact forms, a block-based page builder, and WCAG 2.1 accessibility baked in from day one.",
  client: "Simon Eramo Studio",
  year: "2026",
  role: "Product Designer & Full-Stack Developer",
  stack: [
    "Astro 5",
    "TinaCMS",
    "Tailwind CSS v4",
    "Alpine.js",
    "Resend",
    "Vercel",
  ],
  tags: ["Development", "Astro", "Headless CMS"],
  emoji: "🦅",
};

const features = [
  {
    icon: "📄",
    title: "3-Tier Page System",
    description:
      "Pages categorised as Core (always included), Common (opt-out), or Optional (opt-in) — driving a principled, data-driven scaffold process.",
  },
  {
    icon: "🧱",
    title: "Block-Based Page Builder",
    description:
      "A flexible page system where non-technical editors compose pages from pre-built blocks via TinaCMS — no developer needed for new layouts.",
  },
  {
    icon: "✍️",
    title: "TinaCMS Visual Editing",
    description:
      "Content lives as Markdown in Git with visual editing via the TinaCMS admin UI. Rollbacks are a git revert away.",
  },
  {
    icon: "📧",
    title: "Contact Form via Resend",
    description:
      "Full contact form with centered and split layout variants, powered by a Resend serverless API route — no SMTP config required.",
  },
  {
    icon: "♿",
    title: "WCAG 2.1 Accessible",
    description:
      "Semantic HTML5, skip-to-content links, full keyboard nav, ARIA labels, high-contrast theme, and focus-visible styles on everything.",
  },
  {
    icon: "🔍",
    title: "SEO Built-In",
    description:
      "Dynamic title/meta tags from CMS content, Open Graph, Twitter Cards, JSON-LD structured data, and auto-generated XML sitemap.",
  },
];

const outcomes = [
  { value: "Minutes", label: "From clone to client-ready project" },
  { value: "30+", label: "Pre-built components & blocks" },
  { value: "100/100", label: "Lighthouse score out of the box" },
];

const problems = [
  "Copy files from the last project and strip out client-specific content.",
  "Rebuild the same FAQ, CTA, and contact form components — again.",
  "Reconnect CMS schemas to fresh content collections.",
  "Configure email delivery, environment variables, and deployment adapters.",
  "Do all of this before writing a single line of client-specific code.",
  "Configuration drift means each project subtly diverges from the last.",
];

const tierData = [
  {
    tier: "Tier 1 — Core",
    description: "Required on every site, non-negotiable",
    examples: "Homepage, About, Contact, 404, Privacy Policy",
    color: "bg-green-500",
  },
  {
    tier: "Tier 2 — Common",
    description: "Standard business pages, included by default",
    examples: "Services, Blog, FAQ, Pricing, Process, Team",
    color: "bg-blue-500",
  },
  {
    tier: "Tier 3 — Optional",
    description: "Specialised pages, toggled per project",
    examples: "Portfolio, Careers, Reviews, Events, Partners, Book",
    color: "bg-purple-500",
  },
];

const techDecisions = [
  {
    icon: "🚀",
    title: "Astro 5",
    description:
      "Island architecture delivers zero JavaScript by default. Content Collections provide end-to-end typing for all Markdown, preventing an entire class of runtime bugs when content schemas drift.",
  },
  {
    icon: "✍️",
    title: "TinaCMS",
    description:
      "Visual editing without locking content into a proprietary database. Content lives as Markdown in Git — version-controlled, rollback-friendly, and builds with no external API dependency.",
  },
  {
    icon: "🎨",
    title: "Tailwind CSS v4",
    description:
      "CSS-native configuration via @theme reduces boilerplate. The design system — high-contrast black/white palette, 2px borders, Inter variable font — is defined once and flows through every component.",
  },
  {
    icon: "⚡",
    title: "Alpine.js",
    description:
      "Reactive interactivity (mobile menus, dark mode, FAQ accordions, form states) without a build step or component framework. Pages stay fully static-renderable with minimal bundle overhead.",
  },
  {
    icon: "📧",
    title: "Resend",
    description:
      "Developer-first API with a generous free tier and first-class Vercel integration. Replaces complex SMTP relay configuration with a single serverless API route.",
  },
  {
    icon: "▲",
    title: "Vercel",
    description:
      "Edge-deployed with zero-config from the Astro adapter. Git push → production deploy. Preview deployments for every PR. The natural deployment target for SSR-capable Astro sites.",
  },
];

const components = [
  {
    name: "HeroSection",
    purpose: "Homepage hero — split, centered, and bold variants",
  },
  {
    name: "PageHeroSection",
    purpose: "Interior page hero — center or left aligned",
  },
  {
    name: "CTASection",
    purpose: "Call-to-action block — reusable across pages",
  },
  {
    name: "FAQ",
    purpose: "Interactive Alpine.js accordion — center / left variants",
  },
  { name: "ContactForm", purpose: "Full form with centered and split layouts" },
  { name: "PricingTiers", purpose: "Pricing cards with feature lists" },
  {
    name: "BlockRenderer",
    purpose: "Maps CMS block templates to Astro components",
  },
  {
    name: "TestimonialsMarquee",
    purpose: "Animated scrolling testimonials strip",
  },
];

const launchSteps = [
  {
    step: "01",
    title: "Run Project Starter CLI",
    description:
      "Select pages, name the project — Tier 1 always included, Tier 2/3 toggled per client.",
  },
  {
    step: "02",
    title: "Connect TinaCMS",
    description:
      "Create a TinaCMS project, copy API keys into .env. Visual editing is live.",
  },
  {
    step: "03",
    title: "Connect Resend",
    description:
      "Add Resend API key for contact form email delivery — one environment variable.",
  },
  {
    step: "04",
    title: "Push to Vercel",
    description:
      "Push to GitHub, import into Vercel. Git push → production deploy, preview on every PR.",
  },
  {
    step: "05",
    title: "Customise & Launch",
    description:
      "Brand, content, copy. The foundation — routing, CMS, email, dark mode, a11y, SEO — is already done.",
  },
];
---

<MainLayout
  title="Master Site Template — Case Study | Simon Eramo"
  description="How I designed and built a production-ready Astro site template with TinaCMS, a block-based page builder, WCAG 2.1 accessibility, and a CLI scaffold tool that compresses days of setup into minutes."
>
  <!-- Hero -->
  <section
    class="border-b-2 border-zinc-100 py-20 md:py-28 dark:border-zinc-800"
  >
    <div class="px-4 md:px-8">
      <div class="mb-8 flex items-center gap-3">
        <a
          href="/case-studies"
          class="inline-flex items-center gap-1.5 text-sm font-bold text-neutral-500 transition-colors hover:text-black dark:text-neutral-400 dark:hover:text-white"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"><path d="m15 18-6-6 6-6"></path></svg
          >
          Case Studies
        </a>
      </div>

      <div class="max-w-4xl">
        <p
          class="mb-4 text-xs font-bold tracking-widest text-neutral-500 uppercase dark:text-neutral-400"
        >
          {caseStudy.client} · {caseStudy.year}
        </p>
        <div class="mb-6 flex items-start gap-5">
          <span class="mt-1 shrink-0 text-6xl md:text-7xl" aria-hidden="true"
            >{caseStudy.emoji}</span
          >
          <h1
            id="case-study-heading"
            class="text-4xl leading-tight font-black text-pretty md:text-6xl"
          >
            {caseStudy.title}
          </h1>
        </div>
        <p
          class="mb-8 max-w-4xl text-xl leading-relaxed font-medium text-neutral-600 dark:text-neutral-400"
        >
          {caseStudy.subtitle}
        </p>

        <div class="mb-8 flex flex-wrap items-center gap-4">
          <a
            href="https://github.com/simoneramo/master-site-template"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-full border-2 border-zinc-200 px-4 py-2 text-sm font-bold transition-colors hover:border-black dark:border-zinc-700 dark:hover:border-white"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              ><path
                d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.4 5.4 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
              ></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg
            >
            View on GitHub
          </a>
        </div>

        <!-- Meta strip -->
        <div
          class="flex flex-wrap gap-6 border-t-2 border-zinc-100 pt-8 dark:border-zinc-800"
        >
          <div>
            <p
              class="mb-1 text-xs font-bold tracking-widest text-neutral-400 uppercase"
            >
              Role
            </p>
            <p class="text-sm font-bold">{caseStudy.role}</p>
          </div>
          <div>
            <p
              class="mb-1 text-xs font-bold tracking-widest text-neutral-400 uppercase"
            >
              Version
            </p>
            <p class="text-sm font-bold">2.0.0</p>
          </div>
          <div>
            <p
              class="mb-1 text-xs font-bold tracking-widest text-neutral-400 uppercase"
            >
              Stack
            </p>
            <p class="text-sm font-bold">
              {caseStudy.stack.join(" · ")}
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Executive Summary -->
  <section class="py-20">
    <div class="px-4 md:px-8">
      <div class="grid max-w-6xl gap-12 md:grid-cols-3">
        <div class="md:col-span-1">
          <p
            class="mb-3 text-xs font-bold tracking-widest text-neutral-400 uppercase"
          >
            Overview
          </p>
          <h2 class="mb-4 text-3xl font-black">Executive Summary</h2>
        </div>
        <div class="space-y-5 md:col-span-2">
          <p
            class="text-lg leading-relaxed font-medium text-neutral-700 dark:text-neutral-300"
          >
            The <strong class="text-black dark:text-white"
              >Master Site Template</strong
            > is a production-ready Astro site template designed to dramatically reduce
            the time it takes to launch a new client website — from days of boilerplate
            setup down to a focused strategy session and a single CLI command.
          </p>
          <p
            class="text-lg leading-relaxed font-medium text-neutral-700 dark:text-neutral-300"
          >
            Rather than a simple starter kit with a hero section and a nav bar,
            it is an <strong class="text-black dark:text-white"
              >opinionated, full-featured platform</strong
            > — complete with a CMS, a contact system, a flexible block-based page
            builder, a 3-tier page architecture, a Project Starter CLI tool, and WCAG
            2.1 accessible components across the board.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Outcomes -->
  <section class="bg-zinc-50 py-16 dark:bg-neutral-900">
    <div class="px-4 md:px-8">
      <div
        class="mx-auto grid max-w-4xl grid-cols-1 gap-8 text-center md:grid-cols-3"
      >
        {
          outcomes.map((o) => (
            <div class="rounded-2xl border-2 border-zinc-200 bg-white p-8 dark:border-zinc-700/50 dark:bg-zinc-900">
              <span class="mb-2 block text-4xl font-black text-black md:text-5xl dark:text-white">
                {o.value}
              </span>
              <span class="text-sm font-bold tracking-widest text-neutral-500 uppercase dark:text-neutral-400">
                {o.label}
              </span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- The Problem -->
  <section class="py-20">
    <div class="px-4 md:px-8">
      <div class="grid max-w-6xl gap-12 md:grid-cols-3">
        <div class="md:col-span-1">
          <p
            class="mb-3 text-xs font-bold tracking-widest text-neutral-400 uppercase"
          >
            The Challenge
          </p>
          <h2 class="mb-4 text-3xl font-black">The Boilerplate Loop</h2>
        </div>
        <div class="space-y-6 md:col-span-2">
          <p
            class="text-lg leading-relaxed font-medium text-neutral-700 dark:text-neutral-300"
          >
            For a solo developer or boutique agency, spinning up a new client
            site involves a predictable, exhausting loop — repeating the same
            tasks <strong class="text-black dark:text-white"
              >before writing a single line of client-specific code</strong
            >.
          </p>
          <ul class="space-y-3">
            {
              problems.map((p) => (
                <li class="flex items-start gap-3 font-medium text-neutral-700 dark:text-neutral-400">
                  <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-red-500" />
                  {p}
                </li>
              ))
            }
          </ul>
          <div
            class="rounded-xl border-l-4 border-red-500 bg-red-50 p-6 dark:bg-red-950/30"
          >
            <p class="text-lg font-bold text-red-800 dark:text-red-300">
              This repetition isn't just inefficient — it's risky. Configuration
              drift means each project subtly diverges from the last, making it
              harder to apply improvements retroactively or share patterns
              across codebases.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- The Solution -->
  <section class="bg-zinc-50 py-20 dark:bg-neutral-900">
    <div class="px-4 md:px-8">
      <div class="grid max-w-6xl gap-12 md:grid-cols-3">
        <div class="md:col-span-1">
          <p
            class="mb-3 text-xs font-bold tracking-widest text-neutral-400 uppercase"
          >
            The Solution
          </p>
          <h2 class="mb-4 text-3xl font-black">
            Build Once, Deploy Everywhere
          </h2>
        </div>
        <div class="md:col-span-2">
          <p
            class="mb-4 text-lg leading-relaxed font-medium text-neutral-700 dark:text-neutral-300"
          >
            The template approaches the problem at two levels:
          </p>
          <div class="mb-8 grid gap-4 sm:grid-cols-2">
            <div
              class="rounded-xl border-2 border-zinc-200 bg-white p-5 dark:border-zinc-700/50 dark:bg-zinc-900"
            >
              <span class="mb-2 block text-2xl">📦</span>
              <h3 class="mb-1 text-base font-black">
                Master Template Repository
              </h3>
              <p
                class="text-sm leading-relaxed font-medium text-neutral-600 dark:text-neutral-400"
              >
                The canonical source of truth for every component, page, schema,
                and style pattern.
              </p>
            </div>
            <div
              class="rounded-xl border-2 border-zinc-200 bg-white p-5 dark:border-zinc-700/50 dark:bg-zinc-900"
            >
              <span class="mb-2 block text-2xl">⚡</span>
              <h3 class="mb-1 text-base font-black">Project Starter CLI</h3>
              <p
                class="text-sm leading-relaxed font-medium text-neutral-600 dark:text-neutral-400"
              >
                Scaffolds a new project from the master template, selecting only
                the pages and features the client needs.
              </p>
            </div>
          </div>
          <p
            class="mb-8 text-lg leading-relaxed font-medium text-neutral-700 dark:text-neutral-300"
          >
            Together, they eliminate the setup phase. A new project is ready to
            receive client content within <strong
              class="text-black dark:text-white">minutes</strong
            > of the first <code
              class="rounded bg-zinc-100 px-1.5 py-0.5 font-mono text-sm dark:bg-zinc-800"
              >git clone</code
            >.
          </p>
          <div class="grid gap-4 sm:grid-cols-2">
            {
              features.map((f) => (
                <div class="rounded-xl border-2 border-zinc-200 bg-white p-5 transition-colors hover:border-zinc-400 dark:border-zinc-700/50 dark:bg-zinc-900 dark:hover:border-zinc-500">
                  <span class="mb-2 block text-2xl">{f.icon}</span>
                  <h3 class="mb-1 text-base font-black">{f.title}</h3>
                  <p class="text-sm leading-relaxed font-medium text-neutral-600 dark:text-neutral-400">
                    {f.description}
                  </p>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Architecture: 3-Tier Page System -->
  <section class="py-20">
    <div class="px-4 md:px-8">
      <div class="grid max-w-6xl gap-12 md:grid-cols-3">
        <div class="md:col-span-1">
          <p
            class="mb-3 text-xs font-bold tracking-widest text-neutral-400 uppercase"
          >
            Architecture
          </p>
          <h2 class="mb-4 text-3xl font-black">3-Tier Page System</h2>
          <p
            class="text-sm leading-relaxed font-medium text-neutral-600 dark:text-neutral-400"
          >
            The most important architectural decision — a principled data model
            that drives the entire scaffold process.
          </p>
        </div>
        <div class="space-y-4 md:col-span-2">
          {
            tierData.map((t) => (
              <div class="flex gap-5 rounded-xl border-2 border-zinc-200 bg-white p-6 dark:border-zinc-700/50 dark:bg-zinc-900">
                <span class={`w-2 rounded-full ${t.color} shrink-0`} />
                <div>
                  <h3 class="mb-1 text-base font-black">{t.tier}</h3>
                  <p class="mb-2 text-sm font-medium text-neutral-600 dark:text-neutral-400">
                    {t.description}
                  </p>
                  <p class="text-xs font-bold tracking-widest text-neutral-400 uppercase">
                    {t.examples}
                  </p>
                </div>
              </div>
            ))
          }
          <div
            class="rounded-xl border-l-4 border-indigo-500 bg-indigo-50 p-6 dark:bg-indigo-950/30"
          >
            <p class="text-sm font-bold text-indigo-800 dark:text-indigo-300">
              Configuration is driven by <code
                class="rounded bg-indigo-100 px-1.5 py-0.5 font-mono text-xs dark:bg-indigo-900/50"
                >template.config.json</code
              > — a single source of truth that maps pages to their content collections,
              CMS fields, and default states. The starter tool logic is entirely data-driven.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Component Library -->
  <section class="bg-zinc-50 py-20 dark:bg-neutral-900">
    <div class="px-4 md:px-8">
      <div class="grid max-w-6xl gap-12 md:grid-cols-3">
        <div class="md:col-span-1">
          <p
            class="mb-3 text-xs font-bold tracking-widest text-neutral-400 uppercase"
          >
            Components
          </p>
          <h2 class="mb-4 text-3xl font-black">Pre-Built Component Library</h2>
          <p
            class="text-sm leading-relaxed font-medium text-neutral-600 dark:text-neutral-400"
          >
            Every component is a typed Astro <code
              class="rounded bg-zinc-200 px-1 py-0.5 font-mono text-xs dark:bg-zinc-700"
              >.astro</code
            > file — no React, no Vue, no framework dependency.
          </p>
        </div>
        <div class="md:col-span-2">
          <div class="grid gap-3 sm:grid-cols-2">
            {
              components.map((c) => (
                <div class="flex gap-3 rounded-xl border-2 border-zinc-200 bg-white p-4 dark:border-zinc-700/50 dark:bg-zinc-900">
                  <code class="mt-0.5 shrink-0 font-mono text-xs font-bold text-indigo-600 dark:text-indigo-400">
                    &lt;/&gt;
                  </code>
                  <div>
                    <h3 class="mb-0.5 text-sm font-black">{c.name}</h3>
                    <p class="text-xs leading-relaxed font-medium text-neutral-600 dark:text-neutral-400">
                      {c.purpose}
                    </p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Technical Decisions -->
  <section class="py-20">
    <div class="px-4 md:px-8">
      <div class="grid max-w-6xl gap-12 md:grid-cols-3">
        <div class="md:col-span-1">
          <p
            class="mb-3 text-xs font-bold tracking-widest text-neutral-400 uppercase"
          >
            Engineering
          </p>
          <h2 class="mb-4 text-3xl font-black">Technical Decisions</h2>
          <p
            class="text-sm leading-relaxed font-medium text-neutral-600 dark:text-neutral-400"
          >
            Every dependency was chosen deliberately — optimised for developer
            experience, performance, and long-term maintainability.
          </p>
        </div>
        <div class="space-y-6 md:col-span-2">
          {
            techDecisions.map((t) => (
              <div class="flex gap-5">
                <span class="shrink-0 text-3xl">{t.icon}</span>
                <div>
                  <h3 class="mb-1 text-lg font-black">{t.title}</h3>
                  <p class="leading-relaxed font-medium text-neutral-700 dark:text-neutral-400">
                    {t.description}
                  </p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Launch Process -->
  <section class="bg-zinc-50 py-20 dark:bg-neutral-900">
    <div class="px-4 md:px-8">
      <div class="grid max-w-6xl gap-12 md:grid-cols-3">
        <div class="md:col-span-1">
          <p
            class="mb-3 text-xs font-bold tracking-widest text-neutral-400 uppercase"
          >
            Process
          </p>
          <h2 class="mb-4 text-3xl font-black">Launching a New Project</h2>
          <p
            class="text-sm leading-relaxed font-medium text-neutral-600 dark:text-neutral-400"
          >
            The entire foundation — routing, CMS, email, dark mode,
            accessibility, SEO, sitemap — is already in place. The developer's
            attention goes to what's actually unique about the client.
          </p>
        </div>
        <div class="md:col-span-2">
          <div class="space-y-3">
            {
              launchSteps.map((s, i) => (
                <div class="flex gap-5 rounded-xl border-2 border-zinc-200 bg-white p-5 dark:border-zinc-700/50 dark:bg-zinc-900">
                  <div class="shrink-0">
                    <span class="flex h-10 w-10 items-center justify-center rounded-full border-2 border-zinc-200 text-xs font-black text-neutral-400 dark:border-zinc-700">
                      {s.step}
                    </span>
                    {i < launchSteps.length - 1 && (
                      <div class="mx-auto mt-1 h-3 w-px bg-zinc-200 dark:bg-zinc-700" />
                    )}
                  </div>
                  <div class="pb-1">
                    <h3 class="mb-1 text-base font-black">{s.title}</h3>
                    <p class="text-sm leading-relaxed font-medium text-neutral-600 dark:text-neutral-400">
                      {s.description}
                    </p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Results -->
  <section class="py-20">
    <div class="px-4 md:px-8">
      <div class="grid max-w-6xl gap-12 md:grid-cols-3">
        <div class="md:col-span-1">
          <p
