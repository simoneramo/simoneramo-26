---
import MainLayout from "../../layouts/MainLayout.astro";

const caseStudy = {
  title: "Little Pigeon Massage & Waxing",
  subtitle:
    "A calm, conversion-focused marketing site for a Melbourne wellness studio — built on Astro with image-heavy storytelling, integrated booking, gift cards, a journal, and serverless contact forms.",
  client: "Little Pigeon Massage & Waxing",
  year: "2025",
  role: "Designer & Full-Stack Developer",
  stack: [
    "Astro 6",
    "Tailwind CSS v4",
    "Alpine.js",
    "Lucide Icons",
    "Vercel",
    "Resend",
  ],
  tags: ["Web Design", "Development", "Astro"],
  emoji: "🕊️",
};

const outcomes = [
  { value: "10+", label: "Pages Shipped" },
  { value: "0", label: "Monthly CMS Cost" },
  { value: "100%", label: "Static & Fast" },
  { value: "1", label: "Owner Inbox" },
];

const problems = [
  {
    title: "Outdated Wix Presence",
    description:
      "The studio's existing site was hosted on a heavy template-builder platform — slow on mobile, hard to update, and visually generic for a brand that trades on calm, premium hospitality.",
  },
  {
    title: "Fragmented Booking & Enquiry",
    description:
      "Appointments, gift card sales, and general enquiries lived across multiple third-party tools with no single funnel guiding visitors from interest to booking.",
  },
  {
    title: "Local Discoverability",
    description:
      "The business needed to rank for massage and waxing search terms across the local area and surface key service pages — services, FAQs, and seasonal promotions — to convert browsers into bookings.",
  },
  {
    title: "Content That Couldn't Breathe",
    description:
      "A growing library of treatment imagery, testimonials, and a wellness journal needed a home that prioritised editorial-style layout over busy template chrome.",
  },
];

const solutions = [
  {
    letter: "A",
    title: "Astro-Powered Static Architecture",
    description:
      "Rebuilt the entire site on Astro 6 with the Vercel adapter, producing a fast, mostly-static experience with progressive enhancement only where needed. Pages compile to lightweight HTML with optimised images via Astro's built-in pipeline.",
  },
  {
    letter: "B",
    title: "Editorial Layout with Premium Imagery",
    description:
      "Designed an image-led visual system using AVIF assets, considered typography pairings from Fontsource (Hepta Slab, Manrope, Outfit), and a soft, on-brand palette that lets the studio's photography lead the story.",
  },
  {
    letter: "C",
    title: "Dedicated Conversion Pages",
    description:
      "Built standalone routes for Services, Book Appointment, Gift Cards, FAQ, Contact, an Autumn Promo landing page, and a Journal — each tuned for a specific intent so paid and organic traffic land on the right surface.",
  },
  {
    letter: "D",
    title: "Serverless Contact + Messenger Hand-off",
    description:
      "Form submissions flow through a Resend-backed Astro API route to the owner's inbox, while Facebook Messenger and WhatsApp components capture mobile visitors who prefer to chat. No third-party form SaaS, no monthly fees.",
  },
];

const projectDetails = [
  { label: "Client", value: "Little Pigeon Massage & Waxing" },
  { label: "Industry", value: "Wellness / Beauty Services" },
  { label: "Location", value: "Melbourne, VIC" },
  { label: "Type", value: "Multi-page Marketing Site + Journal" },
  { label: "Live URL", value: "littlepigeon.com.au" },
];
---

<MainLayout
  title="Little Pigeon — Case Study | Simon Eramo"
  description="How I designed and built a calm, conversion-focused multi-page marketing site for Little Pigeon Massage & Waxing using Astro, Tailwind CSS, and a serverless contact backend."
>
  <!-- Hero -->
  <section
    class="border-b-2 border-zinc-100 py-20 md:py-28 dark:border-zinc-800"
  >
    <div class="px-4 md:px-8">
      <div class="mb-8 flex items-center gap-3">
        <a
          href="/case-studies"
          class="inline-flex items-center gap-1.5 text-sm font-bold text-neutral-500 transition-colors hover:text-black dark:text-neutral-400 dark:hover:text-white"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"><path d="m15 18-6-6 6-6"></path></svg
          >
          Case Studies
        </a>
        <span class="text-neutral-300 dark:text-neutral-600">/</span>
        <span
          class="text-xs font-bold tracking-widest text-neutral-400 uppercase"
          >Web Design</span
        >
      </div>

      <div class="max-w-4xl">
        <p
          class="mb-4 text-xs font-bold tracking-widest text-neutral-500 uppercase dark:text-neutral-400"
        >
          {caseStudy.client} · {caseStudy.year}
        </p>
        <div class="mb-6 flex items-start gap-5">
          <span class="mt-1 shrink-0 text-6xl md:text-7xl" aria-hidden="true"
            >{caseStudy.emoji}</span
          >
          <h1
            id="case-study-heading"
            class="text-4xl leading-tight font-black text-pretty md:text-6xl"
          >
            {caseStudy.title}
          </h1>
        </div>
        <p
          class="mb-8 max-w-4xl text-xl leading-relaxed font-medium text-neutral-600 dark:text-neutral-400"
        >
          {caseStudy.subtitle}
        </p>

        <div class="mb-8 flex flex-wrap items-center gap-4">
          <a
            href="https://littlepigeon.com.au"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-full border-2 border-zinc-200 px-4 py-2 text-sm font-bold transition-colors hover:border-black dark:border-zinc-700 dark:hover:border-white"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              ><path
                d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"
              ></path><polyline points="15 3 21 3 21 9"></polyline><line
                x1="10"
                x2="21"
                y1="14"
                y2="3"></line></svg
            >
            View live site
          </a>
        </div>

        <!-- Meta strip -->
        <div
          class="flex flex-wrap gap-6 border-t-2 border-zinc-100 pt-8 dark:border-zinc-800"
        >
          <div>
            <p
              class="mb-1 text-xs font-bold tracking-widest text-neutral-400 uppercase"
            >
              Role
            </p>
            <p class="text-sm font-bold">{caseStudy.role}</p>
          </div>
          <div>
            <p
              class="mb-1 text-xs font-bold tracking-widest text-neutral-400 uppercase"
            >
              Year
            </p>
            <p class="text-sm font-bold">{caseStudy.year}</p>
          </div>
          <div>
            <p
              class="mb-1 text-xs font-bold tracking-widest text-neutral-400 uppercase"
            >
              Stack
            </p>
            <p class="text-sm font-bold">{caseStudy.stack.join(" · ")}</p>
          </div>
        </div>
      </div>

      <!-- Hero product screenshot -->
      <div
        class="mx-auto mt-12 max-w-2xl overflow-hidden rounded-2xl border-2 border-zinc-200 shadow-xl dark:border-zinc-700/50"
      >
        <img
          src="/images/little-pigeon-home.webp"
          alt="Little Pigeon Massage & Waxing — homepage showing the studio's hero, services and editorial imagery"
          class="block h-auto w-full"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <!-- Outcomes -->
  <section class="bg-zinc-50 py-16 dark:bg-neutral-900">
    <div class="px-4 md:px-8">
      <div
        class="mx-auto grid max-w-4xl grid-cols-2 gap-6 text-center md:grid-cols-4"
      >
        {
          outcomes.map((o) => (
            <div class="rounded-2xl border-2 border-zinc-200 bg-white p-6 md:p-8 dark:border-zinc-700/50 dark:bg-zinc-900">
              <span class="mb-2 block text-3xl font-black text-black md:text-5xl dark:text-white">
                {o.value}
              </span>
              <span class="text-xs font-bold tracking-widest text-neutral-500 uppercase dark:text-neutral-400">
                {o.label}
              </span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Project Details + Challenge -->
  <section class="py-20">
    <div class="px-4 md:px-8">
      <div class="grid max-w-6xl gap-12 md:grid-cols-3">
        <!-- Project details sidebar -->
        <div class="md:col-span-1">
          <p
            class="mb-3 text-xs font-bold tracking-widest text-neutral-400 uppercase"
          >
            Project Details
          </p>
          <div class="space-y-4">
            {
              projectDetails.map((d) => (
                <div>
                  <p class="mb-0.5 text-xs font-bold tracking-widest text-neutral-400 uppercase">
                    {d.label}
                  </p>
                  <p class="text-sm font-bold">{d.value}</p>
                </div>
              ))
            }
            <div>
              <p
                class="mb-2 text-xs font-bold tracking-widest text-neutral-400 uppercase"
              >
                Tech Stack
              </p>
              <div class="flex flex-col gap-1">
                {
                  [
                    { name: "Astro 6", role: "Framework" },
                    { name: "Tailwind CSS v4", role: "Styling" },
                    { name: "Alpine.js", role: "Interactivity" },
                    { name: "Lucide Icons", role: "Iconography" },
                    { name: "Vercel", role: "Hosting" },
                    { name: "Resend", role: "Email API" },
                  ].map((t) => (
                    <div class="flex items-center justify-between border-b border-zinc-100 py-1.5 dark:border-zinc-800">
                      <span class="text-sm font-black">{t.name}</span>
                      <span class="text-xs font-medium text-neutral-500 dark:text-neutral-400">
                        {t.role}
                      </span>
                    </div>
                  ))
                }
              </div>
            </div>
          </div>
        </div>

        <!-- Challenge -->
        <div class="space-y-8 md:col-span-2">
          <div>
            <p
              class="mb-3 text-xs font-bold tracking-widest text-neutral-400 uppercase"
            >
              The Challenge
            </p>
            <h2 class="mb-5 text-3xl font-black">
              Turning a Beloved Local Studio Into a Bookable Brand Online
            </h2>
            <p
              class="mb-8 text-lg leading-relaxed font-medium text-neutral-700 dark:text-neutral-300"
            >
              Little Pigeon is a boutique massage and waxing studio with a loyal
              local following. Their existing presence didn't reflect the calm,
              considered experience of the space, and key conversion paths —
              booking, gift cards, seasonal promos — were buried behind generic
              template chrome. The new site had to feel like the studio itself:
              warm, premium, and effortless to navigate.
            </p>
            <div class="space-y-5">
              {
                problems.map((p) => (
                  <div class="flex gap-4">
                    <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-red-500" />
                    <div>
                      <h3 class="mb-1 text-base font-black">{p.title}</h3>
                      <p class="text-sm leading-relaxed font-medium text-neutral-600 dark:text-neutral-400">
                        {p.description}
                      </p>
                    </div>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Solutions -->
  <section class="bg-zinc-50 py-20 dark:bg-neutral-900">
    <div class="px-4 md:px-8">
      <div class="grid max-w-6xl gap-12 md:grid-cols-3">
        <div class="md:col-span-1">
          <p
            class="mb-3 text-xs font-bold tracking-widest text-neutral-400 uppercase"
          >
            Solutions
          </p>
          <h2 class="mb-4 text-3xl font-black">How We Solved It</h2>
        </div>
        <div class="space-y-6 md:col-span-2">
          {
            solutions.map((s) => (
              <div class="flex gap-5 rounded-xl border-2 border-zinc-200 bg-white p-6 transition-colors hover:border-zinc-400 dark:border-zinc-700/50 dark:bg-zinc-900 dark:hover:border-zinc-500">
                <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-black text-sm font-black text-white dark:bg-white dark:text-black">
                  {s.letter}
                </span>
                <div>
                  <h3 class="mb-2 text-base font-black">{s.title}</h3>
                  <p class="text-sm leading-relaxed font-medium text-neutral-600 dark:text-neutral-400">
                    {s.description}
                  </p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Result -->
  <section class="py-20">
    <div class="px-4 md:px-8">
      <div class="grid max-w-6xl gap-12 md:grid-cols-3">
        <div class="md:col-span-1">
          <p
            class="mb-3 text-xs font-bold tracking-widest text-neutral-400 uppercase"
          >
            Result
          </p>
          <h2 class="mb-4 text-3xl font-black">A Calm Site That Converts</h2>
        </div>
        <div class="space-y-6 md:col-span-2">
          <p
            class="text-lg leading-relaxed font-medium text-neutral-700 dark:text-neutral-300"
          >
            The new Little Pigeon site replaces a slow, generic template with a
            fast, image-led Astro build that mirrors the in-studio experience.
            Every page is purpose-built — services explain treatments, the
            booking page guides clients in, gift cards and seasonal promos have
            dedicated landing pages, and the journal gives the brand a long-term
            content surface.
          </p>
          <p
            class="text-lg leading-relaxed font-medium text-neutral-700 dark:text-neutral-300"
          >
            With static delivery on Vercel, a serverless contact form, and full
            code ownership, the studio runs on near-zero ongoing platform cost
            while keeping room to grow.
          </p>
          <ul class="space-y-4 pt-2">
            <li
              class="flex items-start gap-3 text-lg font-medium text-neutral-700 dark:text-neutral-300"
            >
              <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-green-500"
              ></span>
              <span
                ><strong class="text-black dark:text-white"
                  >Dedicated conversion routes</strong
                > for booking, gift cards, services, FAQ, and seasonal promos.</span
              >
            </li>
            <li
              class="flex items-start gap-3 text-lg font-medium text-neutral-700 dark:text-neutral-300"
            >
              <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-green-500"
              ></span>
              <span
                ><strong class="text-black dark:text-white"
                  >Editorial journal</strong
                > giving the brand a long-term content surface for SEO and storytelling.</span
              >
            </li>
            <li
              class="flex items-start gap-3 text-lg font-medium text-neutral-700 dark:text-neutral-300"
            >
              <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-green-500"
              ></span>
              <span
                ><strong class="text-black dark:text-white"
                  >Serverless contact backend</strong
                > via Resend — enquiries land directly in the owner's inbox.</span
              >
            </li>
            <li
              class="flex items-start gap-3 text-lg font-medium text-neutral-700 dark:text-neutral-300"
            >
              <span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-green-500"
              ></span>
              <span
                ><strong class="text-black dark:text-white"
                  >Optimised imagery & sitemap</strong
                > using Astro's built-in image pipeline and sitemap integration.</span
              >
            </li>
          </ul>

          <div class="pt-2">
            <a
              href="https://littlepigeon.com.au"
              target="_blank"
              rel="noopener noreferrer"
              class="group relative inline-flex h-12 items-center justify-center overflow-hidden rounded-full bg-black px-8 font-bold text-white transition-all duration-300 dark:bg-white dark:text-black"
            >
              <span
                class="transform transition-transform duration-300 group-hover:-translate-x-4"
              >
                Visit littlepigeon.com.au
              </span>
              <span
                class="absolute right-5 -translate-x-4 transform opacity-0 transition-all duration-300 group-hover:translate-x-0 group-hover:opacity-100"
              >
                &rarr;
              </span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Last updated -->
  <section class="pb-12">
    <div class="px-4 md:px-8">
      <p
        class="text-xs font-bold tracking-widest text-neutral-900 uppercase dark:text-white"
      >
        Last updated · June 2026
      </p>
    </div>
  </section>

  <!-- Next / Back nav -->
  <section class="border-t-2 border-zinc-100 py-16 dark:border-zinc-800">
    <div
      class="flex flex-col items-center justify-between gap-6 px-4 sm:flex-row md:px-8"
    >
      <a
        href="/case-studies"
        class="inline-flex items-center gap-2 font-bold text-neutral-500 transition-colors hover:text-black dark:text-neutral-400 dark:hover:text-white"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"><path d="m15 18-6-6 6-6"></path></svg
        >
        All case studies
      </a>
      <a
        href="/#contact"
        class="group relative inline-flex h-12 items-center justify-center overflow-hidden rounded-full bg-black px-8 font-bold text-white transition-all duration-300 dark:bg-white dark:text-black"
      >
        <span
          class="transform transition-transform duration-300 group-hover:-translate-x-4"
        >
          Get in touch
        </span>
        <span
          class="absolute right-5 -translate-x-4 transform opacity-0 transition-all duration-300 group-hover:translate-x-0 group-hover:opacity-100"
        >
          &rarr;
        </span>
      </a>
    </div>
  </section>
</MainLayout>
