---
import MainLayout from "../../layouts/MainLayout.astro";

const caseStudy = {
    title: "Little Pigeon Massage & Waxing",
    subtitle: "A calm, conversion-focused marketing site for a Melbourne wellness studio — built on Astro with image-heavy storytelling, integrated booking, gift cards, a journal, and serverless contact forms.",
    client: "Little Pigeon Massage & Waxing",
    year: "2025",
    role: "Designer & Full-Stack Developer",
    stack: ["Astro 6", "Tailwind CSS v4", "Alpine.js", "Lucide Icons", "Vercel", "Resend"],
    tags: ["Web Design", "Development", "Astro"],
    emoji: "🕊️",
};

const outcomes = [
    { value: "10+", label: "Pages Shipped" },
    { value: "0", label: "Monthly CMS Cost" },
    { value: "100%", label: "Static & Fast" },
    { value: "1", label: "Owner Inbox" },
];

const problems = [
    {
        title: "Outdated Wix Presence",
        description:
            "The studio's existing site was hosted on a heavy template-builder platform — slow on mobile, hard to update, and visually generic for a brand that trades on calm, premium hospitality.",
    },
    {
        title: "Fragmented Booking & Enquiry",
        description:
            "Appointments, gift card sales, and general enquiries lived across multiple third-party tools with no single funnel guiding visitors from interest to booking.",
    },
    {
        title: "Local Discoverability",
        description:
            "The business needed to rank for massage and waxing search terms across the local area and surface key service pages — services, FAQs, and seasonal promotions — to convert browsers into bookings.",
    },
    {
        title: "Content That Couldn't Breathe",
        description:
            "A growing library of treatment imagery, testimonials, and a wellness journal needed a home that prioritised editorial-style layout over busy template chrome.",
    },
];

const solutions = [
    {
        letter: "A",
        title: "Astro-Powered Static Architecture",
        description:
            "Rebuilt the entire site on Astro 6 with the Vercel adapter, producing a fast, mostly-static experience with progressive enhancement only where needed. Pages compile to lightweight HTML with optimised images via Astro's built-in pipeline.",
    },
    {
        letter: "B",
        title: "Editorial Layout with Premium Imagery",
        description:
            "Designed an image-led visual system using AVIF assets, considered typography pairings from Fontsource (Hepta Slab, Manrope, Outfit), and a soft, on-brand palette that lets the studio's photography lead the story.",
    },
    {
        letter: "C",
        title: "Dedicated Conversion Pages",
        description:
            "Built standalone routes for Services, Book Appointment, Gift Cards, FAQ, Contact, an Autumn Promo landing page, and a Journal — each tuned for a specific intent so paid and organic traffic land on the right surface.",
    },
    {
        letter: "D",
        title: "Serverless Contact + Messenger Hand-off",
        description:
            "Form submissions flow through a Resend-backed Astro API route to the owner's inbox, while Facebook Messenger and WhatsApp components capture mobile visitors who prefer to chat. No third-party form SaaS, no monthly fees.",
    },
];

const projectDetails = [
    { label: "Client", value: "Little Pigeon Massage & Waxing" },
    { label: "Industry", value: "Wellness / Beauty Services" },
    { label: "Location", value: "Melbourne, VIC" },
    { label: "Type", value: "Multi-page Marketing Site + Journal" },
    { label: "Live URL", value: "littlepigeon.com.au" },
];
---

<MainLayout
    title="Little Pigeon — Case Study | Simon Eramo"
    description="How I designed and built a calm, conversion-focused multi-page marketing site for Little Pigeon Massage & Waxing using Astro, Tailwind CSS, and a serverless contact backend."
>
    <!-- Hero -->
    <section class="py-20 md:py-28 border-b-2 border-zinc-100 dark:border-zinc-800">
        <div class="px-4 md:px-8">
            <div class="flex items-center gap-3 mb-8">
                <a
                    href="/case-studies"
                    class="inline-flex items-center gap-1.5 text-sm font-bold text-neutral-500 dark:text-neutral-400 hover:text-black dark:hover:text-white transition-colors"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
                    Case Studies
                </a>
                <span class="text-neutral-300 dark:text-neutral-600">/</span>
                <span class="text-xs font-bold uppercase tracking-widest text-neutral-400">Web Design</span>
            </div>

            <div class="max-w-4xl">
                <p class="text-xs font-bold uppercase tracking-widest text-neutral-500 dark:text-neutral-400 mb-4">
                    {caseStudy.client} · {caseStudy.year}
                </p>
                <div class="flex items-start gap-5 mb-6">
                    <span class="text-6xl md:text-7xl shrink-0 mt-1" aria-hidden="true">{caseStudy.emoji}</span>
                    <h1
                        id="case-study-heading"
                        class="text-4xl md:text-6xl font-black leading-tight text-pretty"
                    >
                        {caseStudy.title}
                    </h1>
                </div>
                <p class="text-xl font-medium text-neutral-600 dark:text-neutral-400 mb-8 max-w-2xl leading-relaxed">
                    {caseStudy.subtitle}
                </p>

                <div class="flex flex-wrap items-center gap-4 mb-8">
                    <a
                        href="https://littlepigeon.com.au"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-2 font-bold text-sm px-4 py-2 rounded-full border-2 border-zinc-200 dark:border-zinc-700 hover:border-black dark:hover:border-white transition-colors"
                    >
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>
                        View live site
                    </a>
                </div>

                <!-- Meta strip -->
                <div class="flex flex-wrap gap-6 pt-8 border-t-2 border-zinc-100 dark:border-zinc-800">
                    <div>
                        <p class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-1">Role</p>
                        <p class="font-bold text-sm">{caseStudy.role}</p>
                    </div>
                    <div>
                        <p class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-1">Year</p>
                        <p class="font-bold text-sm">{caseStudy.year}</p>
                    </div>
                    <div>
                        <p class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-1">Stack</p>
                        <p class="font-bold text-sm">{caseStudy.stack.join(" · ")}</p>
                    </div>
                </div>
            </div>

            <!-- Hero product screenshot -->
            <div
                class="mt-12 max-w-2xl mx-auto rounded-2xl overflow-hidden border-2 border-zinc-200 dark:border-zinc-700/50 shadow-xl"
            >
                <img
                    src="/images/little-pigeon-home.png"
                    alt="Little Pigeon Massage & Waxing — homepage showing the studio's hero, services and editorial imagery"
                    class="w-full h-auto block"
                    loading="eager"
                />
            </div>
        </div>
    </section>

    <!-- Outcomes -->
    <section class="py-16 bg-zinc-50 dark:bg-neutral-900">
        <div class="px-4 md:px-8">
            <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-4xl mx-auto text-center">
                {outcomes.map((o) => (
                    <div class="p-6 md:p-8 rounded-2xl border-2 border-zinc-200 dark:border-zinc-700/50 bg-white dark:bg-zinc-900">
                        <span class="block text-3xl md:text-5xl font-black mb-2 text-black dark:text-white">
                            {o.value}
                        </span>
                        <span class="text-xs font-bold text-neutral-500 dark:text-neutral-400 uppercase tracking-widest">
                            {o.label}
                        </span>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Project Details + Challenge -->
    <section class="py-20">
        <div class="px-4 md:px-8">
            <div class="grid md:grid-cols-3 gap-12 max-w-6xl">
                <!-- Project details sidebar -->
                <div class="md:col-span-1">
                    <p class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-3">Project Details</p>
                    <div class="space-y-4">
                        {projectDetails.map((d) => (
                            <div>
                                <p class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-0.5">{d.label}</p>
                                <p class="font-bold text-sm">{d.value}</p>
                            </div>
                        ))}
                        <div>
                            <p class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-2">Tech Stack</p>
                            <div class="flex flex-col gap-1">
                                {[
                                    { name: "Astro 6", role: "Framework" },
                                    { name: "Tailwind CSS v4", role: "Styling" },
                                    { name: "Alpine.js", role: "Interactivity" },
                                    { name: "Lucide Icons", role: "Iconography" },
                                    { name: "Vercel", role: "Hosting" },
                                    { name: "Resend", role: "Email API" },
                                ].map((t) => (
                                    <div class="flex items-center justify-between py-1.5 border-b border-zinc-100 dark:border-zinc-800">
                                        <span class="font-black text-sm">{t.name}</span>
                                        <span class="text-xs text-neutral-500 dark:text-neutral-400 font-medium">{t.role}</span>
                                    </div>
                                ))}
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Challenge -->
                <div class="md:col-span-2 space-y-8">
                    <div>
                        <p class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-3">The Challenge</p>
                        <h2 class="text-3xl font-black mb-5">Turning a Beloved Local Studio Into a Bookable Brand Online</h2>
                        <p class="text-lg font-medium text-neutral-700 dark:text-neutral-300 leading-relaxed mb-8">
                            Little Pigeon is a boutique massage and waxing studio with a loyal local following. Their existing presence didn't reflect the calm, considered experience of the space, and key conversion paths — booking, gift cards, seasonal promos — were buried behind generic template chrome. The new site had to feel like the studio itself: warm, premium, and effortless to navigate.
                        </p>
                        <div class="space-y-5">
                            {problems.map((p) => (
                                <div class="flex gap-4">
                                    <span class="mt-1 w-2 h-2 rounded-full bg-red-500 shrink-0" />
                                    <div>
                                        <h3 class="font-black text-base mb-1">{p.title}</h3>
                                        <p class="text-neutral-600 dark:text-neutral-400 font-medium leading-relaxed text-sm">{p.description}</p>
                                    </div>
                                </div>
                            ))}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Solutions -->
    <section class="py-20 bg-zinc-50 dark:bg-neutral-900">
        <div class="px-4 md:px-8">
            <div class="grid md:grid-cols-3 gap-12 max-w-6xl">
                <div class="md:col-span-1">
                    <p class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-3">Solutions</p>
                    <h2 class="text-3xl font-black mb-4">How We Solved It</h2>
                </div>
                <div class="md:col-span-2 space-y-6">
                    {solutions.map((s) => (
                        <div class="flex gap-5 p-6 rounded-xl border-2 border-zinc-200 dark:border-zinc-700/50 bg-white dark:bg-zinc-900 hover:border-zinc-400 dark:hover:border-zinc-500 transition-colors">
                            <span class="w-9 h-9 rounded-lg bg-black dark:bg-white text-white dark:text-black font-black text-sm flex items-center justify-center shrink-0">
                                {s.letter}
                            </span>
                            <div>
                                <h3 class="font-black text-base mb-2">{s.title}</h3>
                                <p class="text-neutral-600 dark:text-neutral-400 font-medium leading-relaxed text-sm">
                                    {s.description}
                                </p>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </section>

    <!-- Result -->
    <section class="py-20">
        <div class="px-4 md:px-8">
            <div class="grid md:grid-cols-3 gap-12 max-w-6xl">
                <div class="md:col-span-1">
                    <p class="text-xs font-bold uppercase tracking-widest text-neutral-400 mb-3">Result</p>
                    <h2 class="text-3xl font-black mb-4">A Calm Site That Converts</h2>
                </div>
                <div class="md:col-span-2 space-y-6">
                    <p class="text-lg font-medium text-neutral-700 dark:text-neutral-300 leading-relaxed">
                        The new Little Pigeon site replaces a slow, generic template with a fast, image-led Astro build that mirrors the in-studio experience. Every page is purpose-built — services explain treatments, the booking page guides clients in, gift cards and seasonal promos have dedicated landing pages, and the journal gives the brand a long-term content surface.
                    </p>
                    <p class="text-lg font-medium text-neutral-700 dark:text-neutral-300 leading-relaxed">
                        With static delivery on Vercel, a serverless contact form, and full code ownership, the studio runs on near-zero ongoing platform cost while keeping room to grow.
                    </p>
                    <ul class="space-y-4 pt-2">
                        <li class="flex items-start gap-3 text-neutral-700 dark:text-neutral-300 font-medium text-lg">
                            <span class="mt-1.5 w-2 h-2 rounded-full bg-green-500 shrink-0" />
                            <span><strong class="text-black dark:text-white">Dedicated conversion routes</strong> for booking, gift cards, services, FAQ, and seasonal promos.</span>
                        </li>
                        <li class="flex items-start gap-3 text-neutral-700 dark:text-neutral-300 font-medium text-lg">
                            <span class="mt-1.5 w-2 h-2 rounded-full bg-green-500 shrink-0" />
                            <span><strong class="text-black dark:text-white">Editorial journal</strong> giving the brand a long-term content surface for SEO and storytelling.</span>
                        </li>
                        <li class="flex items-start gap-3 text-neutral-700 dark:text-neutral-300 font-medium text-lg">
                            <span class="mt-1.5 w-2 h-2 rounded-full bg-green-500 shrink-0" />
                            <span><strong class="text-black dark:text-white">Serverless contact backend</strong> via Resend — enquiries land directly in the owner's inbox.</span>
                        </li>
                        <li class="flex items-start gap-3 text-neutral-700 dark:text-neutral-300 font-medium text-lg">
                            <span class="mt-1.5 w-2 h-2 rounded-full bg-green-500 shrink-0" />
                            <span><strong class="text-black dark:text-white">Optimised imagery & sitemap</strong> using Astro's built-in image pipeline and sitemap integration.</span>
                        </li>
                    </ul>

                    <div class="pt-2">
                        <a
                            href="https://littlepigeon.com.au"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="group relative inline-flex items-center justify-center overflow-hidden h-12 px-8 font-bold text-white bg-black dark:bg-white dark:text-black transition-all duration-300 rounded-md"
                        >
                            <span class="transform transition-transform duration-300 group-hover:-translate-x-4">
                                Visit littlepigeon.com.au
                            </span>
                            <span class="absolute right-5 transform -translate-x-4 opacity-0 transition-all duration-300 group-hover:translate-x-0 group-hover:opacity-100">
                                &rarr;
                            </span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Next / Back nav -->
    <section class="py-16 border-t-2 border-zinc-100 dark:border-zinc-800">
        <div class="px-4 md:px-8 flex flex-col sm:flex-row items-center justify-between gap-6">
            <a
                href="/case-studies"
                class="inline-flex items-center gap-2 font-bold text-neutral-500 dark:text-neutral-400 hover:text-black dark:hover:text-white transition-colors"
            >
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
                All case studies
            </a>
            <a
                href="/#contact"
                class="group relative inline-flex items-center justify-center overflow-hidden h-12 px-8 font-bold text-white bg-black dark:bg-white dark:text-black transition-all duration-300 rounded-md"
            >
                <span class="transform transition-transform duration-300 group-hover:-translate-x-4">
                    Get in touch
                </span>
                <span class="absolute right-5 transform -translate-x-4 opacity-0 transition-all duration-300 group-hover:translate-x-0 group-hover:opacity-100">
                    &rarr;
                </span>
            </a>
        </div>
    </section>
</MainLayout>
