  </section>

  <!-- GitHub Stats Section -->
  <section id="github" class="py-20">
    <div class="container mx-auto max-w-7xl px-4 md:px-8">
      <div class="mx-auto text-center">
        <p
          class="mb-2 text-xs font-bold tracking-widest text-neutral-700 uppercase dark:text-neutral-400"
        >
          Open Source
        </p>
        <h2 class="mb-4 text-5xl font-black">GitHub activity</h2>
        <p
          class="font-regular mb-12 text-center text-lg text-neutral-600 dark:text-neutral-400"
        >
          A live snapshot of my contributions over the last year.
        </p>
      </div>

      <!-- Contribution graph -->
      <a
        href="https://github.com/simoneramo"
        target="_blank"
        rel="noopener noreferrer"
        class="mx-auto block max-w-4xl rounded-lg bg-zinc-50 p-6 transition-colors hover:bg-zinc-100 md:p-8 dark:bg-zinc-800 dark:hover:bg-zinc-700/70"
        aria-label="View Simon Eramo's GitHub contribution graph"
      >
        <div
          class="mb-4 flex items-baseline justify-between gap-4 text-sm font-bold"
        >
          <span class="text-neutral-800 dark:text-neutral-200">
            516 contributions in the last year
          </span>
          <span class="text-neutral-800 dark:text-neutral-200"> 57 repos </span>
        </div>
        <img
          class="w-full"
          src="https://ghchart.rshah.org/simoneramo"
          alt="Simon Eramo's GitHub contributions over the last year"
          loading="lazy"
        />
