---
import MainLayout from "../layouts/MainLayout.astro";
import { getEntry } from "astro:content";
import { Image } from "astro:assets";
import meHero from "../assets/me-hero.jpg";

const homepageData = await getEntry("homepage", "index");
if (!homepageData) {
  throw new Error("Homepage data not found");
}
const contactForm = homepageData.data.contactForm;
const hero = homepageData.data.hero;
const skills = homepageData.data.skills;
const testimonials = homepageData.data.testimonials;

// Social links shown in the contact section.
