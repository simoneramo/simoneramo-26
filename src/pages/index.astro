  <!-- Contact Section -->
  <section id="contact" class="py-20">
    <div
      class="container mx-auto grid max-w-6xl items-center gap-12 px-8 md:grid-cols-2"
    >
      <div class="text-left">
        <p
          class="mb-2 text-xs font-bold tracking-widest text-neutral-600 uppercase dark:text-neutral-400"
        >
          Contact me
        </p>
        <h2
          id="contact-heading"
          class="mb-4 text-5xl font-black dark:text-neutral-200"
        >
          Get in touch
        </h2>

        <p
          class="font-regular mb-6 text-lg text-neutral-600 dark:text-neutral-400"
        >
          I’m always open to new collaborations and projects.<br />If you have
          something in mind, send me a message!
        </p>

        <a
          href="/simon-eramo-cv.pdf"
          target="_blank"
          rel="noopener noreferrer"
          class="mb-8 inline-flex items-center gap-2 rounded-full border-2 border-zinc-200 px-6 py-3 font-bold transition-colors hover:border-black dark:border-zinc-700 dark:hover:border-white"
        >
          <svg
            class="h-5 w-5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
            <path d="M14 2v6h6" />
            <path d="M16 13H8" />
            <path d="M16 17H8" />
            <path d="M10 9H8" />
          </svg>
          View my CV
        </a>

        <div class="flex items-center gap-5">
          {
            socials.map((social) => (
              <a
                href={social.url}
                target={social.url.startsWith("mailto:") ? undefined : "_blank"}
                rel={
                  social.url.startsWith("mailto:")
                    ? undefined
                    : "noopener noreferrer"
                }
                aria-label={social.platform}
                class="text-neutral-500 transition-colors hover:text-black dark:text-neutral-400 dark:hover:text-white"
              >
                <svg
                  class="h-6 w-6"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path d={social.icon} />
                </svg>
              </a>
            ))
          }
        </div>
      </div>

      <form
        class="space-y-6 rounded-xl border-2 border-neutral-100 bg-white p-6 text-left md:p-8 dark:border-zinc-800 dark:bg-zinc-800"
        x-data="{
                        name: '',
                        email: '',
                        message: '',
                        isSubmitting: false,
                        showSuccess: false,
                        showError: false,
                        errorMessage: '',
                        touched: {
                            name: false,
                            email: false,
                            message: false
                        },
                        errors: {
                            name: false,
                            email: false,
                            message: false
                        },

                        validateName() {
                            this.errors.name = this.touched.name && this.name.trim().length < 2;
                        },

                        validateEmail() {
                            if (!this.touched.email) return;
                            const isValid = this.email && this.email.includes('@') && this.email.includes('.') && this.email.length > 5;
                            this.errors.email = !isValid;
                        },

                        validateMessage() {
                            this.errors.message = this.touched.message && this.message.trim().length < 10;
                        },

                        async submitForm() {
                            this.touched.name = true;
                            this.touched.email = true;
                            this.touched.message = true;

                            this.validateName();
                            this.validateEmail();
                            this.validateMessage();

                            if (this.errors.name || this.errors.email || this.errors.message) {
                                return;
                            }

                            this.isSubmitting = true;
                            this.showError = false;

                            try {
                                const response = await fetch('/api/contact', {
                                    method: 'POST',
                                    headers: {
                                        'Content-Type': 'application/json',
                                    },
                                    body: JSON.stringify({
                                        name: this.name,
                                        email: this.email,
                                        subject: 'Contact from Homepage',
                                        message: this.message
                                    })
                                });

                                const data = await response.json();

                                if (response.ok) {
                                    this.showSuccess = true;
                                    this.name = '';
                                    this.email = '';
                                    this.message = '';
                                    this.touched = { name: false, email: false, message: false };
                                    this.errors = { name: false, email: false, message: false };

                                    setTimeout(() => this.showSuccess = false, 5000);
                                } else {
                                    this.showError = true;
                                    this.errorMessage = data.error || 'Failed to send message. Please try again.';
                                    setTimeout(() => this.showError = false, 5000);
                                }
                            } catch (error) {
                                this.showError = true;
                                this.errorMessage = 'Network error. Please check your connection and try again.';
                                setTimeout(() => this.showError = false, 5000);
                            } finally {
                                this.isSubmitting = false;
                            }
                        }
                    }"
        @submit.prevent="submitForm()"
      >
        <div
          x-show="showSuccess"
          x-transition
          class="mb-6 rounded-md border-l-4 border-green-500 bg-green-100 p-4 text-green-700"
          role="alert"
        >
          <p class="font-bold">
            {contactForm.successMessage.title}
          </p>
          <p>{contactForm.successMessage.description}</p>
        </div>

        <div
          x-show="showError"
          x-transition
          class="mb-6 rounded-md border-l-4 border-red-600 bg-red-100 p-4 text-red-700"
          role="alert"
        >
          <p class="font-bold">Error sending message</p>
          <p x-text="errorMessage"></p>
        </div>

        <div>
          <label for="name" class="mb-2 block font-bold"
            >{contactForm.nameField.label}</label
          >
          <input
            type="text"
            id="name"
            x-model="name"
            @blur="touched.name = true; validateName()"
            @input="touched.name && validateName()"
            class="w-full rounded-md border-2 bg-transparent p-4 placeholder-neutral-500 transition-colors outline-none focus:border-black focus:bg-white focus:text-black focus:ring-0 dark:focus:border-zinc-200 dark:focus:bg-zinc-800 dark:focus:text-white"
            :class="errors.name ? 'border-red-600' : 'border-neutral-200 dark:border-neutral-600'"
            :aria-invalid="errors.name"
            aria-describedby="name-error"
            placeholder={contactForm.nameField.placeholder}
          />
          <span
            id="name-error"
            x-show="errors.name"
            class="mt-1 block font-medium text-red-600 dark:text-red-600"
            role="alert"
          >
            {contactForm.nameField.errorMessage}
          </span>
        </div>

        <div>
          <label for="email" class="mb-2 block font-bold"
            >{contactForm.emailField.label}</label
          >
          <input
            type="email"
            id="email"
            x-model="email"
            @blur="touched.email = true; validateEmail()"
            @input="touched.email && validateEmail()"
            class="w-full rounded-md border-2 bg-transparent p-4 placeholder-neutral-500 transition-colors outline-none focus:border-black focus:bg-white focus:text-black focus:ring-0 dark:focus:border-zinc-200 dark:focus:bg-zinc-800 dark:focus:text-white"
            :class="errors.email ? 'border-red-600' : 'border-neutral-200 dark:border-neutral-600'"
            :aria-invalid="errors.email"
            aria-describedby="email-error"
            placeholder={contactForm.emailField.placeholder}
          />
          <span
            id="email-error"
            x-show="errors.email"
            class="mt-1 block font-medium text-red-600 dark:text-red-600"
            role="alert"
          >
            {contactForm.emailField.errorMessage}
          </span>
        </div>

        <div>
          <label for="message" class="mb-2 block font-bold"
            >{contactForm.messageField.label}</label
          >
          <textarea
            id="message"
            rows="4"
            x-model="message"
            @blur="touched.message = true; validateMessage()"
            @input="touched.message && validateMessage()"
            class="w-full rounded-md border-2 bg-transparent p-4 placeholder-neutral-500 transition-colors outline-none focus:border-black focus:bg-white focus:text-black focus:ring-0 dark:focus:border-zinc-200 dark:focus:bg-zinc-800 dark:focus:text-white"
            :class="errors.message ? 'border-red-600' : 'border-neutral-200 dark:border-neutral-600'"
            :aria-invalid="errors.message"
            aria-describedby="message-error"
            placeholder={contactForm.messageField.placeholder}></textarea>
          <span
            id="message-error"
            x-show="errors.message"
            class="mt-1 block font-medium text-red-600 dark:text-red-600"
            role="alert"
          >
            {contactForm.messageField.errorMessage}
          </span>
        </div>

        <button
          type="submit"
          :disabled="isSubmitting"
          class="group relative flex w-full cursor-pointer items-center justify-center overflow-hidden rounded-full bg-black py-4 font-bold tracking-wider text-white transition-all duration-300 disabled:cursor-not-allowed disabled:opacity-50 dark:bg-white dark:text-black"
        >
          <div
            x-show="!isSubmitting"
            class="relative flex items-center justify-center px-10"
          >
            <span
              class="transform transition-transform duration-300 group-hover:-translate-x-4"
            >
              {contactForm.submitButton.text}
            </span>
            <span
              class="absolute right-6 -translate-x-4 transform opacity-0 transition-all duration-300 group-hover:translate-x-0 group-hover:opacity-100"
            >
              &rarr;
            </span>
          </div>

          <span x-show="isSubmitting"
            >{contactForm.submitButton.loadingText}</span
          >
        </button>
        <p class="mt-4 text-center text-sm text-black dark:text-neutral-400">
          {contactForm.privacyNote}
        </p>
      </form>
    </div>
  </section>
</MainLayout>
