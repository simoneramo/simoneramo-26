---

<MainLayout>
  <!-- Hero Section -->
  <section class="py-20">
    <div class="px-4 md:px-8">
      <div class="grid items-center gap-12 md:grid-cols-5">
        <div class="text-center md:col-span-3 md:text-left">
          <p
            class="mb-4 flex items-center justify-center gap-2 text-xs font-bold tracking-widest text-neutral-600 uppercase md:justify-start dark:text-neutral-400"
          >
            Available for hire
          </p>
          <h1
            id="hero-heading"
            class="mb-4 max-w-3xl text-5xl font-black text-pretty md:text-6xl"
          >
            Creating clean, functional, and user-centered digital solutions
          </h1>
          <p
            class="font-regular mb-10 max-w-xl text-lg text-neutral-600 md:text-xl dark:text-gray-200"
          >
            I'm a Melbourne-based UI/UX Product Designer with 13 years of
            experience. I specialize in creating clean, functional, and
            user-centered digital solutions.
          </p>
          <div
            class="flex flex-col justify-center gap-4 sm:flex-row md:justify-start"
          >
            <a
              href={hero.buttonLink}
              class="group relative inline-flex h-14 items-center justify-center overflow-hidden rounded-full bg-black px-10 text-lg font-bold text-white transition-all duration-300 hover:bg-black dark:bg-white dark:text-black dark:hover:bg-white"
            >
              <span
                class="transform transition-transform duration-300 group-hover:-translate-x-4"
              >
                Get in touch
              </span>
              <span
                class="absolute right-6 -translate-x-4 transform opacity-0 transition-all duration-300 group-hover:translate-x-0 group-hover:opacity-100"
              >
                &rarr;
              </span>
            </a>
          </div>
          <!-- <p
                        class="mt-8 text-md font-black text-purple-500 dark:text-purple-800"
                    >
                        {hero.trustBadge}
                    </p> -->
        </div>

        <div
          class="relative mt-12 flex aspect-square items-center justify-center overflow-hidden rounded-full md:col-span-2 md:mt-0"
        >
          <Image
            src={meHero}
            alt="Simon Eramo"
            class="h-[90%] w-[90%] rounded-full object-cover"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Clients and Projects -->
  <section class="overflow-hidden pt-10 pb-14">
    <div class="px-4 md:px-8">
      <h2
        class="mb-8 text-center text-xs font-bold tracking-widest text-neutral-600 uppercase dark:text-neutral-400"
      >
        Clients and projects that I've worked on
      </h2>
      <div class="relative w-full overflow-hidden">
        <div
          class="animate-scroll flex w-max items-center gap-32 hover:[animation-play-state:paused]"
        >
          {
            /* Duplicate logos for seamless infinite scroll */
            [...Array(4)].map(() => (
              <div class="flex shrink-0 items-center gap-32">
                <img
                  src="/logos/monash.svg"
                  alt="Monash University"
                  class="h-8 w-auto dark:brightness-0 dark:invert"
                />
                <img
                  src="/logos/worksafe.svg"
                  alt="WorkSafe Victoria"
                  class="h-10 w-auto"
                />
                <img
                  src="/logos/mirvac.svg"
                  alt="Mirvac"
                  class="h-8 w-auto dark:brightness-0 dark:invert"
                />
                <img
                  src="/logos/RMIT.svg"
                  alt="RMIT University"
                  class="h-8 w-auto dark:brightness-0 dark:invert"
                />
                <img
                  src="/logos/vic-gov.svg"
                  alt="Victoria State Government"
                  class="h-10 w-auto"
                />
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <style>
    @keyframes marquee {
      0% {
        transform: translateX(0%);
      }
      100% {
        transform: translateX(-100%);
      }
    }

    @keyframes marquee2 {
      0% {
        transform: translateX(100%);
      }
      100% {
        transform: translateX(0%);
      }
    }

    .animate-marquee {
      animation: marquee 60s linear infinite;
    }

    .animate-marquee2 {
      animation: marquee2 60s linear infinite;
    }

    /* Pause on hover */
    section:hover .animate-marquee,
    section:hover .animate-marquee2 {
      animation-play-state: paused;
    }

    @keyframes scroll {
      0% {
        transform: translateX(0);
      }

      100% {
        transform: translateX(-50%);
      }
    }

    .animate-scroll {
      animation: scroll 80s linear infinite;
    }

    .animate-scroll-slow {
      animation: scroll 180s linear infinite;
    }

    .animate-scroll:hover,
    .animate-scroll-slow:hover {
      animation-play-state: paused;
    }
    @keyframes spin-slow {
      from {
        transform: rotate(0deg);
      }
      to {
        transform: rotate(360deg);
      }
    }

    .animate-spin-slow {
      animation: spin-slow 40s linear infinite;
    }
  </style>

  <!-- Skills Section -->
  <section id="skills" class="py-20">
    <div class="container mx-auto max-w-7xl px-4 md:px-8">
      <div class="mx-auto text-center">
        <p
          class="mb-2 text-xs font-bold tracking-widest text-neutral-600 uppercase dark:text-neutral-400"
        >
          Capabilities
        </p>
        <h2 class="mb-4 text-5xl font-black">Core competencies</h2>
        <p
          class="font-regular mb-12 text-center text-lg text-neutral-600 dark:text-neutral-400"
        >
          A versatile skillset bridging the gap between design and development.
        </p>
      </div>

      <div class="grid gap-8 md:grid-cols-3">
        {
          skills.items.map((skill) => (
            <article class="rounded-lg bg-zinc-50 p-4 transition-colors md:p-8 dark:bg-zinc-800">
              <span class="mb-4 block text-4xl">{skill.icon}</span>

              <h3 class="mb-2 text-xl font-black">{skill.title}</h3>
              <p class="font-regular leading-relaxed text-neutral-700 dark:text-neutral-400">
                {skill.description}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- About Me Section -->
  <section id="about" class="bg-zinc-50 py-20 dark:bg-neutral-900">
    <div class="container mx-auto max-w-3xl px-4 text-center md:px-8">
      <span class="mb-4 block text-5xl">👋</span>

      <div
        class="font-regular space-y-6 text-left text-lg leading-relaxed text-neutral-800 md:text-center lg:text-xl dark:text-neutral-400"
      >
        <p>
          I am a dedicated <strong class="dark:text-white"
            >UI/UX & Product Designer</strong
          > with over a decade of experience crafting elegant, intuitive digital solutions
          that simplify the user experience.
        </p>
        <p>
          My six-year tenure at WorkSafe Victoria has been foundational. Most
          recently, I’ve collaborated with senior leads within the Design
          Practice to deliver high-impact projects, specialising in the <strong
            class="dark:text-white">end-to-end design process</strong
          >. From in-depth user research and synthesis to high-fidelity
          prototyping and iterative testing, I ensure every solution is grounded
          in user needs.
        </p>
        <p>
          I am particularly passionate about the intersection of
          <strong class="dark:text-white"
            >visual design and accessibility</strong
          >. A career highlight includes my contribution to our internal <strong
            class="dark:text-white">Design System</strong
          >, where I built scalable, consistent libraries that significantly
          improved development workflow efficiency.
        </p>
        <p>
          I am currently exploring how <strong class="dark:text-white"
            >AI-driven workflows</strong
          > can enhance design efficiency and effectiveness. Parallel to this, I am
          launching a design and development agency focused on high-performance, <strong
            class="dark:text-white">headless websites</strong
          > for small businesses—leveraging a modern stack including <strong
            class="dark:text-white"
            >Astro, TinaCMS, Tailwind CSS, and Vercel.</strong
          >
        </p>
        <p>
          I am a collaborative problem-solver who thrives in fast-paced
          environments, currently seeking a new opportunity to contribute to a
          team building impactful, user-centric products.
        </p>
      </div>
    </div>
  </section>

  <!-- Professional Experience Section -->
  <section class="py-20" id="experience">
    <div class="px-4 md:px-8">
      <div class="mb-16 text-center">
        <p
          class="mb-4 text-xs font-bold tracking-widest text-neutral-600 uppercase dark:text-neutral-400"
        >
          Career History
        </p>
        <h2 class="mb-6 text-4xl font-black md:text-5xl">
          Professional experience
        </h2>
        <p
          class="font-regular mb-12 text-center text-lg text-neutral-600 dark:text-neutral-400"
        >
          A timeline of my role history and professional growth over the last
          decade.
        </p>
      </div>

      <div
        class="relative space-y-12 before:absolute before:inset-0 before:ml-5 before:h-full before:w-0.5 before:-translate-x-px before:bg-linear-to-b before:from-transparent before:via-neutral-200 before:to-transparent md:before:mx-auto md:before:translate-x-0 dark:before:via-zinc-800"
      >
        {
          professionalExperience.map((job, index) => (
            <div class="group is-active relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse">
              <div class="ml-2 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-zinc-500 text-xl md:order-1 md:ml-0 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2 dark:bg-zinc-600" />
              <div class="rounded-xls w-[calc(100%-4rem)] rounded-xl bg-zinc-50 p-6 md:w-[calc(50%-1.5rem)] dark:bg-zinc-900/50">
                <img
                  src={job.logo}
                  alt="Company Logo"
                  class="mb-4 h-12 w-auto"
                />
                <h3 class="mb-1 text-xl font-black text-neutral-800 dark:text-neutral-200">
                  {job.role}
                </h3>
                <p class="mb-2 text-lg font-bold text-neutral-800 dark:text-zinc-200">
                  {job.company}
                </p>
                <p class="text-text-neutral-800 mb-6 text-xs font-bold tracking-wide uppercase dark:text-neutral-400">
                  {job.location} • {job.date}
                </p>
                <ul class="space-y-2">
                  {job.points.map((point) => (
                    <li class="text-md flex items-start gap-3 leading-relaxed font-medium text-neutral-700 dark:text-neutral-400">
                      <span class="mt-1.5 h-1 w-1 shrink-0 rounded-full bg-black dark:bg-white" />
                      {point}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Scrolling Testimonials Section -->
  <section class="overflow-hidden py-20">
    <div class="mb-12 px-8 text-center">
      <p
        class="mb-2 text-xs font-bold tracking-widest text-neutral-600 uppercase dark:text-neutral-400"
      >
        Expert Endorsement
      </p>
      <h2 class="mb-4 text-5xl font-black">Backed by industry peers</h2>
      <p
        class="font-regular mx-auto max-w-2xl text-lg text-neutral-600 dark:text-neutral-400"
      >
        Don't just take my word for it. Here's what industry peers have to say
        about working with me.
      </p>
    </div>

    <div class="group relative w-full overflow-hidden">
      <div
        class="animate-scroll-slow flex w-max gap-8 hover:[animation-play-state:paused]"
      >
        {
          /* Create 4 sets of testimonials to ensure smooth infinite scroll even on wide screens */
          [...Array(4)].map(() => (
            <div class="flex shrink-0 gap-8">
              {testimonials.items.map((testimonial, index) => (
                <div class="flex w-[500px] shrink-0 flex-col rounded-xl bg-zinc-100 p-8 dark:bg-zinc-800">
                  <p class="mb-6 line-clamp-4 text-lg font-medium text-neutral-700 dark:text-neutral-300">
                    "{testimonial.quote}"
                  </p>
                  <div class="mt-auto flex items-center gap-4">
                    <div
                      class={`flex h-12 w-12 items-center justify-center rounded-full text-xl font-bold ${index % 4 === 0 ? "bg-yellow-300 text-yellow-800" : ""} ${index % 4 === 1 ? "bg-purple-300 text-purple-800" : ""} ${index % 4 === 2 ? "bg-blue-300 text-blue-800" : ""} ${index % 4 === 3 ? "bg-green-300 text-green-800" : ""} `}
                    >
                      {testimonial.authorName.charAt(0)}
                    </div>
                    <div>
                      <div class="text-lg font-bold dark:text-neutral-200">
                        {testimonial.authorName}
                      </div>
                      <div class="text-sm font-medium text-neutral-600 dark:text-neutral-400">
                        {testimonial.authorTitle}
                      </div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Tools I Use Section -->
  <section class="pt-20 pb-32">
    <div class="container mx-auto px-4 md:px-8">
      <div class="mb-16 text-center">
        <p
          class="mb-4 text-xs font-bold tracking-widest text-neutral-600 uppercase dark:text-neutral-400"
        >
          My toolkit
        </p>
        <h2 class="mb-6 text-4xl font-black md:text-5xl">
          Tools that I use and love
        </h2>
        <p
          class="font-regular mx-auto mb-12 max-w-2xl text-lg text-neutral-600 dark:text-neutral-400"
        >
          I rely on a modern, robust tech stack to deliver secure, scalable, and
          high-performance digital products.
        </p>
      </div>

      <div
        class="grid grid-cols-2 items-center justify-items-center gap-8 md:grid-cols-6"
      >
        <div class="flex flex-col items-center gap-2">
          <img src="/logos/astro.svg" alt="Astro" class="h-20 w-auto" />
          <span class="text-sm font-bold text-neutral-600 dark:text-neutral-400"
            >Astro</span
          >
        </div>
        <div class="flex flex-col items-center gap-2">
          <img
            src="/logos/tailwindcss.svg"
            alt="Tailwind CSS"
            class="h-20 w-auto"
          />
          <span class="text-sm font-bold text-neutral-600 dark:text-neutral-400"
            >Tailwind CSS</span
          >
        </div>
        <div class="flex flex-col items-center gap-2">
          <img src="/logos/tina.svg" alt="TinaCMS" class="h-20 w-auto" />
          <span class="text-sm font-bold text-neutral-600 dark:text-neutral-400"
            >TinaCMS</span
          >
        </div>
        <div class="flex flex-col items-center gap-2">
          <img src="/logos/figma.svg" alt="Figma" class="h-20 w-auto" />
          <span class="text-sm font-bold text-neutral-600 dark:text-neutral-400"
            >Figma</span
          >
        </div>
        <div class="flex flex-col items-center gap-2">
          <img
            src="/logos/antigravity.svg"
            alt="Antigravity"
            class="h-20 w-auto"
          />
          <span class="text-sm font-bold text-neutral-600 dark:text-neutral-400"
            >Antigravity</span
          >
        </div>
        <div class="flex flex-col items-center gap-2">
          <img src="/logos/claude.svg" alt="Claude" class="h-20 w-auto" />
          <span class="text-sm font-bold text-neutral-600 dark:text-neutral-400"
            >Claude Code</span
          >
        </div>
      </div>
