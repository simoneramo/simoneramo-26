---
import MainLayout from "../layouts/MainLayout.astro";
import { getEntry } from "astro:content";

const homepageData = await getEntry("homepage", "index");
if (!homepageData) {
    throw new Error("Homepage data not found");
}
const contactForm = homepageData.data.contactForm;
const hero = homepageData.data.hero;
const skills = homepageData.data.skills;
const testimonials = homepageData.data.testimonials;

const professionalExperience = [
    {
        role: "Freelance Full Stack Designer",
        company: "Simon Eramo",
        location: "Melbourne, Australia",
        date: "Jan 2026 – Present",
        logo: "/logos/simon-eramo-26.png",
        color: "#8b5cf6",
        points: [
            "Designing and developing high-performance, headless websites using a modern stack: Astro, TinaCMS, and Tailwind CSS.",
            "Leveraging Vercel for global edge deployment and GitHub for secure version control to build scalable, production-ready applications.",
            "Focusing on technical excellence, accessibility (WCAG), and conversion strategy to help small businesses compete digitally.",
            "Utilising AI-driven workflows (Gemini, Claude, Codex, OpenClaw) to accelerate development, optimize code, and enhance creative ideation.",
        ],
    },
    {
        role: "UI/UX Designer",
        company: "WorkSafe Victoria",
        location: "Geelong, VIC, Australia",
        date: "June 2019 – December 2025",
        logo: "/logos/worksafe.png",
        color: "#FDB813",
        points: [
            "Spearheaded end-to-end design activities across multiple high-priority projects, moving from initial user research and synthesis through to low and high-fidelity prototyping and final delivery.",
            "Pivoted core product experiences by collaborating effectively with Product Owners, BAs, developers, and testers, translating complex requirements into actionable design roadmaps.",
            "Established and maintained the Figma design system and component libraries, ensuring design consistency across agency platforms and supporting accelerated team velocity.",
            "Conducted in-depth user interviews and usability testing, synthesising qualitative and quantitative data to identify user needs and validate design solutions, ensuring product roadmaps were user-led.",
            "Drove visual design excellence, utilising expert proficiency in Figma to create and maintain accessible, beautiful, and genuinely easy-to-use user interfaces (UI) and design components.",
        ],
    },
    {
        role: "Design Lead / Digital Designer",
        company: "Social Garden",
        location: "Melbourne, Australia",
        date: "July 2015 – March 2018",
        logo: "/logos/social-garden.svg",
        color: "#20E28F",
        points: [
            "Lowered conversion goals for lead generation campaigns across property and education sectors, delivering great results that always exceeded expectations by raising average rates from 3.5% to above 5%.",
            "Optimised and delivered over 200 high-volume campaigns, ensuring design was focused on conversion while demonstrating an amazing creative eye that aesthetically elevated client brands—a rare dual skill set.",
            "Led a design change to implement a human-centred and design thinking approach across all aspects of the business, fostering a user-first culture.",
            "Trained and mentored a design team of up to 8 members on process, strategy, visual design, conversion optimisation, productivity, and well-being.",
            "Redesigned the lead generation campaign process from end to end, significantly improving team collaboration, productivity, quality, and overall results.",
        ],
    },
    {
        role: "Freelance UI/UX Designer",
        company: "Simon Eramo",
        location: "Melbourne, Australia",
        date: "December 2012 – June 2019",
        logo: "/logos/simon-eramo.png",
        color: "#FF1563",
        points: [
            "Managed end-to-end design for a portfolio of small to medium clients, spanning website creation, marketing creative, and corporate identity projects.",
            "Proactively acquired and mastered front-end design and development tools (Sketch App, Sublime Text, Visual Code Studio, Modular CSS) to enhance design-to-development handoff and understanding.",
            "Improved knowledge and application of core design methodologies, including design history, Lean, Agile, and advanced user experience processes.",
        ],
    },
    {
        role: "Digital Designer / Front End Developer",
        company: "ID Digital Agency",
        location: "Melbourne, Australia",
        date: "August 2013 – June 2014",
        logo: "/logos/id-digital.svg",
        color: "#333333",
        points: [
            "Provided end-to-end website creation services, including account management, User Experience design, Visual Design, and Front-end Development.",
            "Created a front-end and modular HTML and CSS framework to enable quick setup and development of web applications, improving team efficiency.",
        ],
    },
    {
        role: "Freelance Web Designer",
        company: "Thirst Studios",
        location: "Melbourne, Australia",
        date: "Jan 2012 - Mar 2013",
        logo: "/logos/thirst-studios.svg",
        color: "#8AC73E",
        points: [
            "Website creation in a small team of 3, working on small to medium sized clients.",
            "Learnt Expression Engine including PHP, designed and built websites from end to end.",
        ],
    },
];
---

<MainLayout>
    <!-- Hero Section -->
    <section class="py-20">
        <div class="px-4 md:px-8">
            <div class="grid md:grid-cols-5 gap-12 items-center">
                <div class="md:col-span-3 text-center md:text-left">
                    <p
                        class="text-xs font-bold uppercase tracking-widest text-neutral-800 dark:text-neutral-400 mb-4 flex items-center justify-center md:justify-start gap-2"
                    >
                        <span class="relative flex h-2 w-2">
                            <span
                                class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"
                            ></span>
                            <span
                                class="relative inline-flex rounded-full h-2 w-2 bg-green-600"
                            ></span>
                        </span>
                        Available for hire
                    </p>
                    <h1
                        id="hero-heading"
                        class="text-5xl md:text-6xl max-w-3xl text-pretty font-black mb-4"
                    >
                        Creating clean, functional, and user-centered digital
                        solutions
                    </h1>
                    <p
                        class="text-lg md:text-xl font-medium mb-10 max-w-xl text-neutral-600 dark:text-gray-200"
                    >
                        I'm a Melbourne-based UI/UX Product Designer with 13
                        years of experience. I specialize in creating clean,
                        functional, and user-centered digital solutions.
                    </p>
                    <div
                        class="flex flex-col sm:flex-row md:justify-start justify-center gap-4"
                    >
                        <a
                            href={hero.buttonLink}
                            class="group relative inline-flex items-center justify-center overflow-hidden h-14 px-10 font-bold text-white bg-black dark:bg-white dark:text-black transition-all duration-300 text-lg rounded-md hover:bg-black dark:hover:bg-white"
                        >
                            <span
                                class="transform transition-transform duration-300 group-hover:-translate-x-4"
                            >
                                Get in touch
                            </span>
                            <span
                                class="absolute right-6 transform -translate-x-4 opacity-0 transition-all duration-300 group-hover:translate-x-0 group-hover:opacity-100"
                            >
                                &rarr;
                            </span>
                        </a>
                    </div>
                    <!-- <p
                        class="mt-8 text-md font-black text-purple-500 dark:text-purple-800"
                    >
                        {hero.trustBadge}
                    </p> -->
                </div>

                <div
                    class="md:col-span-2 relative aspect-square overflow-hidden rounded-full flex items-center justify-center mt-12 md:mt-0"
                >
                    <img
                        src="/images/me-hero.jpg"
                        alt="Simon Eramo"
                        class="w-[90%] h-[90%] object-cover rounded-full"
                    />
                </div>
            </div>
        </div>
    </section>

    <!-- Clients and Projects -->
    <section class="pt-10 pb-14 overflow-hidden">
        <div class="px-4 md:px-8">
            <h2
                class="text-xs font-bold text-neutral-700 dark:text-neutral-400 mb-8 uppercase tracking-widest"
            >
                Clients and projects that I've worked on
            </h2>
            <div class="relative w-full overflow-hidden">
                <div
                    class="flex animate-scroll hover:[animation-play-state:paused] gap-32 w-max items-center"
                >
                    {
                        /* Duplicate logos for seamless infinite scroll */
                        [...Array(4)].map(() => (
                            <div class="flex gap-32 items-center shrink-0">
                                <img
                                    src="/logos/monash.svg"
                                    alt="Monash University"
                                    class="h-8 w-auto dark:brightness-0 dark:invert"
                                />
                                <img
                                    src="/logos/worksafe.svg"
                                    alt="WorkSafe Victoria"
                                    class="h-10 w-auto"
                                />
                                <img
                                    src="/logos/mirvac.svg"
                                    alt="Mirvac"
                                    class="h-8 w-auto dark:brightness-0 dark:invert"
                                />
                                <img
                                    src="/logos/RMIT.svg"
                                    alt="RMIT University"
                                    class="h-8 w-auto dark:brightness-0 dark:invert"
                                />
                                <img
                                    src="/logos/vic-gov.svg"
                                    alt="Victoria State Government"
                                    class="h-10 w-auto"
                                />
                            </div>
                        ))
                    }
                </div>
            </div>
        </div>
    </section>

    <style>
        @keyframes marquee {
            0% {
                transform: translateX(0%);
            }
            100% {
                transform: translateX(-100%);
            }
        }

        @keyframes marquee2 {
            0% {
                transform: translateX(100%);
            }
            100% {
                transform: translateX(0%);
            }
        }

        .animate-marquee {
            animation: marquee 60s linear infinite;
        }

        .animate-marquee2 {
            animation: marquee2 60s linear infinite;
        }

        /* Pause on hover */
        section:hover .animate-marquee,
        section:hover .animate-marquee2 {
            animation-play-state: paused;
        }

        @keyframes scroll {
            0% {
                transform: translateX(0);
            }

            100% {
                transform: translateX(-50%);
            }
        }

        .animate-scroll {
            animation: scroll 80s linear infinite;
        }

        .animate-scroll-slow {
            animation: scroll 180s linear infinite;
        }

        .animate-scroll:hover,
        .animate-scroll-slow:hover {
            animation-play-state: paused;
        }
        @keyframes spin-slow {
            from {
                transform: rotate(0deg);
            }
            to {
                transform: rotate(360deg);
            }
        }

        .animate-spin-slow {
            animation: spin-slow 40s linear infinite;
        }
    </style>

    <!-- Skills Section -->
    <section id="skills" class="py-20">
        <div class="px-4 md:px-8">
            <div class="mx-auto text-center">
                <p
                    class="text-xs font-bold uppercase tracking-widest text-neutral-700 dark:text-neutral-400 mb-2"
                >
                    Capabilities
                </p>
                <h2 class="text-5xl font-black mb-4">Core competencies</h2>
                <p
                    class="text-center text-lg text-black dark:text-neutral-200 mb-12 font-medium"
                >
                    A versatile skillset bridging the gap between design and
                    development.
                </p>
            </div>

            <div class="grid md:grid-cols-3 gap-8">
                {
                    skills.items.map((skill) => (
                        <article class="border-2 border-zinc-200 dark:border-zinc-700/40 p-4 md:p-8 rounded-lg transition-colors">
                            <span class="text-4xl mb-4 block">
                                {skill.icon}
                            </span>

                            <h3 class="text-xl font-black mb-2">
                                {skill.title}
                            </h3>
                            <p class="leading-relaxed text-neutral-700 dark:text-neutral-400 font-regular">
                                {skill.description}
                            </p>
                        </article>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- About Me Section -->
    <section id="about" class="py-20 bg-zinc-50 dark:bg-neutral-900">
        <div class="container mx-auto px-4 md:px-8 max-w-3xl text-center">
            <span class="text-5xl mb-4 block">👋</span>

            <h2 class="text-4xl md:text-5xl font-black mb-12">
                Simpler, better, faster
            </h2>

            <div
                class="space-y-6 text-lg text-neutral-800 dark:text-neutral-400 font-regular leading-relaxed text-left md:text-center"
            >
                <p>
                    I am a dedicated <strong class="dark:text-white"
                        >UI/UX & Product Designer</strong
                    > with over a decade of experience crafting elegant, intuitive
                    digital solutions that simplify the user experience.
                </p>
                <p>
                    My six-year tenure at WorkSafe Victoria has been
                    foundational. Most recently, I’ve collaborated with senior
                    leads within the Design Practice to deliver high-impact
                    projects, specialising in the <strong
                        class="dark:text-white"
                        >end-to-end design process</strong
                    >. From in-depth user research and synthesis to
                    high-fidelity prototyping and iterative testing, I ensure
                    every solution is grounded in user needs.
                </p>
                <p>
                    I am particularly passionate about the intersection of
                    <strong class="dark:text-white"
                        >visual design and accessibility</strong
                    >. A career highlight includes my contribution to our
                    internal <strong class="dark:text-white"
                        >Design System</strong
                    >, where I built scalable, consistent libraries that
                    significantly improved development workflow efficiency.
                </p>
                <p>
                    I am currently exploring how <strong class="dark:text-white"
                        >AI-driven workflows</strong
                    > can enhance design efficiency and effectiveness. Parallel to
                    this, I am launching a design and development agency focused on
                    high-performance, <strong class="dark:text-white"
                        >headless websites</strong
                    > for small businesses—leveraging a modern stack including <strong
                        class="dark:text-white"
                        >Astro, TinaCMS, Tailwind CSS, and Vercel.</strong
                    >
                </p>
                <p>
                    I am a collaborative problem-solver who thrives in
                    fast-paced environments, currently seeking a new opportunity
                    to contribute to a team building impactful, user-centric
                    products.
                </p>
            </div>
        </div>
    </section>

    <!-- Professional Experience Section -->
    <section class="py-20" id="experience">
        <div class="px-4 md:px-8">
            <div class="text-center mb-16">
                <p
                    class="text-xs font-bold uppercase tracking-widest text-neutral-500 dark:text-neutral-400 mb-4"
                >
                    Career History
                </p>
                <h2 class="text-4xl md:text-5xl font-black mb-6">
                    Professional experience
                </h2>
                <p
                    class="text-center text-lg text-black dark:text-neutral-200 mb-12 font-medium"
                >
                    A timeline of my role history and professional growth over
                    the last decade.
                </p>
            </div>

            <div
                class="space-y-12 relative before:absolute before:inset-0 before:ml-5 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-0.5 before:bg-linear-to-b before:from-transparent before:via-neutral-200 before:to-transparent dark:before:via-zinc-800"
            >
                {
                    professionalExperience.map((job, index) => (
                        <div class="relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group is-active">
                            <div class="flex items-center justify-center w-6 h-6 rounded-full shrink-0 md:order-1 ml-2 md:ml-0 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2 text-xl bg-zinc-500 dark:bg-zinc-600" />
                            <div class="w-[calc(100%-4rem)] md:w-[calc(50%-1.5rem)] p-6 rounded-xl bg-zinc-50 dark:bg-zinc-900/50 rounded-xls">
                                <img
                                    src={job.logo}
                                    alt="Company Logo"
                                    class="h-12 w-auto mb-4"
                                />
                                <h3 class="text-xl font-black text-neutral-800 dark:text-neutral-200 mb-1">
                                    {job.role}
                                </h3>
                                <p class="font-bold text-lg text-neutral-800 dark:text-zinc-200 mb-2">
                                    {job.company}
                                </p>
                                <p class="text-xs font-bold text-text-neutral-800 dark:text-neutral-400 mb-6 uppercase tracking-wide">
                                    {job.location} • {job.date}
                                </p>
                                <ul class="space-y-2">
                                    {job.points.map((point) => (
                                        <li class="flex items-start gap-3 text-md text-neutral-700 dark:text-neutral-400 font-medium leading-relaxed">
                                            <span class="mt-1.5 w-1 h-1 bg-black dark:bg-white rounded-full shrink-0" />
                                            {point}
                                        </li>
                                    ))}
                                </ul>
                            </div>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- Scrolling Testimonials Section -->
    <section class="py-20 overflow-hidden">
        <div class="px-8 mb-12 text-center">
            <p
                class="text-xs font-bold uppercase tracking-widest text-neutral-800 dark:text-neutral-400 mb-2"
            >
                Expert Endorsement
            </p>
            <h2 class="text-5xl font-black mb-4">Backed by industry peers</h2>
            <p
                class="text-lg font-medium text-neutral-600 dark:text-neutral-400 max-w-2xl mx-auto"
            >
                Don't just take my word for it. Here's what industry peers have
                to say about working with me.
            </p>
        </div>

        <div class="relative w-full overflow-hidden group">
            <div
                class="flex animate-scroll-slow hover:[animation-play-state:paused] gap-8 w-max"
            >
                {
                    /* Create 4 sets of testimonials to ensure smooth infinite scroll even on wide screens */
                    [...Array(4)].map(() => (
                        <div class="flex gap-8 shrink-0">
                            {testimonials.items.map((testimonial, index) => (
                                <div class="w-[500px] shrink-0 bg-zinc-100 dark:bg-zinc-800 p-8 rounded-xl flex flex-col">
                                    <p class="text-lg font-medium text-neutral-700 dark:text-neutral-300 mb-6 line-clamp-4">
                                        "{testimonial.quote}"
                                    </p>
                                    <div class="flex items-center gap-4 mt-auto">
                                        <div
                                            class={`w-12 h-12 rounded-full flex items-center justify-center font-bold text-xl
                                            ${index % 4 === 0 ? "bg-yellow-300 text-yellow-800" : ""}
                                            ${index % 4 === 1 ? "bg-purple-300 text-purple-800" : ""}
                                            ${index % 4 === 2 ? "bg-blue-300 text-blue-800" : ""}
                                            ${index % 4 === 3 ? "bg-green-300 text-green-800" : ""}
                                        `}
                                        >
                                            {testimonial.authorName.charAt(0)}
                                        </div>
                                        <div>
                                            <div class="font-bold text-lg dark:text-neutral-200">
                                                {testimonial.authorName}
                                            </div>
                                            <div class="text-sm font-medium text-neutral-600 dark:text-neutral-400">
                                                {testimonial.authorTitle}
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            ))}
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- Tools We Use Section -->
    <section class="pt-20 pb-32">
        <div class="container mx-auto px-4 md:px-8">
            <div class="text-center mb-16">
                <p
                    class="text-xs font-bold uppercase tracking-widest text-neutral-500 mb-4"
                >
                    My toolkit
                </p>
                <h2 class="text-4xl md:text-5xl font-black mb-6">
                    Tools that I use and love
                </h2>
                <p
                    class="text-lg text-black dark:text-neutral-200 mb-12 max-w-2xl font-medium mx-auto"
                >
                    I rely on a modern, robust tech stack to deliver secure,
                    scalable, and high-performance digital products.
                </p>
            </div>

            <div
                class="grid grid-cols-2 md:grid-cols-6 gap-8 items-center justify-items-center"
            >
                <div class="flex flex-col items-center gap-2">
                    <img
                        src="/logos/astro.svg"
                        alt="Astro"
                        class="h-20 w-auto"
                    />
                    <span
                        class="text-sm font-bold text-neutral-600 dark:text-neutral-400"
                        >Astro</span
                    >
                </div>
                <div class="flex flex-col items-center gap-2">
                    <img
                        src="/logos/tailwindcss.svg"
                        alt="Tailwind CSS"
                        class="h-20 w-auto"
                    />
                    <span
                        class="text-sm font-bold text-neutral-600 dark:text-neutral-400"
                        >Tailwind CSS</span
                    >
                </div>
                <div class="flex flex-col items-center gap-2">
                    <img
                        src="/logos/tina.svg"
                        alt="TinaCMS"
                        class="h-20 w-auto"
                    />
                    <span
                        class="text-sm font-bold text-neutral-600 dark:text-neutral-400"
                        >TinaCMS</span
                    >
                </div>
                <div class="flex flex-col items-center gap-2">
                    <img
                        src="/logos/figma.svg"
                        alt="Figma"
                        class="h-20 w-auto"
                    />
                    <span
                        class="text-sm font-bold text-neutral-600 dark:text-neutral-400"
                        >Figma</span
                    >
                </div>
                <div class="flex flex-col items-center gap-2">
                    <img
                        src="/logos/antigravity.svg"
                        alt="Antigravity"
                        class="h-20 w-auto"
                    />
                    <span
                        class="text-sm font-bold text-neutral-600 dark:text-neutral-400"
                        >Antigravity</span
                    >
                </div>
                <div class="flex flex-col items-center gap-2">
                    <img
                        src="/logos/claude.svg"
                        alt="Claude"
                        class="h-20 w-auto"
                    />
                    <span
                        class="text-sm font-bold text-neutral-600 dark:text-neutral-400"
                        >Claude Code</span
                    >
                </div>
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="py-20">
        <div
            class="container mx-auto max-w-6xl px-8 items-center grid md:grid-cols-2 gap-12"
        >
            <div class="text-left">
                <p
                    class="text-xs font-bold uppercase tracking-widest text-neutral-800 dark:text-neutral-200 mb-2"
                >
                    Contact me
                </p>
                <h2
                    id="contact-heading"
                    class="text-5xl font-black mb-4 dark:text-neutral-200"
                >
                    Get in touch
                </h2>

                <p
                    class="mb-6 text-neutral-600 font-medium dark:text-neutral-400 text-lg"
                >
                    I’m always open to new collaborations and projects.<br />If
                    you have something in mind, send me a message!
                </p>
                <p
                    class="mb-2 text-neutral-600 font-medium dark:text-neutral-400"
                >
                    Folio and Case studies available on request.
                </p>
            </div>

            <form
                class="text-left space-y-6 border-2 border-neutral-100 dark:border-zinc-800 bg-white dark:bg-zinc-800 p-6 md:p-8 rounded-xl"
                x-data="{
                        name: '',
                        email: '',
                        message: '',
                        isSubmitting: false,
                        showSuccess: false,
                        showError: false,
                        errorMessage: '',
                        touched: {
                            name: false,
                            email: false,
                            message: false
                        },
                        errors: {
                            name: false,
                            email: false,
                            message: false
                        },

                        validateName() {
                            this.errors.name = this.touched.name && this.name.trim().length < 2;
                        },

                        validateEmail() {
                            if (!this.touched.email) return;
                            const isValid = this.email && this.email.includes('@') && this.email.includes('.') && this.email.length > 5;
                            this.errors.email = !isValid;
                        },

                        validateMessage() {
                            this.errors.message = this.touched.message && this.message.trim().length < 10;
                        },

                        async submitForm() {
                            this.touched.name = true;
                            this.touched.email = true;
                            this.touched.message = true;

                            this.validateName();
                            this.validateEmail();
                            this.validateMessage();

                            if (this.errors.name || this.errors.email || this.errors.message) {
                                return;
                            }

                            this.isSubmitting = true;
                            this.showError = false;

                            try {
                                const response = await fetch('/api/contact', {
                                    method: 'POST',
                                    headers: {
                                        'Content-Type': 'application/json',
                                    },
                                    body: JSON.stringify({
                                        name: this.name,
                                        email: this.email,
                                        subject: 'Contact from Homepage',
                                        message: this.message
                                    })
                                });

                                const data = await response.json();

                                if (response.ok) {
                                    this.showSuccess = true;
                                    this.name = '';
                                    this.email = '';
                                    this.message = '';
                                    this.touched = { name: false, email: false, message: false };
                                    this.errors = { name: false, email: false, message: false };

                                    setTimeout(() => this.showSuccess = false, 5000);
                                } else {
                                    this.showError = true;
                                    this.errorMessage = data.error || 'Failed to send message. Please try again.';
                                    setTimeout(() => this.showError = false, 5000);
                                }
                            } catch (error) {
                                this.showError = true;
                                this.errorMessage = 'Network error. Please check your connection and try again.';
                                setTimeout(() => this.showError = false, 5000);
                            } finally {
                                this.isSubmitting = false;
                            }
                        }
                    }"
                @submit.prevent="submitForm()"
            >
                <div
                    x-show="showSuccess"
                    x-transition
                    class="p-4 bg-green-100 border-l-4 border-green-500 text-green-700 mb-6 rounded-md"
                    role="alert"
                >
                    <p class="font-bold">
                        {contactForm.successMessage.title}
                    </p>
                    <p>{contactForm.successMessage.description}</p>
                </div>

                <div
                    x-show="showError"
                    x-transition
                    class="p-4 bg-red-100 border-l-4 border-red-600 text-red-700 mb-6 rounded-md"
                    role="alert"
                >
                    <p class="font-bold">Error sending message</p>
                    <p x-text="errorMessage"></p>
                </div>

                <div>
                    <label for="name" class="block font-bold mb-2"
                        >{contactForm.nameField.label}</label
                    >
                    <input
                        type="text"
                        id="name"
                        x-model="name"
                        @blur="touched.name = true; validateName()"
                        @input="touched.name && validateName()"
                        class="w-full p-4 bg-transparent border-2 focus:bg-white focus:text-black focus:border-black dark:focus:bg-zinc-800 dark:focus:text-white dark:focus:border-zinc-200 transition-colors outline-none focus:ring-0 placeholder-neutral-500 rounded-md"
                        :class="errors.name ? 'border-red-600' : 'border-neutral-200 dark:border-zinc-600'"
                        :aria-invalid="errors.name"
                        aria-describedby="name-error"
                        placeholder={contactForm.nameField.placeholder}
                    />
                    <span
                        id="name-error"
                        x-show="errors.name"
                        class="text-red-600 dark:text-red-600 font-medium mt-1 block"
                        role="alert"
                    >
                        {contactForm.nameField.errorMessage}
                    </span>
                </div>

                <div>
                    <label for="email" class="block font-bold mb-2"
                        >{contactForm.emailField.label}</label
                    >
                    <input
                        type="email"
                        id="email"
                        x-model="email"
                        @blur="touched.email = true; validateEmail()"
                        @input="touched.email && validateEmail()"
                        class="w-full p-4 bg-transparent border-2 focus:bg-white focus:text-black focus:border-black dark:focus:bg-zinc-800 dark:focus:text-white dark:focus:border-zinc-200 transition-colors outline-none focus:ring-0 placeholder-neutral-500 rounded-md"
                        :class="errors.email ? 'border-red-600' : 'border-neutral-200 dark:border-zinc-600'"
                        :aria-invalid="errors.email"
                        aria-describedby="email-error"
                        placeholder={contactForm.emailField.placeholder}
                    />
                    <span
                        id="email-error"
                        x-show="errors.email"
                        class="text-red-600 dark:text-red-600 font-medium mt-1 block"
                        role="alert"
                    >
                        {contactForm.emailField.errorMessage}
                    </span>
                </div>

                <div>
                    <label for="message" class="block font-bold mb-2"
                        >{contactForm.messageField.label}</label
                    >
                    <textarea
                        id="message"
                        rows="4"
                        x-model="message"
                        @blur="touched.message = true; validateMessage()"
                        @input="touched.message && validateMessage()"
                        class="w-full p-4 bg-transparent border-2 focus:bg-white focus:text-black focus:border-black dark:focus:bg-zinc-800 dark:focus:text-white dark:focus:border-zinc-200 transition-colors outline-none focus:ring-0 placeholder-neutral-500 rounded-md"
                        :class="errors.message ? 'border-red-600' : 'border-neutral-200 dark:border-zinc-600'"
                        :aria-invalid="errors.message"
                        aria-describedby="message-error"
                        placeholder={contactForm.messageField.placeholder}
                    ></textarea>
                    <span
                        id="message-error"
                        x-show="errors.message"
                        class="text-red-600 dark:text-red-600 font-medium mt-1 block"
                        role="alert"
                    >
                        {contactForm.messageField.errorMessage}
                    </span>
                </div>

                <button
                    type="submit"
                    :disabled="isSubmitting"
                    class="w-full py-4 group relative overflow-hidden bg-black text-white dark:bg-white dark:text-black font-bold tracking-wider transition-all duration-300 disabled:opacity-50 disabled:cursor-not-allowed flex justify-center items-center rounded-md cursor-pointer"
                >
                    <div
                        x-show="!isSubmitting"
                        class="relative flex items-center justify-center px-10"
                    >
                        <span
                            class="transform transition-transform duration-300 group-hover:-translate-x-4"
                        >
                            {contactForm.submitButton.text}
                        </span>
                        <span
                            class="absolute right-6 transform -translate-x-4 opacity-0 transition-all duration-300 group-hover:translate-x-0 group-hover:opacity-100"
                        >
                            &rarr;
                        </span>
                    </div>

                    <span x-show="isSubmitting"
                        >{contactForm.submitButton.loadingText}</span
                    >
                </button>
                <p
                    class="text-sm text-center text-black dark:text-neutral-400 mt-4"
                >
                    {contactForm.privacyNote}
                </p>
            </form>
        </div>
    </section>
</MainLayout>
