const socials = [
  {
    platform: "GitHub",
    url: "https://github.com/simoneramo",
    icon: socialIcons.github,
  },
  {
    platform: "Email",
    url: "mailto:simonramo@gmail.com",
    icon: socialIcons.email,
  },
  {
    platform: "LinkedIn",
    url: "https://www.linkedin.com/in/simoneramo/",
    icon: socialIcons.linkedin,
  },
  {
    platform: "Dribbble",
    url: "https://dribbble.com/simoneramo",
    icon: socialIcons.dribbble,
  },
  {
    platform: "Instagram",
    url: "https://www.instagram.com/simon_eramo/",
    icon: socialIcons.instagram,
  },
];

const professionalExperience = [
  {
    role: "Freelance Full Stack Designer",
    company: "Simon Eramo",
    location: "Melbourne, Australia",
    date: "Jan 2026 – Present",
    logo: "/logos/simon-eramo-26.png",
    color: "#8b5cf6",
    points: [
      "Designing and developing high-performance, headless websites using a modern stack: Astro, TinaCMS, and Tailwind CSS.",
      "Leveraging Vercel for global edge deployment and GitHub for secure version control to build scalable, production-ready applications.",
      "Focusing on technical excellence, accessibility (WCAG), and conversion strategy to help small businesses compete digitally.",
      "Utilising AI-driven workflows (Gemini, Claude, Codex, OpenClaw) to accelerate development, optimize code, and enhance creative ideation.",
    ],
  },
  {
    role: "UI/UX Designer",
    company: "WorkSafe Victoria",
    location: "Geelong, VIC, Australia",
    date: "June 2019 – December 2025",
    logo: "/logos/worksafe.png",
    color: "#FDB813",
    points: [
      "Spearheaded end-to-end design activities across multiple high-priority projects, moving from initial user research and synthesis through to low and high-fidelity prototyping and final delivery.",
      "Pivoted core product experiences by collaborating effectively with Product Owners, BAs, developers, and testers, translating complex requirements into actionable design roadmaps.",
      "Established and maintained the Figma design system and component libraries, ensuring design consistency across agency platforms and supporting accelerated team velocity.",
      "Conducted in-depth user interviews and usability testing, synthesising qualitative and quantitative data to identify user needs and validate design solutions, ensuring product roadmaps were user-led.",
      "Drove visual design excellence, utilising expert proficiency in Figma to create and maintain accessible, beautiful, and genuinely easy-to-use user interfaces (UI) and design components.",
    ],
  },
  {
    role: "Digital Designer",
    company: "Social Garden",
    location: "Melbourne, Australia",
    date: "July 2015 – March 2018",
    logo: "/logos/social-garden.svg",
    color: "#20E28F",
    points: [
      "Lowered conversion goals for lead generation campaigns across property and education sectors, delivering great results that always exceeded expectations by raising average rates from 3.5% to above 5%.",
      "Optimised and delivered over 200 high-volume campaigns, ensuring design was focused on conversion while demonstrating an amazing creative eye that aesthetically elevated client brands—a rare dual skill set.",
      "Led a design change to implement a human-centred and design thinking approach across all aspects of the business, fostering a user-first culture.",
      "Trained and mentored a design team of up to 8 members on process, strategy, visual design, conversion optimisation, productivity, and well-being.",
      "Redesigned the lead generation campaign process from end to end, significantly improving team collaboration, productivity, quality, and overall results.",
    ],
  },
  {
    role: "Freelance UI/UX Designer",
    company: "Simon Eramo",
    location: "Melbourne, Australia",
    date: "December 2012 – June 2019",
    logo: "/logos/simon-eramo.png",
    color: "#FF1563",
    points: [
      "Managed end-to-end design for a portfolio of small to medium clients, spanning website creation, marketing creative, and corporate identity projects.",
      "Proactively acquired and mastered front-end design and development tools (Sketch App, Sublime Text, Visual Code Studio, Modular CSS) to enhance design-to-development handoff and understanding.",
      "Improved knowledge and application of core design methodologies, including design history, Lean, Agile, and advanced user experience processes.",
    ],
  },
  {
    role: "Digital Designer / Front End Developer",
    company: "ID Digital Agency",
    location: "Melbourne, Australia",
    date: "August 2013 – June 2014",
    logo: "/logos/id-digital.svg",
    color: "#333333",
    points: [
      "Provided end-to-end website creation services, including account management, User Experience design, Visual Design, and Front-end Development.",
      "Created a front-end and modular HTML and CSS framework to enable quick setup and development of web applications, improving team efficiency.",
    ],
  },
  {
    role: "Freelance Web Designer",
    company: "Thirst Studios",
    location: "Melbourne, Australia",
    date: "Jan 2012 - Mar 2013",
    logo: "/logos/thirst-studios.svg",
    color: "#8AC73E",
    points: [
      "Website creation in a small team of 3, working on small to medium sized clients.",
      "Learnt Expression Engine including PHP, designed and built websites from end to end.",
    ],
  },
