# Tina CMS Configuration
# Get these values from tina.io after creating a project
NEXT_PUBLIC_TINA_CLIENT_ID=your_client_id_here
TINA_TOKEN=your_token_here

# Resend Email Configuration
# Get your API key from resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here
# Email where contact form submissions will be sent
SITE_OWNER_EMAIL=your-email@example.com
# Email address to send from (must be verified in Resend, or use onboarding@resend.dev for testing)
RESEND_FROM_EMAIL=onboarding@resend.dev
